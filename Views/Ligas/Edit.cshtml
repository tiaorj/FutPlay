@model FutPlay.Models.Liga

@{
    ViewData["Title"] = "Editar Liga";
}

<div class="container mt-4">
    <h1>Editar Liga</h1>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DataCriacao" />
                <input type="hidden" asp-for="CriadorUserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CampeonatoId" class="form-label"></label>
                    <select asp-for="CampeonatoId" class="form-select" asp-items="ViewBag.CampeonatoId">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="CampeonatoId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CodigoConvite" class="form-label"></label>
                    <input asp-for="CodigoConvite" class="form-control" readonly />
                    <span asp-validation-for="CodigoConvite" class="text-danger"></span>
                </div>
                <div class="form-text">
                    Compartilhe este código com convidados para eles entrarem na sua liga.
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Publica" class="form-check-input" />
                    <label asp-for="Publica" class="form-check-label"></label>
                </div>
                <div class="form-text mb-3">
                    Liga pública aparece no catálogo. Liga privada só pode ser acessada por código de convite.
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Salvar Alterações
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}