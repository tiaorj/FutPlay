@model FutPlay.ViewModels.PalpitarLigaViewModel
@using FutPlay.Settings
@{
    ViewData["Title"] = "Palpitar na Liga";

    var totalJogos = Model.Jogos.Count;
    var pendentes = Model.Jogos.Count(j => !j.Bloqueado && !j.JaPalpitado);
    var palpitados = Model.Jogos.Count(j => j.JaPalpitado);
    var bloqueados = Model.Jogos.Count(j => j.Bloqueado);
    var pontosApurados = Model.Jogos
        .Where(j => j.JogoFinalizado && j.JaPalpitado)
        .Sum(j => j.PontosGanhos);
    var jogoDestaque = Model.Jogos.FirstOrDefault(j => !j.Bloqueado) ?? Model.Jogos.FirstOrDefault();
    var percentualConcluido = totalJogos == 0 ? 0 : Convert.ToInt32((palpitados * 100.0) / totalJogos);
    var rodadaTitulo = Model.RodadaSelecionada.HasValue
        ? $"Rodada {Model.RodadaSelecionada}"
        : "Todos os jogos";

    string NomeCurto(string? sigla, string? nome, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(sigla))
        {
            return sigla.Trim().ToUpperInvariant();
        }

        if (!string.IsNullOrWhiteSpace(nome))
        {
            return nome.Trim().Substring(0, Math.Min(3, nome.Trim().Length)).ToUpperInvariant();
        }

        return fallback;
    }

    string FormatarHorario(DateTime data)
    {
        return data.TimeOfDay == TimeSpan.Zero
            ? "Horário a definir"
            : data.ToString("HH:mm");
    }
}

<div class="container fp-score-home fp-bolao-page">

    <form asp-action="Palpitar" method="post" onsubmit="normalizarPlacaresAntesSalvar()">
        <input type="hidden" asp-for="LigaId" />
        <input type="hidden" asp-for="ParticipanteBloqueado" />
        <input type="hidden" asp-for="Origem" />
        <input type="hidden" asp-for="RodadaSelecionada" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <section class="fp-bet-header mb-3">

            <div class="fp-bet-header-ball">
                🎯
            </div>

            <div class="fp-bet-header-info">
                <span>Central de palpites</span>
                <h1>@Model.NomeLiga</h1>
                <p>@Model.NomeCampeonato</p>
            </div>

            <div class="fp-bet-header-actions">
                <a asp-action="Ranking" asp-route-id="@Model.LigaId">
                    Ranking
                </a>

                @if (string.Equals(Model.Origem, "minhasligas", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-controller="MinhasLigas" asp-action="Index">
                        Minhas Ligas
                    </a>
                }
                else
                {
                    <a asp-action="Index">
                        Ligas
                    </a>
                }
            </div>
        </section>
        <div class="row g-3 fp-picks-layout">

            <aside class="col-xl-3 col-lg-4 order-2 order-lg-1 fp-picks-sidebar">
                
                <section class="fp-home-card">
                    <div class="fp-card-header-link">
                        <h2>Participante</h2>
                    </div>

                    @if (Model.ParticipanteBloqueado)
                    {
                        <div class="fp-bet-participant-card">
                            <span>Vinculado ao usuário</span>
                            <strong>@Model.NomeParticipanteSelecionado</strong>
                            <p>Você está palpitando com o participante vinculado ao seu usuário.</p>
                        </div>

                        <input type="hidden" asp-for="LigaParticipanteId" />
                    }
                    else
                    {
                        <div class="mb-2">
                            <label asp-for="LigaParticipanteId" class="form-label fw-bold"></label>
                            <select asp-for="LigaParticipanteId"
                                    class="form-select"
                                    asp-items="Model.Participantes"
                                    onchange="carregarParticipante(this.value)">
                                <option value="">Selecione o participante...</option>
                            </select>
                            <span asp-validation-for="LigaParticipanteId" class="text-danger"></span>
                        </div>

                        <p class="fp-side-text mb-0">
                            Selecione o participante para carregar ou editar palpites já enviados.
                        </p>
                    }
                </section>

                <section class="fp-home-card mt-3">
                    <div class="fp-card-header-link">
                        <h2>Resumo</h2>
                    </div>

                    <div class="fp-score-stats-list">
                        <div>
                            <span>Pendentes</span>
                            <strong>@pendentes</strong>
                        </div>

                        <div>
                            <span>Palpitados</span>
                            <strong>@palpitados</strong>
                        </div>

                        <div>
                            <span>Bloqueados</span>
                            <strong>@bloqueados</strong>
                        </div>

                        <div>
                            <span>Conclusão</span>
                            <strong>@percentualConcluido%</strong>
                        </div>

                        <div>
                            <span>Pontos apurados</span>
                            <strong>@pontosApurados</strong>
                        </div>
                    </div>
                </section>

                <section class="fp-home-card mt-3">
                    <div class="fp-card-header-link">
                        <h2>Progresso</h2>
                    </div>

                    <div class="progress fp-bet-progress">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width: @percentualConcluido%;"
                             aria-valuenow="@percentualConcluido"
                             aria-valuemin="0"
                             aria-valuemax="100">
                        </div>
                    </div>

                    <p class="fp-side-text mt-3 mb-0">
                        Palpites são bloqueados 5 minutos antes da partida.
                    </p>
                </section>

                @if (jogoDestaque != null)
                {
                    <section class="fp-home-card mt-3 fp-bet-next-card fp-mobile-hidden">
                        <div class="fp-card-header-link">
                            <h2>Próximo jogo</h2>
                        </div>

                        <div class="fp-bet-next-match">
                            <strong>@jogoDestaque.TimeCasa</strong>
                            <b>x</b>
                            <strong>@jogoDestaque.TimeVisitante</strong>
                            <span>@jogoDestaque.DataJogo.ToString("dd/MM") · @FormatarHorario(jogoDestaque.DataJogo)</span>
                        </div>
                    </section>
                }

                <details class="futplay-rules-card fp-bet-rules-card mt-3" open>
                    <summary>
                        <span>Regras de pontuação</span>
                        <small>Como seus palpites viram pontos</small>
                    </summary>

                    <div class="futplay-points-grid fp-bet-rules-grid">
                        <div class="futplay-points-item highlight">
                            <strong>10 pts</strong>
                            <span>Placar exato</span>
                        </div>

                        <div class="futplay-points-item">
                            <strong>5 pts</strong>
                            <span>Acertar vencedor ou empate</span>
                        </div>

                        <div class="futplay-points-item">
                            <strong>+2 pts</strong>
                            <span>Gols do mandante</span>
                        </div>

                        <div class="futplay-points-item">
                            <strong>+2 pts</strong>
                            <span>Gols do visitante</span>
                        </div>

                        <div class="futplay-points-item">
                            <strong>0 pts</strong>
                            <span>Errou resultado e gols</span>
                        </div>
                    </div>

                    <div class="futplay-points-example mt-3 fp-desktop-only">
                        <strong>Exemplo:</strong>
                        se o resultado for <b>Brasil 2 x 1 Argentina</b>,
                        o palpite <b>Brasil 2 x 0 Argentina</b> vale <b>7 pontos</b>:
                        5 pelo vencedor + 2 pelos gols do Brasil.

                        <p class="futplay-points-note mt-2 mb-0">
                            No placar exato, vale a pontuação máxima de 10 pontos, sem somar bônus adicionais.
                        </p>
                    </div>
                </details>
            </aside>

            <main class="col-xl-6 col-lg-8 order-1 order-lg-2">
                <section class="fp-score-board">
                    <div class="fp-score-board-tabs">
                        <a class="active" href="#">Palpites</a>
                        <a asp-action="Ranking" asp-route-id="@Model.LigaId">Ranking</a>
                        <a asp-controller="MinhasLigas" asp-action="Index">Meu bolão</a>
                    </div>

                    <div class="fp-pick-round-summary">
                        <span>Rodada selecionada</span>
                        <strong>@rodadaTitulo</strong>
                        <small>@totalJogos jogo(s) · @pendentes pendente(s)</small>
                    </div>

                    @if (Model.Rodadas.Any())
                    {
                        <div class="fp-round-toolbar">
                            @if (Model.RodadaAnterior.HasValue)
                            {
                                <a asp-action="Palpitar"
                                   asp-route-id="@Model.LigaId"
                                   asp-route-participanteId="@Model.LigaParticipanteId"
                                   asp-route-origem="@Model.Origem"
                                   asp-route-rodada="@Model.RodadaAnterior"
                                   class="fp-round-nav">
                                    Anterior
                                </a>
                            }
                            else
                            {
                                <span class="fp-round-nav disabled">Anterior</span>
                            }

                            <div class="fp-round-select-form">
                                <select class="form-select form-select-sm"
                                        onchange="carregarRodada(this.value)">
                                    @foreach (var rodada in Model.Rodadas)
                                    {
                                        <option value="@rodada.Rodada" selected="@rodada.Selecionada">
                                            Rodada @rodada.Rodada - @rodada.TotalJogos jogo(s)
                                        </option>
                                    }
                                </select>
                            </div>

                            @if (Model.ProximaRodada.HasValue)
                            {
                                <a asp-action="Palpitar"
                                   asp-route-id="@Model.LigaId"
                                   asp-route-participanteId="@Model.LigaParticipanteId"
                                   asp-route-origem="@Model.Origem"
                                   asp-route-rodada="@Model.ProximaRodada"
                                   class="fp-round-nav">
                                    Próxima
                                </a>
                            }
                            else
                            {
                                <span class="fp-round-nav disabled">Próxima</span>
                            }
                        </div>
                    }

                    <div class="fp-score-filter-row">
                        <span class="fp-score-filter active">Todos (@totalJogos)</span>
                        <span class="fp-score-filter">Pendentes (@pendentes)</span>
                        <span class="fp-score-filter">Palpitados (@palpitados)</span>
                        <span class="fp-score-filter">Bloqueados (@bloqueados)</span>
                    </div>

                    @if (!Model.Jogos.Any())
                    {
                        <div class="fp-empty-mini m-3">
                            Nenhum jogo disponível para esta liga.
                        </div>
                    }
                    else
                    {
                        <div class="fp-bet-pick-list">
                            <div class="fp-match-list-title">
                                <span>⚽ @rodadaTitulo</span>
                                <small>@pendentes pendente(s)</small>
                            </div>

                            @for (int i = 0; i < Model.Jogos.Count; i++)
                            {
                                var jogo = Model.Jogos[i];

                                var casaMarca = NomeCurto(jogo.TimeCasaSigla, jogo.TimeCasa, "CAS");

                                var visitanteMarca = NomeCurto(jogo.TimeVisitanteSigla, jogo.TimeVisitante, "VIS");

                                var statusClass = jogo.Bloqueado
                                ? "locked"
                                : jogo.JaPalpitado
                                ? "done"
                                : "pending";

                                var statusText = jogo.Bloqueado
                                ? "Bloqueado"
                                : jogo.JaPalpitado
                                ? "Palpitado"
                                : "Pendente";

                                var metaRodada = jogo.Rodada.HasValue
                                    ? $"Rodada {jogo.Rodada}"
                                    : rodadaTitulo;

                                var horarioJogo = FormatarHorario(jogo.DataJogo);

                                <article class="fp-bet-pick-row @statusClass">
                                    <input type="hidden" asp-for="Jogos[i].JogoId" />
                                    <input type="hidden" asp-for="Jogos[i].TimeCasa" />
                                    <input type="hidden" asp-for="Jogos[i].TimeCasaSigla" />
                                    <input type="hidden" asp-for="Jogos[i].TimeVisitante" />
                                    <input type="hidden" asp-for="Jogos[i].TimeVisitanteSigla" />
                                    <input type="hidden" asp-for="Jogos[i].DataJogo" />
                                    <input type="hidden" asp-for="Jogos[i].StatusJogo" />
                                    <input type="hidden" asp-for="Jogos[i].Fase" />
                                    <input type="hidden" asp-for="Jogos[i].Grupo" />
                                    <input type="hidden" asp-for="Jogos[i].Rodada" />
                                    <input type="hidden" asp-for="Jogos[i].GolsCasaReal" />
                                    <input type="hidden" asp-for="Jogos[i].GolsVisitanteReal" />
                                    <input type="hidden" asp-for="Jogos[i].PontosGanhos" />
                                    <input type="hidden" asp-for="Jogos[i].JogoFinalizado" />
                                    <input type="hidden" asp-for="Jogos[i].JaPalpitado" />
                                    <input type="hidden" asp-for="Jogos[i].Bloqueado" />

                                    <div class="fp-bet-pick-meta">
                                        <strong>@jogo.DataJogo.ToString("dd/MM")</strong>
                                        <span>@metaRodada</span>
                                        <small>@horarioJogo</small>
                                    </div>

                                    <div class="fp-bet-pick-main">
                                        <div class="fp-pick-team fp-pick-team-home">
                                            <span class="fp-mini-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeCasaEscudoUrl))
                                                {
                                                    <img src="@jogo.TimeCasaEscudoUrl" alt="@jogo.TimeCasa" />
                                                }
                                                else
                                                {
                                                    @casaMarca
                                                }
                                            </span>

                                            <span class="fp-pick-team-name-full">@jogo.TimeCasa</span>
                                            <span class="fp-pick-team-name-short">@casaMarca</span>
                                        </div>

                                        <div class="fp-bet-pick-score">
                                            <input asp-for="Jogos[i].GolsCasaPalpite"
                                                   class="form-control js-gols-casa"
                                                   type="number"
                                                   min="0"
                                                   max="99"
                                                   inputmode="numeric"
                                                   placeholder="0"
                                                   readonly="@jogo.Bloqueado" />

                                            <span>x</span>

                                            <input asp-for="Jogos[i].GolsVisitantePalpite"
                                                   class="form-control js-gols-visitante"
                                                   type="number"
                                                   min="0"
                                                   max="99"
                                                   inputmode="numeric"
                                                   placeholder="0"
                                                   readonly="@jogo.Bloqueado" />
                                        </div>

                                        <div class="fp-pick-team fp-pick-team-away">
                                            <span class="fp-pick-team-name-full">@jogo.TimeVisitante</span>
                                            <span class="fp-pick-team-name-short">@visitanteMarca</span>

                                            <span class="fp-mini-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitanteEscudoUrl))
                                                {
                                                    <img src="@jogo.TimeVisitanteEscudoUrl" alt="@jogo.TimeVisitante" />
                                                }
                                                else
                                                {
                                                    @visitanteMarca
                                                }
                                            </span>
                                        </div>
                                    </div>

                                    <div class="fp-bet-pick-details">
                                        <span>@(string.IsNullOrWhiteSpace(jogo.Fase) ? "Fase não informada" : jogo.Fase)</span>
                                        @if (!string.IsNullOrWhiteSpace(jogo.Grupo))
                                        {
                                            <span>Grupo @jogo.Grupo</span>
                                        }

                                        @if (jogo.JogoFinalizado && jogo.TemResultadoReal)
                                        {
                                            <div class="fp-bet-real-score">
                                                <span>Resultado</span>
                                                <strong>@jogo.GolsCasaReal x @jogo.GolsVisitanteReal</strong>

                                                @if (jogo.JaPalpitado)
                                                {
                                                    <b>@jogo.PontosGanhos pts</b>
                                                }
                                                else
                                                {
                                                    <small>Sem palpite</small>
                                                }
                                            </div>
                                        }

                                        <div class="fp-bet-pick-status">
                                            <span class="@statusClass">@statusText</span>

                                            @if (jogo.Bloqueado)
                                            {
                                                <small>Prazo encerrado</small>
                                            }
                                        </div>
                                    </div>

                                    <div class="fp-bet-pick-validation">
                                        <span asp-validation-for="Jogos[i].GolsCasaPalpite"></span>
                                        <span asp-validation-for="Jogos[i].GolsVisitantePalpite"></span>
                                    </div>
                                </article>
                            }
                        </div>

                        <section class="fp-bet-save-card">
                            <div>
                                <strong>Salvar seus palpites</strong>
                                <p>
                                    Você pode alterar seus palpites enquanto o jogo não estiver bloqueado.
                                </p>
                            </div>

                            <div>
                                <button type="submit" class="btn btn-success">
                                    Salvar palpites
                                </button>

                                <a asp-action="Ranking"
                                   asp-route-id="@Model.LigaId"
                                   class="btn btn-outline-primary">
                                    Ver ranking
                                </a>
                            </div>
                        </section>
                    }
                </section>
            </main>

            <aside class="col-xl-3 d-none d-xl-block order-xl-3">
                <section class="fp-side-ad">
                    <span>Publicidade</span>
                    <strong>@AppBrand.Name</strong>
                    <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
                </section>
               
                <section class="fp-home-card mt-3">
                    <div class="fp-card-header-link">
                        <h2>Ações rápidas</h2>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-action="Ranking"
                           asp-route-id="@Model.LigaId"
                           class="btn btn-success">
                            Ranking
                        </a>

                        <a asp-controller="MinhasLigas"
                           asp-action="Index"
                           class="btn btn-outline-primary">
                            Minhas Ligas
                        </a>

                        <a asp-controller="Ligas"
                           asp-action="Index"
                           class="btn btn-outline-primary">
                            Ligas públicas
                        </a>
                    </div>
                </section>
            </aside>

        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const regras = document.querySelector(".fp-bet-rules-card");

            if (regras && window.matchMedia("(max-width: 768px)").matches) {
                regras.removeAttribute("open");
            }
        });

        function carregarParticipante(participanteId) {
            if (participanteId) {
                const url = montarUrlPalpitar();
                url.searchParams.set("participanteId", participanteId);
                window.location.href = url.pathname + url.search;
            }
        }

        function carregarRodada(rodada) {
            const url = montarUrlPalpitar();

            if (rodada) {
                url.searchParams.set("rodada", rodada);
            }

            window.location.href = url.pathname + url.search;
        }

        function montarUrlPalpitar() {
            const url = new URL('@Url.Action("Palpitar", "Ligas", new { id = Model.LigaId })', window.location.origin);
            const participanteId = document.querySelector("[name='LigaParticipanteId']")?.value;
            const origem = '@Model.Origem';
            const rodada = '@Model.RodadaSelecionada';

            if (participanteId) {
                url.searchParams.set("participanteId", participanteId);
            }

            if (origem) {
                url.searchParams.set("origem", origem);
            }

            if (rodada) {
                url.searchParams.set("rodada", rodada);
            }

            return url;
        }

        function normalizarPlacaresAntesSalvar() {
            const cards = document.querySelectorAll(".fp-bet-pick-row");

            cards.forEach(card => {
                const casa = card.querySelector(".js-gols-casa");
                const visitante = card.querySelector(".js-gols-visitante");

                if (!casa || !visitante) {
                    return;
                }

                if (casa.readOnly || visitante.readOnly) {
                    return;
                }

                const casaVazio = casa.value.trim() === "";
                const visitanteVazio = visitante.value.trim() === "";

                if (casaVazio && visitanteVazio) {
                    return;
                }

                if (!casaVazio && visitanteVazio) {
                    visitante.value = "0";
                }

                if (casaVazio && !visitanteVazio) {
                    casa.value = "0";
                }
            });
        }
    </script>
}
