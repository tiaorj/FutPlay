@model FutPlay.ViewModels.PalpitarLigaViewModel

@{
    ViewData["Title"] = "Palpitar na Liga";
    var totalJogos = Model.Jogos.Count;
    var pendentes = Model.Jogos.Count(j => !j.Bloqueado && !j.JaPalpitado);
    var palpitados = Model.Jogos.Count(j => j.JaPalpitado);
    var bloqueados = Model.Jogos.Count(j => j.Bloqueado);
    var jogoDestaque = Model.Jogos.FirstOrDefault(j => !j.Bloqueado) ?? Model.Jogos.FirstOrDefault();
    var percentualConcluido = totalJogos == 0 ? 0 : Convert.ToInt32((palpitados * 100.0) / totalJogos);
}

<div class="container futplay-portal-shell">
   
    <form asp-action="Palpitar" method="post" onsubmit="normalizarPlacaresAntesSalvar()">
        <input type="hidden" asp-for="LigaId" />
        <input type="hidden" asp-for="ParticipanteBloqueado" />
        <input type="hidden" asp-for="Origem" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-xl-9">
                <section class="futplay-pick-hero futplay-pick-hero-banner mb-4">
                    <div class="futplay-pick-hero-content">
                        <div class="futplay-pick-kicker">Central de palpites</div>
                        <h1 class="futplay-pick-title">@Model.NomeLiga</h1>
                        <p class="futplay-pick-lead">@Model.NomeCampeonato</p>

                        @if (jogoDestaque != null)
                        {
                            <div class="futplay-pick-featured-match">
                                <span>@jogoDestaque.TimeCasa</span>
                                <strong>x</strong>
                                <span>@jogoDestaque.TimeVisitante</span>
                            </div>
                        }
                    </div>

                    <div class="futplay-pick-actions">
                        <a asp-action="Ranking" asp-route-id="@Model.LigaId">Ranking</a>
                        @if (string.Equals(Model.Origem, "minhasligas", StringComparison.OrdinalIgnoreCase))
                        {
                            <a asp-controller="MinhasLigas" asp-action="Index">Voltar</a>
                        }
                        else
                        {
                            <a asp-action="Index">Voltar</a>
                        }
                    </div>
                </section>

                <section class="futplay-pick-participant mb-4">
                    @if (Model.ParticipanteBloqueado)
                    {
                        <input type="hidden" asp-for="LigaParticipanteId" />

                        <div>
                            <span>Participante vinculado</span>
                            <strong>@Model.NomeParticipanteSelecionado</strong>
                            <p>Você está palpitando com o participante vinculado ao seu usuário.</p>
                        </div>
                    }
                    else
                    {
                        <div class="futplay-pick-select">
                            <label asp-for="LigaParticipanteId" class="form-label"></label>
                            <select asp-for="LigaParticipanteId"
                                    class="form-select"
                                    asp-items="Model.Participantes"
                                    onchange="carregarParticipante(this.value)">
                                <option value="">Selecione o participante...</option>
                            </select>
                            <span asp-validation-for="LigaParticipanteId" class="text-danger"></span>
                        </div>
                        <p>Selecione o participante para carregar ou editar palpites já enviados.</p>
                    }
                </section>

                <section class="futplay-pick-progress mb-4">
                    <div class="futplay-pick-progress-head">
                        <div>
                            <strong>Progresso dos palpites</strong>
                            <span>@palpitados de @totalJogos jogos preenchidos</span>
                        </div>

                        <strong>@percentualConcluido%</strong>
                    </div>

                    <div class="progress futplay-pick-progress-bar">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width: @percentualConcluido%;"
                             aria-valuenow="@percentualConcluido"
                             aria-valuemin="0"
                             aria-valuemax="100">
                        </div>
                    </div>

                    <p>
                        Preencha os placares dos jogos disponíveis. Palpites são bloqueados 30 minutos antes da partida.
                    </p>
                </section>

                @if (!Model.Jogos.Any())
                {
                    <section class="futplay-pick-empty">
                        <h2>Nenhum jogo disponível</h2>
                        <p>
                            Ainda não há jogos cadastrados para o campeonato desta liga.
                            Assim que a tabela estiver pronta, os palpites aparecerão aqui.
                        </p>
                    </section>
                }
                else
                {
                    <section class="futplay-pick-panel">
                        <div class="futplay-pick-panel-head">
                            <h2>Jogos da rodada</h2>
                            <span>@pendentes pendentes</span>
                        </div>

                        <div class="futplay-pick-list">
                            @for (int i = 0; i < Model.Jogos.Count; i++)
                            {
                                var jogo = Model.Jogos[i];
                                var casaMarca = string.IsNullOrWhiteSpace(jogo.TimeCasa)
                                    ? "CAS"
                                    : jogo.TimeCasa.Substring(0, Math.Min(3, jogo.TimeCasa.Length)).ToUpperInvariant();
                                var visitanteMarca = string.IsNullOrWhiteSpace(jogo.TimeVisitante)
                                    ? "VIS"
                                    : jogo.TimeVisitante.Substring(0, Math.Min(3, jogo.TimeVisitante.Length)).ToUpperInvariant();
                                var cardClass = jogo.Bloqueado
                                    ? "futplay-pick-card futplay-pick-card-locked"
                                    : jogo.JaPalpitado
                                        ? "futplay-pick-card futplay-pick-card-done"
                                        : "futplay-pick-card futplay-pick-card-pending";
                                var statusClass = jogo.Bloqueado
                                    ? "futplay-pick-status futplay-pick-status-locked"
                                    : jogo.JaPalpitado
                                        ? "futplay-pick-status futplay-pick-status-done"
                                        : "futplay-pick-status futplay-pick-status-pending";
                                var statusText = jogo.Bloqueado
                                    ? "Bloqueado"
                                    : jogo.JaPalpitado
                                        ? "Já palpitado"
                                        : "Pendente";

                                <article class="@cardClass">
                                    <input type="hidden" asp-for="Jogos[i].JogoId" />
                                    <input type="hidden" asp-for="Jogos[i].TimeCasa" />
                                    <input type="hidden" asp-for="Jogos[i].TimeVisitante" />
                                    <input type="hidden" asp-for="Jogos[i].DataJogo" />
                                    <input type="hidden" asp-for="Jogos[i].Fase" />
                                    <input type="hidden" asp-for="Jogos[i].Grupo" />
                                    <input type="hidden" asp-for="Jogos[i].JaPalpitado" />
                                    <input type="hidden" asp-for="Jogos[i].Bloqueado" />

                                    <div class="futplay-pick-card-head">
                                        <div class="futplay-pick-meta">
                                            <strong>@jogo.DataJogo.ToString("dd/MM/yyyy")</strong>
                                            <span>@jogo.DataJogo.ToString("HH:mm")</span>
                                            <span>
                                                @(string.IsNullOrWhiteSpace(jogo.Fase) ? "Fase não informada" : jogo.Fase)
                                                @if (!string.IsNullOrWhiteSpace(jogo.Grupo))
                                                {
                                                    <span> | Grupo @jogo.Grupo</span>
                                                }
                                            </span>
                                        </div>

                                        <span class="@statusClass">@statusText</span>
                                    </div>

                                    @if (jogo.Bloqueado)
                                    {
                                        <div class="futplay-pick-lock">
                                            Palpite bloqueado. O prazo encerra 30 minutos antes do início da partida.
                                        </div>
                                    }

                                    <div class="futplay-pick-board">
                                        <div class="futplay-match-team futplay-pick-team">
                                            <span class="futplay-match-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeCasaEscudoUrl))
                                                {
                                                    <img src="@jogo.TimeCasaEscudoUrl" alt="@jogo.TimeCasa" />
                                                }
                                                else
                                                {
                                                    <span>@casaMarca</span>
                                                }
                                            </span>
                                            <strong>@jogo.TimeCasa</strong>
                                        </div>

                                        <div class="futplay-pick-score">
                                            <input asp-for="Jogos[i].GolsCasaPalpite"
                                                   class="form-control futplay-pick-input js-gols-casa"
                                                   type="number"
                                                   min="0"
                                                   max="99"
                                                   inputmode="numeric"
                                                   placeholder="0"
                                                   readonly="@jogo.Bloqueado" />

                                            <input asp-for="Jogos[i].GolsVisitantePalpite"
                                                   class="form-control futplay-pick-input js-gols-visitante"
                                                   type="number"
                                                   min="0"
                                                   max="99"
                                                   inputmode="numeric"
                                                   placeholder="0"
                                                   readonly="@jogo.Bloqueado" />
                                        </div>

                                        <div class="futplay-match-team futplay-match-team-away futplay-pick-team">
                                            <strong>@jogo.TimeVisitante</strong>
                                            <span class="futplay-match-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitanteEscudoUrl))
                                                {
                                                    <img src="@jogo.TimeVisitanteEscudoUrl" alt="@jogo.TimeVisitante" />
                                                }
                                                else
                                                {
                                                    <span>@visitanteMarca</span>
                                                }
                                            </span>
                                        </div>
                                    </div>

                                    <div class="futplay-pick-validation">
                                        <span asp-validation-for="Jogos[i].GolsCasaPalpite"></span>
                                        <span asp-validation-for="Jogos[i].GolsVisitantePalpite"></span>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="futplay-pick-save mt-4">
                        <div>
                            <strong>Salvar seus palpites</strong>
                            <p>
                                Você pode alterar seus palpites enquanto o jogo não estiver bloqueado.
                                Jogos bloqueados ficam apenas para consulta.
                            </p>
                        </div>

                        <div class="futplay-pick-actions">
                            <button type="submit" class="futplay-pick-action-primary">
                                Salvar palpites
                            </button>

                            <a asp-action="Ranking"
                               asp-route-id="@Model.LigaId">
                                Ver ranking
                            </a>
                        </div>
                    </section>
                }
            </div>

            <aside class="col-xl-3">
                <section class="futplay-pick-side-card mb-4">
                    <div class="futplay-pick-side-head">
                        <h2>Resumo</h2>
                    </div>
                    <div class="futplay-pick-side-stats">
                        <div>
                            <span>Pendentes</span>
                            <strong>@pendentes</strong>
                        </div>
                        <div>
                            <span>Palpitados</span>
                            <strong>@palpitados</strong>
                        </div>
                        <div>
                            <span>Bloqueados</span>
                            <strong>@bloqueados</strong>
                        </div>
                    </div>
                </section>

                <section class="futplay-pick-side-card">
                    <div class="futplay-pick-side-head">
                        <h2>Próximo jogo</h2>
                    </div>

                    @if (jogoDestaque == null)
                    {
                        <p class="futplay-pick-side-empty">Nenhum jogo disponível.</p>
                    }
                    else
                    {
                        <div class="futplay-pick-side-match">
                            <strong>@jogoDestaque.TimeCasa</strong>
                            <span>x</span>
                            <strong>@jogoDestaque.TimeVisitante</strong>
                            <small>@jogoDestaque.DataJogo.ToString("dd/MM HH:mm")</small>
                        </div>
                    }
                </section>
            </aside>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function carregarParticipante(participanteId) {
            if (participanteId) {
                window.location.href = '@Url.Action("Palpitar", "Ligas", new { id = Model.LigaId })' + '?participanteId=' + participanteId;
            }
        }

        function normalizarPlacaresAntesSalvar() {
            const cards = document.querySelectorAll(".futplay-pick-card");

            cards.forEach(card => {
                const casa = card.querySelector(".js-gols-casa");
                const visitante = card.querySelector(".js-gols-visitante");

                if (!casa || !visitante) {
                    return;
                }

                if (casa.readOnly || visitante.readOnly) {
                    return;
                }

                const casaVazio = casa.value.trim() === "";
                const visitanteVazio = visitante.value.trim() === "";

                // Se os dois estiverem vazios, não mexe.
                // Assim o jogo continua sem palpite.
                if (casaVazio && visitanteVazio) {
                    return;
                }

                // Se o usuário preencheu só um lado, completa o outro com zero.
                if (!casaVazio && visitanteVazio) {
                    visitante.value = "0";
                }

                if (casaVazio && !visitanteVazio) {
                    casa.value = "0";
                }
            });
        }
    </script>
}
