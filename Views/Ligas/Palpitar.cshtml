@model FutPlay.ViewModels.PalpitarLigaViewModel

@{
    ViewData["Title"] = "Palpitar na Liga";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Palpitar na Liga</h1>
            <p class="text-muted mb-0">
                @Model.NomeLiga - @Model.NomeCampeonato
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Voltar
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form asp-action="Palpitar" method="post">
                <input type="hidden" asp-for="LigaId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="LigaParticipanteId" class="form-label"></label>
                    <select asp-for="LigaParticipanteId" class="form-select" asp-items="Model.Participantes">
                        <option value="">Selecione o participante...</option>
                    </select>
                    <span asp-validation-for="LigaParticipanteId" class="text-danger"></span>
                </div>

                @if (!Model.Jogos.Any())
                {
                    <div class="alert alert-info">
                        Nenhum jogo cadastrado para o campeonato desta liga.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Jogo</th>
                                    <th>Fase</th>
                                    <th style="width: 220px;">Palpite</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Jogos.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            @Model.Jogos[i].DataJogo.ToString("dd/MM/yyyy HH:mm")
                                            <input type="hidden" asp-for="Jogos[i].JogoId" />
                                        </td>

                                        <td>
                                            <strong>@Model.Jogos[i].TimeCasa</strong>
                                            x
                                            <strong>@Model.Jogos[i].TimeVisitante</strong>
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(Model.Jogos[i].Fase) ? "-" : Model.Jogos[i].Fase)

                                            @if (!string.IsNullOrWhiteSpace(Model.Jogos[i].Grupo))
                                            {
                                                <span> / Grupo @Model.Jogos[i].Grupo</span>
                                            }
                                        </td>

                                        <td>
                                            @if (Model.Jogos[i].Bloqueado)
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <input asp-for="Jogos[i].GolsCasaPalpite" class="form-control form-control-sm text-center" readonly />
                                                    <span>x</span>
                                                    <input asp-for="Jogos[i].GolsVisitantePalpite" class="form-control form-control-sm text-center" readonly />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <input asp-for="Jogos[i].GolsCasaPalpite" class="form-control form-control-sm text-center" />
                                                    <span>x</span>
                                                    <input asp-for="Jogos[i].GolsVisitantePalpite" class="form-control form-control-sm text-center" />
                                                </div>

                                                <div class="small text-danger">
                                                    <span asp-validation-for="Jogos[i].GolsCasaPalpite"></span>
                                                    <span asp-validation-for="Jogos[i].GolsVisitantePalpite"></span>
                                                </div>
                                            }
                                        </td>

                                        <td>
                                            @if (Model.Jogos[i].Bloqueado)
                                            {
                                                <span class="badge bg-secondary">Bloqueado</span>
                                            }
                                            else if (Model.Jogos[i].JaPalpitado)
                                            {
                                                <span class="badge bg-success">Já palpitado</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Pendente</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            Salvar Palpites
                        </button>

                        <a asp-action="Details" asp-route-id="@Model.LigaId" class="btn btn-outline-primary">
                            Detalhes da Liga
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}