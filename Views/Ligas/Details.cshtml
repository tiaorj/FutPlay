@model FutPlay.Models.Liga

@{
    ViewData["Title"] = "Detalhes da Liga";
}

<div class="container futplay-portal-shell">
    <section class="futplay-league-hero futplay-league-hero-banner mb-4">
        <div class="futplay-league-hero-content">
            <div class="futplay-league-kicker">Detalhes da liga</div>
            <h1 class="futplay-league-title">@Model.Nome</h1>
            <p class="futplay-league-lead">@Model.Campeonato?.Nome</p>
        </div>

        <div class="futplay-league-hero-scoreboard">
            <span>Convite</span>
            <strong>@Model.CodigoConvite</strong>
            <small>@(Model.Publica ? "pública" : "privada")</small>
        </div>
    </section>

    <section class="futplay-detail-grid">
        <article class="futplay-detail-panel">
            <h2>Informações</h2>
            <dl>
                <dt>Campeonato</dt>
                <dd>@Model.Campeonato?.Nome</dd>
                <dt>Criada em</dt>
                <dd>@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt>Status</dt>
                <dd>@(Model.Ativo ? "Ativa" : "Inativa")</dd>
            </dl>
        </article>

        <article class="futplay-detail-panel">
            <h2>Ações</h2>
            <div class="futplay-detail-actions">
                <a asp-action="Ranking" asp-route-id="@Model.Id" class="futplay-detail-primary">Ranking</a>
                <a asp-action="Palpitar" asp-route-id="@Model.Id">Palpitar</a>
                @if (User.IsInRole(AppRoles.Administrador))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
                }
                <a asp-action="Index">Voltar para ligas</a>
            </div>
        </article>
    </section>
</div>
