@model FutPlay.Models.Liga

@{
    ViewData["Title"] = "Nova Liga";
}

<div class="container mt-4">
    <h1>Nova Liga</h1>

    <p class="text-muted">
        Crie uma liga para os participantes enviarem palpites.
    </p>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Liga Família Copa 2026" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CampeonatoId" class="form-label"></label>
                    <select asp-for="CampeonatoId" class="form-select" asp-items="ViewBag.CampeonatoId">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="CampeonatoId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CodigoConvite" class="form-label"></label>
                    <input asp-for="CodigoConvite" class="form-control" readonly />
                    <span asp-validation-for="CodigoConvite" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Publica" class="form-check-input" />
                    <label asp-for="Publica" class="form-check-label"></label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Salvar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}