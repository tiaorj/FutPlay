@model List<FutPlay.ViewModels.LigaCatalogoItemViewModel>

@{
    ViewData["Title"] = "Ligas";
}

<div class="container futplay-portal-shell">
    <section class="futplay-league-hero futplay-league-hero-banner mb-4">
        <div class="futplay-league-hero-content">
            <div class="futplay-league-kicker">Catálogo público</div>
            <h1 class="futplay-league-title">Ligas FutPlay</h1>
            <p class="futplay-league-lead">
                Encontre ligas públicas para participar ou entre em uma liga privada usando um código de convite.
            </p>
        </div>

        @if (User.IsInRole(AppRoles.Administrador))
        {
            <div class="futplay-league-hero-scoreboard">
                <a asp-action="Create">Nova liga</a>
            </div>
        }
    </section>

    <section class="futplay-league-invite-card mb-4">
        <div>
            <span>Recebeu um convite?</span>
            <h2>Entre em uma liga privada com código</h2>
            <p>
                Use o código enviado pelo criador da liga para participar do bolão.
            </p>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a asp-action="Entrar" class="btn btn-success">
                Inserir código
            </a>
        }
        else
        {
            <a asp-area="Identity"
               asp-page="/Account/Login"
               asp-route-returnUrl="/Ligas/Entrar"
               class="btn btn-success">
                Entrar para usar código
            </a>
        }
    </section>

    @if (!Model.Any())
    {
        <div class="futplay-league-empty">
            <div class="futplay-league-empty-mark">FP</div>
            <h2>Nenhuma liga pública encontrada</h2>
            <p>Quando houver ligas públicas disponíveis, elas aparecerão aqui.</p>
        </div>
    }
    else
    {
        <section class="futplay-league-panel">
            <div class="futplay-league-panel-head">
                <h2>Ligas públicas</h2>
                <span>@Model.Count ligas</span>
            </div>

            <div class="futplay-league-rows">
                @foreach (var item in Model)
                {
                    var liga = item.Liga;
                    <article class="futplay-league-row">
                        <div class="futplay-league-logo">
                            @if (!string.IsNullOrWhiteSpace(liga.Campeonato?.LogoUrl))
                            {
                                <img src="@liga.Campeonato.LogoUrl" alt="@liga.Campeonato.Nome" />
                            }
                            else
                            {
                                <span>FP</span>
                            }
                        </div>

                        <div class="futplay-league-row-info">
                            <span>Liga pública</span>
                            <h3>@liga.Nome</h3>
                            <p>@liga.Campeonato?.Nome</p>
                        </div>

                        <div class="futplay-league-row-points">
                            <span>Tipo</span>
                            <strong>Pública</strong>
                        </div>

                        <div class="futplay-league-actions">
                            @* Comportamento por tipo de usuário *@
                            @if (!User.Identity.IsAuthenticated)
                            {
                                <a href="/Identity/Account/Login?returnUrl=/Ligas"
                                   class="futplay-league-action-primary">
                                    Entrar
                                </a>
                            }
                            else if (item.UsuarioParticipa)
                            {
                                <a asp-action="Palpitar"
                                   asp-route-id="@liga.Id"
                                   asp-route-origem="minhasligas"
                                   class="futplay-league-action-primary">
                                    Palpitar
                                </a>

                                <a asp-controller="MinhasLigas"
                                   asp-action="Index"
                                   class="futplay-league-action-secondary">
                                    Ver em Minhas Ligas
                                </a>
                            }
                            else
                            {
                                <a asp-action="Entrar"
                                   asp-route-codigoConvite="@liga.CodigoConvite"
                                   class="futplay-league-action-primary">
                                    Entrar na Liga
                                </a>
                            }

                            <a asp-action="Ranking"
                               asp-route-id="@liga.Id"
                               class="futplay-league-action-secondary">
                                Ranking
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@liga.Id"
                               class="futplay-league-action-secondary">
                                Detalhes
                            </a>

                            @if (User.IsInRole(AppRoles.Administrador))
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@liga.Id"
                                   class="futplay-league-action-secondary">
                                    Editar
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>
