@model List<FutPlay.Models.Liga>

@{
    ViewData["Title"] = "Ligas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Ligas</h1>
            <p class="text-muted mb-0">
                Crie ligas para disputar palpites com amigos, família ou empresa.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-success">
            Nova Liga
        </a>
    </div>

    <div class="row">
        @foreach (var liga in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@liga.Nome</h5>

                        <p class="card-text mb-1">
                            <strong>Campeonato:</strong> @liga.Campeonato?.Nome
                        </p>

                        <p class="card-text mb-1">
                            <strong>Código:</strong>
                            <span class="badge bg-dark">@liga.CodigoConvite</span>
                        </p>

                        <p class="card-text mb-1">
                            <strong>Tipo:</strong>
                            @(liga.Publica ? "Pública" : "Privada")
                        </p>

                        <p class="card-text mt-2">
                            @if (liga.Ativo)
                            {
                                <span class="badge bg-success">Ativa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativa</span>
                            }
                        </p>

                        <div class="d-flex gap-2 mt-3 flex-wrap">
                            <a asp-action="Palpitar" asp-route-id="@liga.Id" class="btn btn-outline-success btn-sm">
                                Palpitar
                            </a>

                            <a asp-action="Ranking" asp-route-id="@liga.Id" class="btn btn-outline-dark btn-sm">
                                Ranking
                            </a>

                            <a asp-action="Details" asp-route-id="@liga.Id" class="btn btn-outline-primary btn-sm">
                                Detalhes
                            </a>

                            <a asp-action="Edit" asp-route-id="@liga.Id" class="btn btn-outline-success btn-sm">
                                Editar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Nenhuma liga cadastrada ainda.
        </div>
    }
</div>