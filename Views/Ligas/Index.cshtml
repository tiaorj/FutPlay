@model List<FutPlay.Models.Liga>

@{
    ViewData["Title"] = "Ligas";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Ligas</h1>
            <p class="futplay-subtitle mb-0">
                Crie ligas para disputar palpites com amigos, família ou empresa.
            </p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-success">
                + Nova Liga
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="futplay-empty">
            Nenhuma liga cadastrada ainda.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var liga in Model)
            {
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                        <div class="card-body futplay-card-content">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">
                                        @liga.Nome
                                    </h5>

                                    <small class="text-muted">
                                        @liga.Campeonato?.Nome
                                    </small>
                                </div>

                                @if (liga.Ativo)
                                {
                                    <span class="badge bg-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inativa</span>
                                }
                            </div>

                            <div class="mb-2">
                                <span class="text-muted small">Código de convite</span>
                                <div>
                                    <span class="badge bg-dark fs-6">@liga.CodigoConvite</span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <span class="text-muted small">Tipo</span>
                                <div>
                                    @if (liga.Publica)
                                    {
                                        <span class="badge bg-primary">Pública</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Privada</span>
                                    }
                                </div>
                            </div>

                            <div class="futplay-actions">
                                <a asp-action="Palpitar" asp-route-id="@liga.Id" class="btn btn-success btn-sm">
                                    Palpitar
                                </a>

                                <a asp-action="Ranking" asp-route-id="@liga.Id" class="btn btn-outline-dark btn-sm">
                                    Ranking
                                </a>

                                <a asp-action="Details" asp-route-id="@liga.Id" class="btn btn-outline-primary btn-sm">
                                    Detalhes
                                </a>

                                <a asp-action="Edit" asp-route-id="@liga.Id" class="btn btn-outline-secondary btn-sm">
                                    Editar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>