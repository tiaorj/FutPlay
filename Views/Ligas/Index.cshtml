@model List<FutPlay.Models.Liga>

@{
    ViewData["Title"] = "Ligas";
}

<div class="container futplay-portal-shell">
    <section class="futplay-league-hero futplay-league-hero-banner mb-4">
        <div class="futplay-league-hero-content">
            <div class="futplay-league-kicker">Área do participante</div>
            <h1 class="futplay-league-title">Ligas FutPlay</h1>
            <p class="futplay-league-lead">
                Escolha uma liga para palpitar, acompanhar o ranking e seguir seu campeonato favorito.
            </p>
        </div>

        @if (User.IsInRole(AppRoles.Administrador))
        {
            <div class="futplay-league-hero-scoreboard">
                <a asp-action="Create">Nova liga</a>
            </div>
        }
    </section>

    @if (!Model.Any())
    {
        <div class="futplay-league-empty">
            <div class="futplay-league-empty-mark">FP</div>
            <h2>Nenhuma liga cadastrada ainda</h2>
            <p>Quando houver ligas disponíveis, elas aparecerão aqui em formato de lista esportiva.</p>
        </div>
    }
    else
    {
        <section class="futplay-league-panel">
            <div class="futplay-league-panel-head">
                <h2>Ligas disponíveis</h2>
                <span>@Model.Count ligas</span>
            </div>

            <div class="futplay-league-rows">
                @foreach (var liga in Model)
                {
                    <article class="futplay-league-row">
                        <div class="futplay-league-logo">
                            @if (!string.IsNullOrWhiteSpace(liga.Campeonato?.LogoUrl))
                            {
                                <img src="@liga.Campeonato.LogoUrl" alt="@liga.Campeonato.Nome" />
                            }
                            else
                            {
                                <span>FP</span>
                            }
                        </div>

                        <div class="futplay-league-row-info">
                            <span>@(liga.Publica ? "Liga pública" : "Liga privada")</span>
                            <h3>@liga.Nome</h3>
                            <p>@liga.Campeonato?.Nome</p>
                        </div>

                        <div class="futplay-league-row-points">
                            <span>Convite</span>
                            <strong>@liga.CodigoConvite</strong>
                        </div>

                        <div class="futplay-league-actions">
                            @if (User.IsInRole(AppRoles.Administrador) || User.IsInRole(AppRoles.Participante))
                            {
                                <a asp-action="Palpitar"
                                   asp-route-id="@liga.Id"
                                   class="futplay-league-action-primary">
                                    Palpitar
                                </a>
                            }

                            <a asp-action="Ranking"
                               asp-route-id="@liga.Id"
                               class="futplay-league-action-secondary">
                                Ranking
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@liga.Id"
                               class="futplay-league-action-secondary">
                                Detalhes
                            </a>

                            @if (User.IsInRole(AppRoles.Administrador))
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@liga.Id"
                                   class="futplay-league-action-secondary">
                                    Editar
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>
