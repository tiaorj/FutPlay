@model FutPlay.ViewModels.RankingLigaViewModel
@using FutPlay.Settings
@{
    ViewData["Title"] = "Ranking da Liga";

    var top3 = Model.Participantes.Take(3).ToList();
    var lider = Model.Participantes.FirstOrDefault();

    var totalParticipantes = Model.Participantes.Count;
    var totalPalpites = Model.Participantes.Sum(p => p.TotalPalpites);
    var totalExatos = Model.Participantes.Sum(p => p.PlacaresExatos);
    var totalPontos = Model.Participantes.Sum(p => p.PontuacaoTotal);

    var aproveitamentoGeral = totalPalpites == 0
        ? 0
        : Convert.ToInt32((totalExatos * 100.0) / totalPalpites);
}

<div class="container fp-score-home">

    <section class="fp-bet-header mb-3">
        <div class="fp-bet-header-ball">
            🏆
        </div>

        <div class="fp-bet-header-info">
            <span>Ranking do bolão</span>
            <h1>@Model.Liga.Nome</h1>
            <p>@(Model.Liga.Campeonato?.Nome ?? "Campeonato não informado")</p>
        </div>

        <div class="fp-bet-header-actions">
            <a asp-action="Palpitar"
               asp-route-id="@Model.Liga.Id"
               asp-route-origem="minhasligas">
                Palpitar
            </a>

            <a asp-controller="MinhasLigas"
               asp-action="Index">
                Minhas Ligas
            </a>
        </div>
    </section>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Participantes</span>
                        <strong>@totalParticipantes</strong>
                    </div>

                    <div>
                        <span>Palpites</span>
                        <strong>@totalPalpites</strong>
                    </div>

                    <div>
                        <span>Exatos</span>
                        <strong>@totalExatos</strong>
                    </div>

                    <div>
                        <span>Acerto geral</span>
                        <strong>@aproveitamentoGeral%</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Líder</h2>
                </div>

                @if (lider == null)
                {
                    <div class="fp-empty-mini">
                        Ranking aguardando participantes.
                    </div>
                }
                else
                {
                    <div class="fp-bet-leader-card">
                        <span>1º</span>
                        <strong>@lider.Nome</strong>
                        <small>@lider.PontuacaoTotal pontos</small>
                    </div>
                }
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Palpitar"
                       asp-route-id="@Model.Liga.Id"
                       asp-route-origem="minhasligas"
                       class="btn btn-success">
                        Palpitar
                    </a>

                    <a asp-controller="MinhasLigas"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Minhas Ligas
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-primary">
                        Ligas Públicas
                    </a>
                </div>
            </section>
        </aside>

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a class="active" href="#">Ranking</a>

                    <a asp-action="Palpitar"
                       asp-route-id="@Model.Liga.Id"
                       asp-route-origem="minhasligas">
                        Palpites
                    </a>

                    <a asp-controller="MinhasLigas" asp-action="Index">
                        Meu bolão
                    </a>
                </div>

                <div class="fp-score-filter-row">
                    <span class="fp-score-filter active">Geral</span>
                    <span class="fp-score-filter">@totalParticipantes participantes</span>
                    <span class="fp-score-filter">@totalPontos pontos</span>
                </div>

                @if (!Model.Participantes.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Assim que os participantes entrarem na liga e enviarem palpites, o ranking aparecerá aqui.
                    </div>
                }
                else
                {
                    <section class="fp-bet-podium">
                        <div class="fp-match-list-title">
                            <span>🏆 Top 3</span>
                            <small>@top3.Count destaque(s)</small>
                        </div>

                        <div class="fp-bet-podium-grid">
                            @foreach (var item in top3)
                            {
                                var aproveitamento = item.TotalPalpites == 0
                                ? 0
                                : Convert.ToInt32((item.PlacaresExatos * 100.0) / item.TotalPalpites);

                                <article class="fp-bet-podium-card @(item.Posicao == 1 ? "first" : "")">
                                    <span>@(item.Posicao)º</span>
                                    <strong>@item.Nome</strong>
                                    <small>@item.Email</small>

                                    <div>
                                        <b>@item.PontuacaoTotal</b>
                                        <em>pontos</em>
                                    </div>

                                    <footer>
                                        <span>@item.TotalPalpites palpites</span>
                                        <span>@item.PlacaresExatos exatos</span>
                                        <span>@aproveitamento% acerto</span>
                                    </footer>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="fp-bet-ranking-list">
                        <div class="fp-match-list-title">
                            <span>📊 Classificação geral</span>
                            <small>@Model.Participantes.Count participante(s)</small>
                        </div>

                        <div class="table-responsive">
                            <table class="table fp-bet-ranking-table align-middle">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Participante</th>
                                        <th>Palpites</th>
                                        <th>Exatos</th>
                                        <th>Acerto</th>
                                        <th>PTS</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var item in Model.Participantes)
                                    {
                                        var aproveitamento = item.TotalPalpites == 0
                                        ? 0
                                        : Convert.ToInt32((item.PlacaresExatos * 100.0) / item.TotalPalpites);

                                        <tr class="@(item.Posicao <= 3 ? "top" : "")">
                                            <td>
                                                <span class="fp-bet-rank-position">
                                                    @item.Posicao
                                                </span>
                                            </td>

                                            <td>
                                                <strong>@item.Nome</strong>
                                                <small>@item.Email</small>
                                            </td>

                                            <td>@item.TotalPalpites</td>
                                            <td>@item.PlacaresExatos</td>

                                            <td>
                                                <span class="fp-bet-hit-rate">
                                                    @aproveitamento%
                                                </span>
                                            </td>

                                            <td class="fp-bet-ranking-points">
                                                @item.PontuacaoTotal
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>@AppBrand.Name</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Estatísticas</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Pontos</span>
                        <strong>@totalPontos</strong>
                    </div>

                    <div>
                        <span>Exatos</span>
                        <strong>@totalExatos</strong>
                    </div>
                </div>
            </section>
        </aside>

    </div>
</div>