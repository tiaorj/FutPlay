@model FutPlay.ViewModels.RankingLigaViewModel

@{
    ViewData["Title"] = "Ranking da Liga";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Ranking da Liga</h1>
            <p class="futplay-subtitle mb-0">
                @Model.Liga.Nome - @Model.Liga.Campeonato?.Nome
            </p>
        </div>

        <div class="mt-3 mt-md-0 futplay-actions">
            <a asp-action="Palpitar" asp-route-id="@Model.Liga.Id" class="btn btn-success">
                Palpitar
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Voltar
            </a>
        </div>
    </div>

    @if (!Model.Participantes.Any())
    {
        <div class="futplay-empty">
            Nenhum participante cadastrado nesta liga ainda.
        </div>
    }
    else
    {
        <div class="card shadow-sm futplay-section-card">
            <div class="card-body table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 90px;">Posição</th>
                            <th>Participante</th>
                            <th>E-mail</th>
                            <th>Palpites</th>
                            <th>Placares Exatos</th>
                            <th>Pontos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Participantes)
                        {
                            <tr>
                                <td>
                                    @if (item.Posicao == 1)
                                    {
                                        <span class="badge bg-warning text-dark fs-6">🥇 1º</span>
                                    }
                                    else if (item.Posicao == 2)
                                    {
                                        <span class="badge bg-secondary fs-6">🥈 2º</span>
                                    }
                                    else if (item.Posicao == 3)
                                    {
                                        <span class="badge bg-danger fs-6">🥉 3º</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">@(item.Posicao)º</span>
                                    }
                                </td>

                                <td>
                                    <strong>@item.Nome</strong>
                                </td>

                                <td>@item.Email</td>

                                <td>
                                    <span class="badge bg-primary">
                                        @item.TotalPalpites
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-success">
                                        @item.PlacaresExatos
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-dark fs-6">
                                        @item.PontuacaoTotal
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>