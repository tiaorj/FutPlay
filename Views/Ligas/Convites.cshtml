@model FutPlay.ViewModels.LigaConviteViewModel

@{
    ViewData["Title"] = "Convites da Liga";

    var totalConvites = Model.Convites.Count;
    var totalPendentes = Model.Convites.Count(c => c.Status == "Pendente");
    var totalAceitos = Model.Convites.Count(c => c.Status == "Aceito");
    var totalCancelados = Model.Convites.Count(c => c.Status == "Cancelado");
}

<div class="container fp-score-home">

    <section class="fp-bet-header mb-3">
        <div class="fp-bet-header-ball">
            ✉️
        </div>

        <div class="fp-bet-header-info">
            <span>Convites do bolão</span>
            <h1>@Model.Liga?.Nome</h1>
            <p>
                Gerencie participantes convidados, copie links individuais e acompanhe quem já entrou na liga.
            </p>
        </div>

        <div class="fp-bet-header-actions">
            <a asp-controller="MinhasLigas"
               asp-action="Index">
                Minhas Ligas
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.Liga?.Id">
                Editar Liga
            </a>

            <a asp-action="Index">
                Ligas Públicas
            </a>
        </div>
    </section>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">

            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Total</span>
                        <strong>@totalConvites</strong>
                    </div>

                    <div>
                        <span>Pendentes</span>
                        <strong>@totalPendentes</strong>
                    </div>

                    <div>
                        <span>Aceitos</span>
                        <strong>@totalAceitos</strong>
                    </div>

                    <div>
                        <span>Cancelados</span>
                        <strong>@totalCancelados</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Código geral</h2>
                </div>

                <p class="fp-side-text">
                    O participante também pode acessar “Ligas &gt; Entrar com Código” e informar este código.
                </p>

                <div class="input-group">
                    <input id="codigoGeralLiga"
                           type="text"
                           class="form-control text-uppercase"
                           value="@Model.Liga?.CodigoConvite"
                           readonly />

                    <button type="button"
                            class="btn btn-outline-primary"
                            onclick="copiarTexto('codigoGeralLiga', 'Código copiado com sucesso!')">
                        Copiar
                    </button>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Como funciona</h2>
                </div>

                <ol class="fp-invite-steps">
                    <li>Crie um convite com nome e e-mail.</li>
                    <li>Copie o link individual gerado.</li>
                    <li>Envie o link para o participante.</li>
                    <li>O convidado faz login com o mesmo e-mail.</li>
                    <li>A liga aparece em “Minhas Ligas”.</li>
                </ol>
            </section>

        </aside>

        <main class="col-xl-6 col-lg-8">

            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a class="active" href="#">Convites</a>
                    <a asp-controller="MinhasLigas" asp-action="Index">Meu bolão</a>
                    <a asp-action="Edit" asp-route-id="@Model.Liga?.Id">Editar liga</a>
                </div>

                <div class="fp-score-filter-row">
                    <span class="fp-score-filter active">Todos (@totalConvites)</span>
                    <span class="fp-score-filter">Pendentes (@totalPendentes)</span>
                    <span class="fp-score-filter">Aceitos (@totalAceitos)</span>
                    <span class="fp-score-filter">Cancelados (@totalCancelados)</span>
                </div>

                <section class="fp-invite-form-panel">
                    <div class="fp-match-list-title">
                        <span>➕ Novo convite</span>
                        <small>Adicionar participante</small>
                    </div>

                    <form asp-action="Convidar" method="post" class="fp-invite-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="LigaId" />

                        <div asp-validation-summary="All" class="text-danger mb-2"></div>

                        <div>
                            <label asp-for="NomeConvidado" class="form-label fw-bold"></label>
                            <input asp-for="NomeConvidado"
                                   class="form-control"
                                   placeholder="Ex: João Silva" />
                            <span asp-validation-for="NomeConvidado" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="email@dominio.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success">
                            Criar convite
                        </button>
                    </form>
                </section>

                <section class="fp-invite-list-panel">
                    <div class="fp-match-list-title">
                        <span>👥 Participantes convidados</span>
                        <small>@Model.Convites.Count convite(s)</small>
                    </div>

                    @if (!Model.Convites.Any())
                    {
                        <div class="fp-empty-mini m-3">
                            Nenhum convite criado para esta liga.
                            <br />
                            Crie o primeiro convite usando o formulário acima.
                        </div>
                    }
                    else
                    {
                        <div class="fp-invite-list">
                            @foreach (var convite in Model.Convites)
                            {
                                var linkToken = Url.Action(
                                action: "AceitarConvite",
                                controller: "Ligas",
                                values: new { token = convite.TokenConvite },
                                protocol: Context.Request.Scheme
                                );

                                var statusCss = convite.Status == "Aceito"
                                ? "accepted"
                                : convite.Status == "Cancelado"
                                ? "cancelled"
                                : "pending";

                                var inicial = (string.IsNullOrWhiteSpace(convite.NomeConvidado)
                                ? convite.Email
                                : convite.NomeConvidado).Substring(0, 1).ToUpper();

                                <article class="fp-invite-row @statusCss">
                                    <div class="fp-invite-avatar">
                                        @inicial
                                    </div>

                                    <div class="fp-invite-info">
                                        <div class="fp-invite-name-line">
                                            <strong>
                                                @(string.IsNullOrWhiteSpace(convite.NomeConvidado)
                                                                                        ? convite.Email
                                                                                        : convite.NomeConvidado)
                                    </strong>

                                            <span class="@statusCss">
                                                @convite.Status
                                            </span>
                                        </div>

                                        <small>@convite.Email</small>

                                        <div class="fp-invite-meta">
                                            <span>Criado em @convite.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>

                                    @if (convite.DataAceite.HasValue)
                                            {
                                                <span>Aceito em @convite.DataAceite.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                        </div>
                                    </div>

                                    @if (convite.Status == "Pendente")
                                    {
                                        <div class="fp-invite-actions">
                                            <input id="convite-@convite.Id"
                                                   type="text"
                                                   value="@linkToken"
                                                   class="form-control form-control-sm"
                                                   readonly />

                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary"
                                                    onclick="copiarTexto('convite-@convite.Id', 'Link copiado com sucesso!')">
                                                Copiar
                                            </button>

                                            <form asp-action="CancelarConvite"
                                                  method="post"
                                                  onsubmit="return confirm('Cancelar este convite?');">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@convite.Id" />

                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Cancelar
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>
            </section>

        </main>

        <aside class="col-xl-3 d-none d-xl-block">

            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>FutPlay</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações rápidas</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="MinhasLigas"
                       asp-action="Index"
                       class="btn btn-success">
                        Minhas Ligas
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.Liga?.Id"
                       class="btn btn-outline-primary">
                        Editar Liga
                    </a>

                    <a asp-action="Ranking"
                       asp-route-id="@Model.Liga?.Id"
                       class="btn btn-outline-primary">
                        Ranking
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-primary">
                        Ligas Públicas
                    </a>
                </div>
            </section>

        </aside>

    </div>
</div>

@section Scripts {
    <script>
        function copiarTexto(elementId, mensagem) {
            const campo = document.getElementById(elementId);

            if (!campo) {
                return;
            }

            campo.select();
            campo.setSelectionRange(0, 99999);

            navigator.clipboard.writeText(campo.value)
                .then(() => {
                    alert(mensagem || "Copiado com sucesso!");
                })
                .catch(() => {
                    document.execCommand("copy");
                    alert(mensagem || "Copiado com sucesso!");
                });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}