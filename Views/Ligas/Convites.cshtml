@model FutPlay.ViewModels.LigaConviteViewModel

@{
    ViewData["Title"] = "Convites da Liga";
}

<div class="container futplay-portal-shell">

    <section class="futplay-league-join-hero mb-4">
        <div>
            <div class="futplay-league-kicker">Convites da Liga</div>

            <h1>@Model.Liga.Nome</h1>

            <p>
                Crie convites individuais para seus participantes. Por enquanto, copie o link e envie manualmente.
            </p>
        </div>
    </section>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-5">
            <section class="futplay-league-join-card">
                <h2 class="h5 fw-bold mb-3">Novo convite</h2>

                <form asp-action="Convidar" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="LigaId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NomeConvidado" class="form-label"></label>
                        <input asp-for="NomeConvidado"
                               class="form-control"
                               placeholder="Ex: João Silva" />
                        <span asp-validation-for="NomeConvidado" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="email@dominio.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Criar convite
                    </button>
                </form>

                <hr />

                <div class="futplay-league-join-help">
                    <strong>Código geral da liga</strong>
                    <p>
                        Código: <strong>@Model.Liga.CodigoConvite</strong>
                    </p>
                    <p>
                        Este código também pode ser usado na tela “Entrar na Liga”.
                    </p>
                </div>
            </section>
        </div>

        <div class="col-lg-7">
            <section class="futplay-home-side-card">
                <div class="futplay-home-section-title compact">
                    <div>
                        <span>Participantes</span>
                        <h2>Convites criados</h2>
                    </div>
                </div>

                @if (!Model.Convites.Any())
                {
                    <div class="futplay-empty-state">
                        Nenhum convite criado para esta liga.
                    </div>
                }
                else
                {
                    <div class="futplay-invite-list">
                        @foreach (var convite in Model.Convites)
                        {
                            var linkToken = Url.Action(
                            action: "AceitarConvite",
                            controller: "Ligas",
                            values: new { token = convite.TokenConvite },
                            protocol: Context.Request.Scheme
                            );

                            <article class="futplay-invite-item">
                                <div>
                                    <h3>
                                        @(string.IsNullOrWhiteSpace(convite.NomeConvidado)
                                                                        ? convite.Email
                                                                        : convite.NomeConvidado)
                            </h3>

                                    <p>@convite.Email</p>

                                    <div class="small text-muted">
                                        Criado em @convite.DataCriacao.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>

                                <div class="futplay-invite-actions">
                                    <span class="badge @(convite.Status == "Aceito" ? "bg-success" : convite.Status == "Cancelado" ? "bg-secondary" : "bg-warning text-dark")">
                                        @convite.Status
                                    </span>

                            @if (convite.Status == "Pendente")
                                    {
                                        <input id="convite-@convite.Id"
                                               type="text"
                                               value="@linkToken"
                                               class="form-control form-control-sm"
                                               readonly />

                                        <button type="button"
                                                class="btn btn-sm btn-outline-success"
                                                onclick="copiarTexto('convite-@convite.Id')">
                                            Copiar link
                                        </button>

                                        <form asp-action="CancelarConvite"
                                              method="post"
                                              onsubmit="return confirm('Cancelar este convite?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@convite.Id" />

                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Cancelar
                                            </button>
                                        </form>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-controller="MinhasLigas" asp-action="Index" class="btn btn-success">
            Minhas Ligas
        </a>

        <a asp-action="Edit" asp-route-id="@Model.Liga.Id" class="btn btn-outline-secondary">
            Editar Liga
        </a>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Ver Ligas Públicas
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function copiarTexto(elementId) {
            const campo = document.getElementById(elementId);

            if (!campo) {
                return;
            }

            campo.select();
            campo.setSelectionRange(0, 99999);

            navigator.clipboard.writeText(campo.value)
                .then(() => {
                    alert("Link copiado com sucesso!");
                })
                .catch(() => {
                    document.execCommand("copy");
                    alert("Link copiado com sucesso!");
                });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}