@model FutPlay.ViewModels.LigaConviteViewModel

@{
    ViewData["Title"] = "Convites da Liga";

    var totalConvites = Model.Convites.Count;
    var totalPendentes = Model.Convites.Count(c => c.Status == "Pendente");
    var totalAceitos = Model.Convites.Count(c => c.Status == "Aceito");
    var totalCancelados = Model.Convites.Count(c => c.Status == "Cancelado");
}

<div class="container futplay-portal-shell">

    <section class="futplay-league-create-hero mb-4">
        <div>
            <div class="futplay-league-kicker">Convites do bolão</div>

            <h1>@Model.Liga?.Nome</h1>

            <p>
                Gerencie os convites da liga, copie links individuais e acompanhe quem já entrou no bolão.
            </p>
        </div>
    </section>

    <section class="futplay-invite-summary mb-4">
        <article>
            <span>Total</span>
            <strong>@totalConvites</strong>
        </article>

        <article>
            <span>Pendentes</span>
            <strong>@totalPendentes</strong>
        </article>

        <article>
            <span>Aceitos</span>
            <strong>@totalAceitos</strong>
        </article>

        <article>
            <span>Cancelados</span>
            <strong>@totalCancelados</strong>
        </article>
    </section>

    <div class="row g-4">
        <div class="col-lg-5">

            <section class="futplay-league-create-card mb-4">
                <div class="futplay-home-section-title compact">
                    <div>
                        <span>Novo convite</span>
                        <h2>Adicionar participante</h2>
                    </div>
                </div>

                <form asp-action="Convidar" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="LigaId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NomeConvidado" class="form-label fw-semibold"></label>
                        <input asp-for="NomeConvidado"
                               class="form-control form-control-lg"
                               placeholder="Ex: João Silva" />
                        <span asp-validation-for="NomeConvidado" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email"
                               class="form-control form-control-lg"
                               placeholder="email@dominio.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100">
                        Criar convite
                    </button>
                </form>
            </section>

            <section class="futplay-home-side-card mb-4">
                <div class="futplay-home-section-title compact">
                    <div>
                        <span>Código geral</span>
                        <h2>Entrada por código</h2>
                    </div>
                </div>

                <div class="input-group input-group-lg">
                    <input id="codigoGeralLiga"
                           type="text"
                           class="form-control text-uppercase"
                           value="@Model.Liga?.CodigoConvite"
                           readonly />

                    <button type="button"
                            class="btn btn-outline-success"
                            onclick="copiarTexto('codigoGeralLiga', 'Código copiado com sucesso!')">
                        Copiar
                    </button>
                </div>

                <p class="futplay-invite-help-text mt-3 mb-0">
                    O participante também pode acessar “Ligas &gt; Entrar com Código” e informar este código.
                </p>
            </section>

            <section class="futplay-home-side-card">
                <div class="futplay-home-section-title compact">
                    <div>
                        <span>Como funciona</span>
                        <h2>Fluxo do convite</h2>
                    </div>
                </div>

                <ol class="futplay-invite-steps">
                    <li>Crie um convite informando nome e e-mail.</li>
                    <li>Copie o link individual gerado.</li>
                    <li>Envie o link pelo WhatsApp, e-mail ou mensagem.</li>
                    <li>O convidado faz login com o mesmo e-mail do convite.</li>
                    <li>A liga aparece automaticamente em “Minhas Ligas”.</li>
                </ol>
            </section>

        </div>

        <div class="col-lg-7">

            <section class="futplay-home-side-card">
                <div class="futplay-home-section-title compact">
                    <div>
                        <span>Lista de convites</span>
                        <h2>Participantes convidados</h2>
                    </div>
                </div>

                @if (!Model.Convites.Any())
                {
                    <div class="futplay-empty-state">
                        Nenhum convite criado para esta liga.
                        <br />
                        <small>Crie o primeiro convite usando o formulário ao lado.</small>
                    </div>
                }
                else
                {
                    <div class="futplay-invite-list">
                        @foreach (var convite in Model.Convites)
                        {
                            var linkToken = Url.Action(
                            action: "AceitarConvite",
                            controller: "Ligas",
                            values: new { token = convite.TokenConvite },
                            protocol: Context.Request.Scheme
                            );

                            var statusCss = convite.Status == "Aceito"
                            ? "accepted"
                            : convite.Status == "Cancelado"
                            ? "cancelled"
                            : "pending";

                            <article class="futplay-invite-item-modern">
                                <div class="futplay-invite-main">
                                    <div class="futplay-invite-avatar">
                                        @((string.IsNullOrWhiteSpace(convite.NomeConvidado)
                                                                        ? convite.Email
                                                                        : convite.NomeConvidado).Substring(0, 1).ToUpper())
                                                                                                                       </div>

                                    <div>
                                        <div class="futplay-invite-name-row">
                                            <h3>
                                                @(string.IsNullOrWhiteSpace(convite.NomeConvidado)
                                                                                        ? convite.Email
                                                                                        : convite.NomeConvidado)
                                    </h3>

                                            <span class="futplay-invite-status @statusCss">
                                                @convite.Status
                                            </span>
                                        </div>

                                        <p>@convite.Email</p>

                                        <div class="futplay-invite-meta">
                                            <span>Criado em @convite.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>

                                    @if (convite.DataAceite.HasValue)
                                            {
                                                <span>Aceito em @convite.DataAceite.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @if (convite.Status == "Pendente")
                                {
                                    <div class="futplay-invite-link-box">
                                        <input id="convite-@convite.Id"
                                               type="text"
                                               value="@linkToken"
                                               class="form-control form-control-sm"
                                               readonly />

                                        <div class="futplay-invite-buttons">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success"
                                                    onclick="copiarTexto('convite-@convite.Id', 'Link copiado com sucesso!')">
                                                Copiar link
                                            </button>

                                            <form asp-action="CancelarConvite"
                                                  method="post"
                                                  onsubmit="return confirm('Cancelar este convite?');">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@convite.Id" />

                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Cancelar
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            </section>

        </div>
    </div>

    <div class="mt-4 d-flex flex-column flex-md-row gap-2">
        <a asp-controller="MinhasLigas"
           asp-action="Index"
           class="btn btn-success">
            Minhas Ligas
        </a>

        <a asp-action="Edit"
           asp-route-id="@Model.Liga?.Id"
           class="btn btn-outline-secondary">
            Editar Liga
        </a>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Ver Ligas Públicas
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function copiarTexto(elementId, mensagem) {
            const campo = document.getElementById(elementId);

            if (!campo) {
                return;
            }

            campo.select();
            campo.setSelectionRange(0, 99999);

            navigator.clipboard.writeText(campo.value)
                .then(() => {
                    alert(mensagem || "Copiado com sucesso!");
                })
                .catch(() => {
                    document.execCommand("copy");
                    alert(mensagem || "Copiado com sucesso!");
                });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}