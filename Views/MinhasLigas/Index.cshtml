@model List<FutPlay.ViewModels.MinhaLigaViewModel>

@{
    ViewData["Title"] = "Minhas Ligas";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Minhas Ligas</h1>
            <p class="futplay-subtitle mb-0">
                Acompanhe suas ligas, pontuação e próximos palpites.
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="futplay-empty">
            Você ainda não participa de nenhuma liga vinculada ao seu usuário.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var liga in Model)
            {
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                        <div class="card-body futplay-card-content">
                            <div>
                                <h5 class="card-title mb-1">
                                    @liga.NomeLiga
                                </h5>

                                <p class="text-muted small mb-3">
                                    @liga.NomeCampeonato
                                </p>

                                <span class="text-muted small">Pontuação</span>
                                <div class="fs-3 fw-bold">
                                    @liga.Pontuacao
                                </div>
                            </div>

                            <div class="futplay-actions mt-3">
                                <a asp-controller="Ligas"
                                   asp-action="Palpitar"
                                   asp-route-id="@liga.LigaId"
                                   asp-route-participanteId="@liga.LigaParticipanteId"
                                   asp-route-origem="minhasligas"
                                   class="btn btn-success">
                                    Palpitar
                                </a>

                                <a asp-controller="Ligas"
                                   asp-action="Ranking"
                                   asp-route-id="@liga.LigaId"
                                   class="btn btn-outline-dark btn-sm">
                                    Ranking
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
