@model List<FutPlay.ViewModels.MinhaLigaViewModel>

@{
    ViewData["Title"] = "Minhas Ligas";
}

<div class="container mt-4">
    <section class="futplay-page-hero mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="futplay-card-kicker">Seu vestiário</div>
                <h1 class="futplay-page-title mb-1">Minhas Ligas</h1>
                <p class="futplay-subtitle mb-0">
                    Acompanhe suas ligas, pontuação e os próximos palpites vinculados ao seu usuário.
                </p>
            </div>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="futplay-empty">
            Você ainda não participa de nenhuma liga vinculada ao seu usuário.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var liga in Model)
            {
                <div class="col-xl-4 col-md-6 mb-3">
                    <article class="futplay-entity-card">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <span class="futplay-logo">
                                @if (!string.IsNullOrWhiteSpace(liga.CampeonatoLogoUrl))
                                {
                                    <img src="@liga.CampeonatoLogoUrl" alt="@liga.NomeCampeonato" />
                                }
                                else
                                {
                                    <span>⭐</span>
                                }
                            </span>

                            <div>
                                <div class="futplay-card-kicker">Liga participante</div>
                                <h5 class="mb-1">@liga.NomeLiga</h5>
                                <p class="text-muted small mb-0">@liga.NomeCampeonato</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-end justify-content-between gap-3 mb-3">
                            <div>
                                <span class="text-muted small">Pontuação</span>
                                <div class="display-6 fw-bold text-success">@liga.Pontuacao</div>
                            </div>
                            <span class="futplay-status futplay-status-done">Ativo</span>
                        </div>

                        <div class="futplay-actions">
                            <a asp-controller="Ligas"
                               asp-action="Palpitar"
                               asp-route-id="@liga.LigaId"
                               asp-route-participanteId="@liga.LigaParticipanteId"
                               asp-route-origem="minhasligas"
                               class="btn btn-success">
                                Palpitar
                            </a>

                            <a asp-controller="Ligas"
                               asp-action="Ranking"
                               asp-route-id="@liga.LigaId"
                               class="btn btn-outline-dark">
                                Ranking
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
