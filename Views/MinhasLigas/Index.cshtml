@model List<FutPlay.ViewModels.MinhaLigaViewModel>
@using FutPlay.Settings
@{
    ViewData["Title"] = "Meu Pitaco";

    var totalPontos = Model.Sum(l => l.Pontuacao);
    var melhorLiga = Model.OrderByDescending(l => l.Pontuacao).FirstOrDefault();
    var ligasCriadas = Model.Count(l => l.CriadorDaLiga);
    var ligasPublicas = Model.Count(l => l.Publica);
    var ligasPrivadas = Model.Count(l => !l.Publica);
}

<div class="container fp-score-home">

    <div class="fp-score-page-title d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>Meu Pitaco: suas ligas, palpites, rankings e convites</span>

        <a asp-controller="Ligas"
           asp-action="Create"
           class="fp-score-admin-link">
            + Criar liga
        </a>
    </div>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Ligas</span>
                        <strong>@Model.Count</strong>
                    </div>

                    <div>
                        <span>Pontos</span>
                        <strong>@totalPontos</strong>
                    </div>

                    <div>
                        <span>Criadas</span>
                        <strong>@ligasCriadas</strong>
                    </div>

                    <div>
                        <span>Privadas</span>
                        <strong>@ligasPrivadas</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="Ligas"
                       asp-action="Create"
                       class="btn btn-success">
                        Criar Liga
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Entrar"
                       class="btn btn-outline-primary">
                        Entrar com Código
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Ligas Públicas
                    </a>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Melhor campanha</h2>
                </div>

                @if (melhorLiga == null)
                {
                    <div class="fp-empty-mini">
                        Participe de uma liga para aparecer aqui.
                    </div>
                }
                else
                {
                    <div class="fp-bet-best-card">
                        <div class="fp-bet-league-logo">
                            @if (!string.IsNullOrWhiteSpace(melhorLiga.CampeonatoLogoUrl))
                            {
                                <img src="@melhorLiga.CampeonatoLogoUrl" alt="@melhorLiga.NomeCampeonato" />
                            }
                            else
                            {
                                <span>FP</span>
                            }
                        </div>

                        <strong>@melhorLiga.NomeLiga</strong>
                        <span>@melhorLiga.Pontuacao pontos</span>
                    </div>
                }
            </section>
        </aside>

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a class="active" href="#">Minhas Ligas</a>
                    <a asp-controller="Ligas" asp-action="Index">Ligas públicas</a>
                    <a asp-controller="Ligas" asp-action="Create">Criar liga</a>
                </div>

                <div class="fp-score-filter-row">
                    <span class="fp-score-filter active">Todas (@Model.Count)</span>
                    <span class="fp-score-filter">Criadas (@ligasCriadas)</span>
                    <span class="fp-score-filter">Públicas (@ligasPublicas)</span>
                    <span class="fp-score-filter">Privadas (@ligasPrivadas)</span>
                </div>

                @if (!Model.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Você ainda não participa de nenhuma liga. Crie sua primeira liga de palpites ou entre usando um código de convite.
                    </div>

                    <div class="d-flex flex-column flex-md-row gap-2 m-3">
                        <a asp-controller="Ligas"
                           asp-action="Create"
                           class="btn btn-success">
                            Criar minha primeira liga
                        </a>

                        <a asp-controller="Ligas"
                           asp-action="Entrar"
                           class="btn btn-outline-primary">
                            Tenho um código
                        </a>
                    </div>
                }
                else
                {
                    <div class="fp-bet-league-list">
                        <div class="fp-match-list-title">
                            <span>📊 Meu Pitaco</span>
                            <small>@Model.Count liga(s)</small>
                        </div>

                        @foreach (var liga in Model)
                        {
                            <article class="fp-bet-league-row">
                                <div class="fp-bet-league-logo">
                                    @if (!string.IsNullOrWhiteSpace(liga.CampeonatoLogoUrl))
                                    {
                                        <img src="@liga.CampeonatoLogoUrl" alt="@liga.NomeCampeonato" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </div>

                                <div class="fp-bet-league-info">
                                    <div class="fp-bet-league-badges">
                                        <span>@(liga.Publica ? "Pública" : "Privada")</span>

                                        @if (liga.CriadorDaLiga)
                                        {
                                            <span class="owner">Criador</span>
                                        }
                                        else
                                        {
                                            <span class="participant">Participante</span>
                                        }
                                    </div>

                                    <strong>@liga.NomeLiga</strong>
                                    <small>@liga.NomeCampeonato</small>
                                </div>

                                <div class="fp-bet-league-score">
                                    <span>Pontos</span>
                                    <strong>@liga.Pontuacao</strong>
                                </div>

                                <div class="fp-bet-league-actions">
                                    <a asp-controller="Ligas"
                                       asp-action="Palpitar"
                                       asp-route-id="@liga.LigaId"
                                       asp-route-participanteId="@liga.LigaParticipanteId"
                                       asp-route-origem="minhasligas"
                                       class="primary">
                                        Palpitar
                                    </a>

                                    <a asp-controller="Ligas"
                                       asp-action="Ranking"
                                       asp-route-id="@liga.LigaId">
                                        Ranking
                                    </a>

                                    @if (liga.PodeGerenciar)
                                    {
                                        <a asp-controller="Ligas"
                                           asp-action="Convites"
                                           asp-route-id="@liga.LigaId">
                                            Convites
                                        </a>

                                        <a asp-controller="Ligas"
                                           asp-action="Edit"
                                           asp-route-id="@liga.LigaId">
                                            Editar
                                        </a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>@AppBrand.Name</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Minhas criações</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Criadas</span>
                        <strong>@ligasCriadas</strong>
                    </div>

                    <div>
                        <span>Participando</span>
                        <strong>@(Model.Count - ligasCriadas)</strong>
                    </div>
                </div>

                <p class="fp-side-text mt-3 mb-0">
                    Quem cria uma liga pode gerenciar convites e editar informações do Meu Pitaco.
                </p>
            </section>
        </aside>

    </div>
</div>
