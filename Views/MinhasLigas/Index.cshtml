@model List<FutPlay.ViewModels.MinhaLigaViewModel>

@{
    ViewData["Title"] = "Minhas Ligas";

    var totalPontos = Model.Sum(l => l.Pontuacao);
    var melhorLiga = Model.OrderByDescending(l => l.Pontuacao).FirstOrDefault();
    var ligasCriadas = Model.Count(l => l.CriadorDaLiga);
    var ligasPublicas = Model.Count(l => l.Publica);
    var ligasPrivadas = Model.Count(l => !l.Publica);
}

<div class="container futplay-portal-shell">
    <div class="row g-4">
        <div class="col-xl-9">

            <section class="futplay-league-hero futplay-league-hero-banner mb-4">
                <div class="futplay-league-hero-content">
                    <div class="futplay-league-kicker">Meus bolões</div>

                    <h1 class="futplay-league-title">
                        Minhas Ligas
                    </h1>

                    <p class="futplay-league-lead">
                        Acompanhe suas ligas, envie palpites, veja rankings e gerencie os convites dos bolões que você criou.
                    </p>

                    <div class="futplay-league-hero-meta">
                        <span>@Model.Count ligas</span>
                        <span>@totalPontos pontos</span>
                        <span>@ligasCriadas criadas por você</span>
                    </div>
                </div>

                <div class="futplay-league-hero-scoreboard">
                    <span>FutPlay</span>
                    <strong>Bolão</strong>
                    <small>ranking e palpites</small>
                </div>
            </section>

            <section class="futplay-my-league-toolbar mb-4">
                <div>
                    <strong>O que deseja fazer?</strong>
                    <span>Crie uma liga, entre com um código ou continue seus palpites.</span>
                </div>

                <div class="futplay-my-league-toolbar-actions">
                    <a asp-controller="Ligas"
                       asp-action="Create"
                       class="btn btn-success">
                        Criar Liga
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Entrar"
                       class="btn btn-outline-success">
                        Entrar com Código
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Ver Ligas Públicas
                    </a>
                </div>
            </section>

            @if (!Model.Any())
            {
                <section class="futplay-league-empty">
                    <div class="futplay-league-empty-mark">FP</div>

                    <h2>Você ainda não participa de nenhuma liga</h2>

                    <p>
                        Crie seu próprio bolão ou entre em uma liga usando o código de convite enviado por um amigo.
                    </p>

                    <div class="d-flex flex-column flex-md-row justify-content-center gap-2 mt-3">
                        <a asp-controller="Ligas"
                           asp-action="Create"
                           class="btn btn-success">
                            Criar minha primeira liga
                        </a>

                        <a asp-controller="Ligas"
                           asp-action="Entrar"
                           class="btn btn-outline-success">
                            Tenho um código
                        </a>
                    </div>
                </section>
            }
            else
            {
                <section class="futplay-league-panel">
                    <div class="futplay-league-panel-head">
                        <h2>Minhas competições</h2>
                        <span>Palpites, rankings e convites</span>
                    </div>

                    <div class="futplay-league-rows">
                        @foreach (var liga in Model)
                        {
                            <article class="futplay-league-row futplay-my-league-row">
                                <div class="futplay-league-logo">
                                    @if (!string.IsNullOrWhiteSpace(liga.CampeonatoLogoUrl))
                                    {
                                        <img src="@liga.CampeonatoLogoUrl" alt="@liga.NomeCampeonato" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </div>

                                <div class="futplay-league-row-info">
                                    <div class="futplay-my-league-badges">
                                        <span class="futplay-my-league-badge">
                                            @(liga.Publica ? "Pública" : "Privada")
                                        </span>

                                        @if (liga.CriadorDaLiga)
                                        {
                                            <span class="futplay-my-league-badge owner">
                                                Criador
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="futplay-my-league-badge participant">
                                                Participante
                                            </span>
                                        }
                                    </div>

                                    <h3>@liga.NomeLiga</h3>
                                    <p>@liga.NomeCampeonato</p>
                                </div>

                                <div class="futplay-league-row-points">
                                    <span>Pontos</span>
                                    <strong>@liga.Pontuacao</strong>
                                </div>

                                <div class="futplay-league-actions">
                                    <a asp-controller="Ligas"
                                       asp-action="Palpitar"
                                       asp-route-id="@liga.LigaId"
                                       asp-route-participanteId="@liga.LigaParticipanteId"
                                       asp-route-origem="minhasligas"
                                       class="futplay-league-action-primary">
                                        Palpitar
                                    </a>

                                    <a asp-controller="Ligas"
                                       asp-action="Ranking"
                                       asp-route-id="@liga.LigaId"
                                       class="futplay-league-action-secondary">
                                        Ranking
                                    </a>

                                    @if (liga.PodeGerenciar)
                                    {
                                        <a asp-controller="Ligas"
                                           asp-action="Convites"
                                           asp-route-id="@liga.LigaId"
                                           class="futplay-league-action-secondary">
                                            Convites
                                        </a>

                                        <a asp-controller="Ligas"
                                           asp-action="Edit"
                                           asp-route-id="@liga.LigaId"
                                           class="futplay-league-action-secondary">
                                            Editar
                                        </a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }
        </div>

        <aside class="col-xl-3">
            <section class="futplay-league-side-card mb-4">
                <div class="futplay-league-side-head">
                    <h2>Resumo</h2>
                </div>

                <div class="futplay-league-side-stats">
                    <div>
                        <span>Ligas</span>
                        <strong>@Model.Count</strong>
                    </div>

                    <div>
                        <span>Pontos</span>
                        <strong>@totalPontos</strong>
                    </div>

                    <div>
                        <span>Públicas</span>
                        <strong>@ligasPublicas</strong>
                    </div>

                    <div>
                        <span>Privadas</span>
                        <strong>@ligasPrivadas</strong>
                    </div>
                </div>
            </section>

            <section class="futplay-league-side-card mb-4">
                <div class="futplay-league-side-head">
                    <h2>Minhas criações</h2>
                </div>

                <div class="futplay-league-side-stats">
                    <div>
                        <span>Criadas</span>
                        <strong>@ligasCriadas</strong>
                    </div>

                    <div>
                        <span>Participando</span>
                        <strong>@(Model.Count - ligasCriadas)</strong>
                    </div>
                </div>

                <p class="futplay-league-side-empty mt-3">
                    Quem cria uma liga pode gerenciar convites e editar informações do bolão.
                </p>
            </section>

            <section class="futplay-league-side-card">
                <div class="futplay-league-side-head">
                    <h2>Melhor campanha</h2>
                </div>

                @if (melhorLiga == null)
                {
                    <p class="futplay-league-side-empty">
                        Participe de uma liga para aparecer aqui.
                    </p>
                }
                else
                {
                    <div class="futplay-league-best">
                        <div class="futplay-league-logo">
                            @if (!string.IsNullOrWhiteSpace(melhorLiga.CampeonatoLogoUrl))
                            {
                                <img src="@melhorLiga.CampeonatoLogoUrl" alt="@melhorLiga.NomeCampeonato" />
                            }
                            else
                            {
                                <span>FP</span>
                            }
                        </div>

                        <h3>@melhorLiga.NomeLiga</h3>
                        <span>@melhorLiga.Pontuacao pontos</span>
                    </div>
                }
            </section>
        </aside>
    </div>
</div>