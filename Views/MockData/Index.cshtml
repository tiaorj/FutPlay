@{
    ViewData["Title"] = "Dados de Teste";
    bool dadosTesteExistem = ViewBag.DadosTesteExistem == true;
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Dados de Teste</h1>
            <p class="futplay-subtitle mb-0">
                Gere ou remova dados mockados para testar o FutPlay sem consumir chamadas da API.
            </p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-controller="Importacoes" asp-action="Index" class="btn btn-outline-secondary">
                Voltar para Importações
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm futplay-section-card h-100">
                <div class="card-header bg-white">
                    <strong>Gerar dados mockados</strong>
                </div>

                <div class="card-body">
                    <p class="text-muted">
                        Esta ação cria campeonato, times, jogos, ligas, participantes, palpites,
                        classificação e ranking de exemplo.
                    </p>

                    <ul class="text-muted">
                        <li>Copa FutPlay Mock</li>
                        <li>8 seleções mockadas</li>
                        <li>10 jogos de exemplo</li>
                        <li>1 liga pública e 1 liga privada</li>
                        <li>4 participantes</li>
                        <li>Palpites e pontuação calculada</li>
                    </ul>

                    @if (dadosTesteExistem)
                    {
                        <div class="alert alert-info">
                            Os dados de teste já existem. Limpe antes de gerar novamente.
                        </div>
                    }
                    else
                    {
                        <form asp-action="Gerar" method="post">
                            <button type="submit" class="btn btn-warning">
                                Gerar Dados de Teste
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm futplay-section-card h-100">
                <div class="card-header bg-white">
                    <strong>Limpar dados mockados</strong>
                </div>

                <div class="card-body">
                    <p class="text-muted">
                        Esta ação remove somente os dados mockados criados para teste.
                    </p>

                    <div class="alert alert-warning">
                        Atenção: essa limpeza remove a Copa FutPlay Mock, jogos, liga,
                        participantes, palpites e classificação relacionados a ela.
                    </div>

                    @if (!dadosTesteExistem)
                    {
                        <div class="alert alert-info">
                            Nenhum dado de teste encontrado.
                        </div>
                    }
                    else
                    {
                        <form asp-action="Limpar" method="post"
                              onsubmit="return confirm('Tem certeza que deseja limpar os dados de teste?');">
                            <button type="submit" class="btn btn-outline-danger">
                                Limpar Dados de Teste
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>