@model FutPlay.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Portal de Futebol";
}

<div class="container futplay-portal-shell">
    <section class="futplay-portal-header mb-4">
        <div class="row g-4 align-items-end">
            <div class="col-lg-8">
                <div class="futplay-portal-kicker">Portal FutPlay</div>
                <h1 class="futplay-portal-title">Futebol, tabelas e palpites em um só lugar</h1>
                <p class="futplay-portal-lead">
                    Acompanhe campeonatos, veja jogos da rodada, consulte resultados e participe das ligas públicas.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="futplay-portal-summary">
                    <div>
                        <span>Campeonatos</span>
                        <strong>@Model.TotalCampeonatos</strong>
                    </div>
                    <div>
                        <span>Jogos</span>
                        <strong>@Model.TotalJogos</strong>
                    </div>
                    <div>
                        <span>Ligas</span>
                        <strong>@Model.TotalLigas</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <section class="futplay-section-block">
                <div class="futplay-section-header">
                    <h2 class="futplay-section-title">TABELA</h2>
                    <a asp-controller="Campeonatos" asp-action="Index" class="futplay-section-link">Ver campeonatos</a>
                </div>

                @if (!Model.CampeonatosAtivos.Any())
                {
                    <div class="futplay-section-empty">Nenhum campeonato ativo cadastrado.</div>
                }
                else
                {
                    <div class="futplay-portal-news-list">
                        @foreach (var campeonato in Model.CampeonatosAtivos)
                        {
                            <article class="futplay-portal-news-item">
                                <div class="futplay-portal-logo">
                                    @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                    {
                                        <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </div>
                                <div class="futplay-portal-news-body">
                                    <div class="futplay-portal-meta">
                                        @campeonato.Tipo
                                        @if (!string.IsNullOrWhiteSpace(campeonato.Pais))
                                        {
                                            <span> | @campeonato.Pais</span>
                                        }
                                    </div>
                                    <h3>@campeonato.Nome @campeonato.Ano</h3>
                                    <div class="futplay-portal-actions">
                                        <a asp-controller="Campeonatos"
                                           asp-action="Portal"
                                           asp-route-id="@campeonato.Id">
                                            Portal
                                        </a>
                                        <a asp-controller="Campeonatos"
                                           asp-action="Classificacao"
                                           asp-route-id="@campeonato.Id">
                                            Classificação
                                        </a>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="futplay-section-block mt-4">
                <div class="futplay-section-header">
                    <h2 class="futplay-section-title">RESULTADOS</h2>
                    <a asp-controller="Jogos" asp-action="Index" class="futplay-section-link">Ver jogos</a>
                </div>

                @if (!Model.UltimosResultados.Any())
                {
                    <div class="futplay-section-empty">Nenhum resultado cadastrado.</div>
                }
                else
                {
                    <div class="futplay-match-list">
                        @foreach (var jogo in Model.UltimosResultados)
                        {
                            var statusClass = string.Equals(jogo.Status, "Finalizado", StringComparison.OrdinalIgnoreCase)
                                ? "futplay-match-status-finalizado"
                                : "futplay-match-status-default";

                            <article class="futplay-match-item">
                                <div class="futplay-match-meta">
                                    <strong>@jogo.DataJogo.ToString("dd/MM")</strong>
                                    <span>@jogo.DataJogo.ToString("HH:mm")</span>
                                    <span>@jogo.Campeonato?.Nome</span>
                                </div>

                                <div class="futplay-match-board">
                                    <div class="futplay-match-team">
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeCasa?.Sigla ?? "CAS")</span>
                                            }
                                        </span>
                                        <strong>@jogo.TimeCasa?.Nome</strong>
                                    </div>

                                    <div class="futplay-match-center">
                                        <span class="futplay-match-score">
                                            @(jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue
                                                ? $"{jogo.GolsCasa} x {jogo.GolsVisitante}"
                                                : "x")
                                        </span>
                                    </div>

                                    <div class="futplay-match-team futplay-match-team-away">
                                        <strong>@jogo.TimeVisitante?.Nome</strong>
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeVisitante?.Sigla ?? "VIS")</span>
                                            }
                                        </span>
                                    </div>
                                </div>

                                <span class="futplay-match-status @statusClass">@jogo.Status</span>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>

        <aside class="col-lg-4">
            <section class="futplay-section-block">
                <div class="futplay-section-header">
                    <h2 class="futplay-section-title">JOGOS</h2>
                    <a asp-controller="Jogos" asp-action="Index" class="futplay-section-link">Agenda</a>
                </div>

                @if (!Model.ProximosJogos.Any())
                {
                    <div class="futplay-section-empty">Nenhum jogo futuro cadastrado.</div>
                }
                else
                {
                    <div class="futplay-match-list futplay-match-list-compact">
                        @foreach (var jogo in Model.ProximosJogos)
                        {
                            var statusClass = string.Equals(jogo.Status, "Agendado", StringComparison.OrdinalIgnoreCase)
                                ? "futplay-match-status-agendado"
                                : "futplay-match-status-default";

                            <article class="futplay-match-item">
                                <div class="futplay-match-meta">
                                    <strong>@jogo.DataJogo.ToString("dd/MM")</strong>
                                    <span>@jogo.DataJogo.ToString("HH:mm")</span>
                                    <span>
                                        @(string.IsNullOrWhiteSpace(jogo.Fase) ? jogo.Campeonato?.Nome : jogo.Fase)
                                    </span>
                                </div>

                                <div class="futplay-match-board">
                                    <div class="futplay-match-team">
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeCasa?.Sigla ?? "CAS")</span>
                                            }
                                        </span>
                                        <strong>@jogo.TimeCasa?.Nome</strong>
                                    </div>

                                    <div class="futplay-match-center">
                                        <span class="futplay-match-score">x</span>
                                    </div>

                                    <div class="futplay-match-team futplay-match-team-away">
                                        <strong>@jogo.TimeVisitante?.Nome</strong>
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeVisitante?.Sigla ?? "VIS")</span>
                                            }
                                        </span>
                                    </div>
                                </div>

                                <span class="futplay-match-status @statusClass">@jogo.Status</span>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="futplay-section-block mt-4">
                <div class="futplay-section-header">
                    <h2 class="futplay-section-title">LIGAS</h2>
                    <a asp-controller="Ligas" asp-action="Index" class="futplay-section-link">Ver ligas</a>
                </div>

                @if (!Model.LigasPublicas.Any())
                {
                    <div class="futplay-section-empty">Nenhuma liga pública cadastrada.</div>
                }
                else
                {
                    <div class="futplay-portal-league-list">
                        @foreach (var liga in Model.LigasPublicas)
                        {
                            <article class="futplay-portal-league-item">
                                <div class="futplay-portal-logo futplay-portal-logo-small">
                                    @if (!string.IsNullOrWhiteSpace(liga.Campeonato?.LogoUrl))
                                    {
                                        <img src="@liga.Campeonato.LogoUrl" alt="@liga.Campeonato.Nome" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </div>
                                <div>
                                    <h3>@liga.Nome</h3>
                                    <p>@liga.Campeonato?.Nome</p>
                                    <a asp-controller="Ligas"
                                       asp-action="Ranking"
                                       asp-route-id="@liga.Id">
                                        Ranking
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </aside>
    </div>
</div>
