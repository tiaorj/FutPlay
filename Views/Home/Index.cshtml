@model FutPlay.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Portal de Futebol";
}

<div class="container mt-4">
    <section class="futplay-hero mb-4">
        <div class="row align-items-center g-4 p-4 p-md-5 position-relative">
            <div class="col-lg-7 position-relative">
                <span class="futplay-eyebrow mb-3">⚽ Portal + Ligas + Palpites</span>

                <h1 class="mb-3">FutPlay</h1>

                <p class="lead mb-4">
                    Acompanhe campeonatos, consulte jogos e dispute rankings com seus palpites em ligas de futebol.
                </p>

                <div class="futplay-actions mb-4">
                    <a asp-controller="Campeonatos" asp-action="Index" class="btn btn-light">
                        Ver Campeonatos
                    </a>

                    <a asp-controller="Jogos" asp-action="Index" class="btn btn-outline-light">
                        Ver Jogos
                    </a>

                    @if (User.IsInRole(AppRoles.Administrador) || User.IsInRole(AppRoles.Participante))
                    {
                        <a asp-controller="MinhasLigas" asp-action="Index" class="btn btn-warning">
                            Minhas Ligas
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-warning">
                            Criar Conta
                        </a>
                    }
                </div>

                <div class="futplay-hero-metrics">
                    <div class="futplay-hero-metric">
                        <div class="small text-white-50">Campeonatos</div>
                        <div class="fs-4 fw-bold">@Model.TotalCampeonatos</div>
                    </div>
                    <div class="futplay-hero-metric">
                        <div class="small text-white-50">Jogos agendados</div>
                        <div class="fs-4 fw-bold">@Model.TotalJogosAgendados</div>
                    </div>
                    <div class="futplay-hero-metric">
                        <div class="small text-white-50">Palpites</div>
                        <div class="fs-4 fw-bold">@Model.TotalPalpites</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="futplay-hero-visual">
                    <div class="futplay-hero-ball">⚽</div>
                    <div class="futplay-hero-score">
                        <div class="small text-white-50 mb-1">Próxima rodada</div>
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <span class="fw-bold">Casa</span>
                            <span class="futplay-score">0 x 0</span>
                            <span class="fw-bold">Visitante</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (User.Identity == null || !User.Identity.IsAuthenticated)
    {
        <div class="alert alert-success border-0 shadow-sm">
            <strong>Área pública liberada.</strong>
            Consulte campeonatos, jogos e classificações sem login. Para criar ligas e enviar palpites, entre ou crie uma conta.
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                <div class="card-body futplay-card-content">
                    <div>
                        <h6 class="text-muted">Campeonatos</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalCampeonatos</h2>
                    </div>
                    <div class="futplay-stat-icon">🏆</div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                <div class="card-body futplay-card-content">
                    <div>
                        <h6 class="text-muted">Jogos</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalJogos</h2>
                    </div>
                    <div class="futplay-stat-icon">📅</div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                <div class="card-body futplay-card-content">
                    <div>
                        <h6 class="text-muted">Ligas</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalLigas</h2>
                    </div>
                    <div class="futplay-stat-icon">👥</div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100 futplay-stat-card">
                <div class="card-body futplay-card-content">
                    <div>
                        <h6 class="text-muted">Resultados</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalJogosFinalizados</h2>
                    </div>
                    <div class="futplay-stat-icon">✅</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="futplay-section-title">
                <h2>Campeonatos em destaque</h2>
                <a asp-controller="Campeonatos" asp-action="Index" class="btn btn-sm btn-outline-success">
                    Ver todos
                </a>
            </div>

            @if (!Model.CampeonatosAtivos.Any())
            {
                <div class="futplay-empty">
                    Nenhum campeonato ativo cadastrado.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var campeonato in Model.CampeonatosAtivos)
                    {
                        <div class="col-md-6 mb-3">
                            <article class="futplay-entity-card">
                                <div class="d-flex align-items-start gap-3 mb-3">
                                    <span class="futplay-logo">
                                        @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                        {
                                            <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                        }
                                        else
                                        {
                                            <span>🏆</span>
                                        }
                                    </span>

                                    <div class="min-w-0">
                                        <div class="futplay-card-kicker">@campeonato.Tipo</div>
                                        <h5 class="mb-1">@campeonato.Nome @campeonato.Ano</h5>
                                        <p class="text-muted small mb-0">@(!string.IsNullOrWhiteSpace(campeonato.Pais) ? campeonato.Pais : "Campeonato")</p>
                                    </div>
                                </div>

                                <div class="futplay-actions">
                                    <a asp-controller="Campeonatos"
                                       asp-action="Portal"
                                       asp-route-id="@campeonato.Id"
                                       class="btn btn-sm btn-success">
                                        Portal
                                    </a>

                                    <a asp-controller="Campeonatos"
                                       asp-action="Classificacao"
                                       asp-route-id="@campeonato.Id"
                                       class="btn btn-sm btn-outline-dark">
                                        Classificação
                                    </a>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-5 mb-4">
            <div class="futplay-section-title">
                <h2>Próximos jogos</h2>
                <a asp-controller="Jogos" asp-action="Index" class="btn btn-sm btn-outline-success">
                    Ver jogos
                </a>
            </div>

            <div class="futplay-panel p-3">
                @if (!Model.ProximosJogos.Any())
                {
                    <div class="futplay-empty">
                        Nenhum jogo futuro cadastrado.
                    </div>
                }
                else
                {
                    @foreach (var jogo in Model.ProximosJogos)
                    {
                        <div class="futplay-match-row">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <small class="text-muted">@jogo.DataJogo.ToString("dd/MM/yyyy HH:mm")</small>
                                <span class="futplay-status futplay-status-live">@jogo.Status</span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="futplay-team-line">
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                    <strong class="futplay-team-name">@jogo.TimeCasa?.Nome</strong>
                                </div>
                                <span class="futplay-versus">x</span>
                                <div class="futplay-team-line justify-content-end">
                                    <strong class="futplay-team-name text-end">@jogo.TimeVisitante?.Nome</strong>
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                </div>
                            </div>

                            <div class="small text-muted mt-2">
                                @jogo.Campeonato?.Nome
                                @if (!string.IsNullOrWhiteSpace(jogo.Grupo))
                                {
                                    <span> · Grupo @jogo.Grupo</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="futplay-section-title">
                <h2>Últimos resultados</h2>
            </div>

            <div class="futplay-panel p-3">
                @if (!Model.UltimosResultados.Any())
                {
                    <div class="futplay-empty">
                        Nenhum resultado cadastrado.
                    </div>
                }
                else
                {
                    @foreach (var jogo in Model.UltimosResultados)
                    {
                        <div class="futplay-match-row">
                            <small class="text-muted d-block mb-2">
                                @jogo.DataJogo.ToString("dd/MM/yyyy HH:mm") · @jogo.Campeonato?.Nome
                            </small>

                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="futplay-team-line">
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                    <strong class="futplay-team-name">@jogo.TimeCasa?.Nome</strong>
                                </div>
                                <span class="futplay-score">@jogo.GolsCasa x @jogo.GolsVisitante</span>
                                <div class="futplay-team-line justify-content-end">
                                    <strong class="futplay-team-name text-end">@jogo.TimeVisitante?.Nome</strong>
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="futplay-section-title">
                <h2>Top participantes</h2>
            </div>

            <div class="futplay-table-card table-responsive">
                @if (!Model.TopParticipantes.Any())
                {
                    <div class="futplay-empty m-3">
                        Nenhum participante pontuando ainda.
                    </div>
                }
                else
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Participante</th>
                                <th>Liga</th>
                                <th>Pontos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var participante in Model.TopParticipantes)
                            {
                                <tr>
                                    <td><strong>@participante.Nome</strong></td>
                                    <td>@participante.Liga</td>
                                    <td>
                                        <span class="badge bg-dark">@participante.Pontos</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="futplay-section-title">
        <h2>Ligas públicas</h2>
        <a asp-controller="Ligas" asp-action="Index" class="btn btn-sm btn-outline-success">
            Ver ligas
        </a>
    </div>

    @if (!Model.LigasPublicas.Any())
    {
        <div class="futplay-empty mb-4">
            Nenhuma liga pública cadastrada ainda.
        </div>
    }
    else
    {
        <div class="row mb-4">
            @foreach (var liga in Model.LigasPublicas)
            {
                <div class="col-md-4 mb-3">
                    <article class="futplay-entity-card">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <span class="futplay-logo">
                                @if (!string.IsNullOrWhiteSpace(liga.Campeonato?.LogoUrl))
                                {
                                    <img src="@liga.Campeonato.LogoUrl" alt="@liga.Campeonato.Nome" />
                                }
                                else
                                {
                                    <span>👥</span>
                                }
                            </span>
                            <div>
                                <h5 class="mb-1">@liga.Nome</h5>
                                <p class="text-muted small mb-0">@liga.Campeonato?.Nome</p>
                            </div>
                        </div>

                        <div class="futplay-actions">
                            <a asp-controller="Ligas"
                               asp-action="Ranking"
                               asp-route-id="@liga.Id"
                               class="btn btn-sm btn-outline-dark">
                                Ranking
                            </a>

                            @if (User.IsInRole(AppRoles.Administrador) || User.IsInRole(AppRoles.Participante))
                            {
                                <a asp-controller="Ligas"
                                   asp-action="Palpitar"
                                   asp-route-id="@liga.Id"
                                   class="btn btn-sm btn-success">
                                    Palpitar
                                </a>
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
