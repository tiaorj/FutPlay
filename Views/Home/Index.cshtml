@model FutPlay.ViewModels.DashboardViewModel
@using FutPlay.Settings
@{
    ViewData["Title"] = "Portal de Futebol";

    var jogoDestaque = Model.ProximosJogos.FirstOrDefault()
        ?? Model.UltimosResultados.FirstOrDefault();

    var jogosLista = Model.ProximosJogos.Any()
        ? Model.ProximosJogos.Take(12).ToList()
        : Model.UltimosResultados.Take(12).ToList();

    var campeonatoDestaque = Model.CampeonatosAtivos.FirstOrDefault();
}

<div class="container fp-score-home">

    <div class="fp-score-page-title">
        <h2>Seu bolão de futebol online</h2>
        <p>
            Acompanhe jogos, participe de ligas públicas ou privadas e mostre quem entende mais de futebol.
        </p>
    </div>

    <div class="row g-3">

        <aside class="col-xl-4 col-lg-5">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a class="active" href="#">Todos</a>
                    <a href="#">Favoritos</a>
                    <a asp-controller="Campeonatos" asp-action="Index">Competições</a>
                </div>

                <div class="fp-score-filter-row">
                    <span class="fp-score-filter active">Ao vivo</span>
                    <span class="fp-score-filter">Finalizado</span>
                    <span class="fp-score-filter">Próximos</span>
                </div>

                <div class="fp-match-list-title">
                    <span>⚽ Futebol</span>
                    <small>@jogosLista.Count jogo(s)</small>
                </div>

                @if (!jogosLista.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhum jogo cadastrado.
                    </div>
                }
                else
                {
                    <div class="fp-score-match-list">
                        @foreach (var jogo in jogosLista)
                        {
                            var casaSigla = !string.IsNullOrWhiteSpace(jogo.TimeCasa?.Sigla)
                            ? jogo.TimeCasa.Sigla
                            : "CAS";

                            var visitanteSigla = !string.IsNullOrWhiteSpace(jogo.TimeVisitante?.Sigla)
                            ? jogo.TimeVisitante.Sigla
                            : "VIS";

                            <article class="fp-score-match-row">
                                <div class="fp-score-match-time">
                                    <strong>@jogo.DataJogo.ToString("HH:mm")</strong>
                                    <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                </div>

                                <div class="fp-score-match-clubs">
                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                @casaSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeCasa?.Nome</span>
                                    </div>

                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                @visitanteSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeVisitante?.Nome</span>
                                    </div>
                                </div>

                                <div class="fp-score-match-score">
                                    @if (jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue)
                                    {
                                        <strong>@jogo.GolsCasa</strong>
                                        <strong>@jogo.GolsVisitante</strong>
                                    }
                                    else
                                    {
                                        <strong>-</strong>
                                        <strong>-</strong>
                                    }
                                </div>

                                <div class="fp-score-match-star">
                                    ☆
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </aside>

        <main class="col-xl-5 col-lg-7">
            @if (jogoDestaque != null)
            {
                <section class="fp-feature-match">
                    <div class="fp-feature-league">
                        <div>
                            <span>Partida em destaque</span>
                            <strong>@(jogoDestaque.Campeonato?.Nome ?? jogoDestaque.Fase ?? "Meu Pitaco FC")</strong>
                        </div>

                        <small>@jogoDestaque.Status</small>
                    </div>

                    <div class="fp-feature-match-body">
                        <div class="fp-feature-team">
                            <div class="fp-feature-crest">
                                @if (!string.IsNullOrWhiteSpace(jogoDestaque.TimeCasa?.EscudoUrl))
                                {
                                    <img src="@jogoDestaque.TimeCasa.EscudoUrl" alt="@jogoDestaque.TimeCasa.Nome" />
                                }
                                else
                                {
                                    <span>@(jogoDestaque.TimeCasa?.Sigla ?? "CAS")</span>
                                }
                            </div>

                            <strong>@jogoDestaque.TimeCasa?.Nome</strong>
                        </div>

                        <div class="fp-feature-center">
                            <strong>@jogoDestaque.DataJogo.ToString("HH:mm")</strong>
                            <span>@jogoDestaque.DataJogo.ToString("dd/MM/yyyy")</span>

                            @if (jogoDestaque.GolsCasa.HasValue && jogoDestaque.GolsVisitante.HasValue)
                            {
                                <div class="fp-feature-score">
                                    @jogoDestaque.GolsCasa x @jogoDestaque.GolsVisitante
                                </div>
                            }
                            else
                            {
                                <div class="fp-feature-score">
                                    x
                                </div>
                            }
                        </div>

                        <div class="fp-feature-team">
                            <div class="fp-feature-crest">
                                @if (!string.IsNullOrWhiteSpace(jogoDestaque.TimeVisitante?.EscudoUrl))
                                {
                                    <img src="@jogoDestaque.TimeVisitante.EscudoUrl" alt="@jogoDestaque.TimeVisitante.Nome" />
                                }
                                else
                                {
                                    <span>@(jogoDestaque.TimeVisitante?.Sigla ?? "VIS")</span>
                                }
                            </div>

                            <strong>@jogoDestaque.TimeVisitante?.Nome</strong>
                        </div>
                    </div>

                    <div class="fp-feature-poll">
                        <h3>Quem vence?</h3>
                        <p>Entre no bolão e dê seus palpites.</p>

                        <div class="fp-feature-poll-buttons">
                            <button type="button">@jogoDestaque.TimeCasa?.Sigla</button>
                            <button type="button">X</button>
                            <button type="button">@jogoDestaque.TimeVisitante?.Sigla</button>
                        </div>
                    </div>
                </section>
            }

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Campeonatos em destaque</h2>
                    <a asp-controller="Campeonatos" asp-action="Index">Ver todos</a>
                </div>

                @if (!Model.CampeonatosAtivos.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhum campeonato ativo cadastrado.
                    </div>
                }
                else
                {
                    <div class="fp-competition-mini-grid">
                        @foreach (var campeonato in Model.CampeonatosAtivos.Take(4))
                        {
                            <article class="fp-competition-mini">
                                <div class="fp-competition-mini-logo">
                                    @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                    {
                                        <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </div>

                                <div>
                                    <strong>@campeonato.Nome @campeonato.Ano</strong>
                                    <span>@campeonato.Tipo</span>
                                </div>

                                <a asp-controller="Campeonatos"
                                   asp-action="Portal"
                                   asp-route-id="@campeonato.Id">
                                    Abrir
                                </a>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Últimos resultados</h2>
                    <a asp-controller="Jogos" asp-action="Index">Ver jogos</a>
                </div>

                @if (!Model.UltimosResultados.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhum resultado cadastrado.
                    </div>
                }
                else
                {
                    <div class="fp-result-list">
                        @foreach (var jogo in Model.UltimosResultados.Take(6))
                        {
                            <article class="fp-result-row">
                                <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                <strong>@jogo.TimeCasa?.Nome</strong>
                                <b>
                                    @(jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue
                                                                ? $"{jogo.GolsCasa} x {jogo.GolsVisitante}"
                                                                : "x")
                        </b>
                        <strong>@jogo.TimeVisitante?.Nome</strong>
                    </article>
                                        }
                    </div>
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>⚽ Meu Pitaco FC</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ligas públicas</h2>
                    <a asp-controller="Ligas" asp-action="Index">Ver</a>
                </div>

                @if (!Model.LigasPublicas.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhuma liga pública cadastrada.
                    </div>
                }
                else
                {
                    <div class="fp-public-league-mini-list">
                        @foreach (var liga in Model.LigasPublicas.Take(5))
                        {
                            <article class="fp-public-league-mini">
                                <div>
                                    <strong>@liga.Nome</strong>
                                    <span>@liga.Campeonato?.Nome</span>
                                </div>

                                <a asp-controller="Ligas"
                                   asp-action="Ranking"
                                   asp-route-id="@liga.Id">
                                    Ranking
                                </a>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="fp-home-card mt-3">
                <h2>Entre no bolão</h2>

                <p class="fp-side-text">
                    Crie sua conta para participar de ligas, enviar palpites e acompanhar rankings.
                </p>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="MinhasLigas"
                       asp-action="Index"
                       class="btn btn-success w-100">
                        Minhas Ligas
                    </a>
                }
                else
                {
                    <a asp-area="Identity"
                       asp-page="/Account/Register"
                       class="btn btn-success w-100">
                        Criar Conta
                    </a>
                }
            </section>
        </aside>
    </div>
</div>