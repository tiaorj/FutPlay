@model FutPlay.ViewModels.PortalCampeonatoViewModel

@{
    ViewData["Title"] = "Portal do Campeonato";

    var totalTimes = Model.Classificacoes.Select(c => c.TimeId).Distinct().Count();
    var gruposClassificacao = Model.Classificacoes
        .GroupBy(c => c.Grupo)
        .ToList();
    var jogosPorDia = Model.JogosDaRodada
        .OrderBy(j => j.DataJogo)
        .GroupBy(j => j.DataJogo.ToString("dd/MM/yyyy"))
        .ToList();
    var classificacaoResumo = gruposClassificacao
        .SelectMany(g => g.OrderBy(c => c.Posicao).Take(4))
        .ToList();
    var rodadaTitulo = Model.RodadaSelecionada.HasValue
        ? $"Rodada {Model.RodadaSelecionada}"
        : "Jogos";

    string StatusCss(string? status)
    {
        if (string.Equals(status, "Finalizado", StringComparison.OrdinalIgnoreCase))
        {
            return "finished";
        }

        if (string.Equals(status, "Ao Vivo", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Em andamento", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Em Andamento", StringComparison.OrdinalIgnoreCase))
        {
            return "live";
        }

        return "scheduled";
    }
}

<div class="container fp-score-home">

    <section class="fp-champ-header mb-3">
        <div class="fp-champ-logo">
            @if (!string.IsNullOrWhiteSpace(Model.Campeonato.LogoUrl))
            {
                <img src="@Model.Campeonato.LogoUrl" alt="@Model.Campeonato.Nome" />
            }
            else
            {
                <span>FP</span>
            }
        </div>

        <div class="fp-champ-info">
            <span>Portal da competição</span>
            <h1>@Model.Campeonato.Nome @Model.Campeonato.Ano</h1>
            <p>
                @Model.Campeonato.Tipo
                @if (!string.IsNullOrWhiteSpace(Model.Campeonato.Pais))
                {
                    <span> &middot; @Model.Campeonato.Pais</span>
                }
            </p>
        </div>

        <div class="fp-champ-actions">
            <a asp-action="Portal"
               asp-route-id="@Model.Campeonato.Id"
               asp-route-aba="jogos"
               asp-route-rodada="@Model.RodadaSelecionada"
               class="@(Model.AbaJogosAtiva ? "active" : "")">
                Jogos
            </a>

            <a asp-action="Portal"
               asp-route-id="@Model.Campeonato.Id"
               asp-route-aba="classificacao"
               class="@(Model.AbaClassificacaoAtiva ? "active" : "")">
                Classificação
            </a>

            <a asp-action="Index">Outras competições</a>
        </div>
    </section>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Times</span>
                        <strong>@totalTimes</strong>
                    </div>

                    <div>
                        <span>Jogos</span>
                        <strong>@Model.TotalJogos</strong>
                    </div>

                    <div>
                        <span>Hoje</span>
                        <strong>@Model.TotalHoje</strong>
                    </div>

                    <div>
                        <span>Rodada</span>
                        <strong>@(Model.RodadaSelecionada?.ToString() ?? "-")</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Navegação</h2>
                </div>

                <div class="fp-score-filter-column">
                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="visao-geral"
                       class="fp-score-filter @(Model.AbaVisaoGeralAtiva ? "active" : "")">
                        Visão geral
                    </a>

                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="jogos"
                       asp-route-rodada="@Model.RodadaSelecionada"
                       class="fp-score-filter @(Model.AbaJogosAtiva ? "active" : "")">
                        Jogos
                    </a>

                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="classificacao"
                       class="fp-score-filter @(Model.AbaClassificacaoAtiva ? "active" : "")">
                        Classificação
                    </a>

                    <a asp-action="Index" class="fp-score-filter">
                        Competições
                    </a>
                </div>
            </section>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <section class="fp-home-card mt-3">
                    <div class="fp-card-header-link">
                        <h2>Admin</h2>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-action="RecalcularClassificacao"
                           asp-route-id="@Model.Campeonato.Id"
                           class="btn btn-outline-primary">
                            Recalcular classificação
                        </a>

                        @if (Model.Campeonato.ApiLeagueId.HasValue)
                        {
                            <form asp-controller="Importacoes"
                                  asp-action="SincronizarCampeonato"
                                  method="post">
                                <input type="hidden" name="campeonatoId" value="@Model.Campeonato.Id" />
                                <button type="submit" class="btn btn-success w-100">
                                    Sincronizar
                                </button>
                            </form>
                        }
                    </div>
                </section>
            }
        </aside>

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="visao-geral"
                       class="@(Model.AbaVisaoGeralAtiva ? "active" : "")">
                        Visão geral
                    </a>

                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="jogos"
                       asp-route-rodada="@Model.RodadaSelecionada"
                       class="@(Model.AbaJogosAtiva ? "active" : "")">
                        Jogos
                    </a>

                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="classificacao"
                       class="@(Model.AbaClassificacaoAtiva ? "active" : "")">
                        Classificação
                    </a>

                    <a asp-action="Index">Competições</a>
                </div>

                @if (Model.AbaVisaoGeralAtiva)
                {
                    <div class="fp-score-filter-row">
                        <span class="fp-score-filter active">Visão geral</span>
                        <span class="fp-score-filter">@Model.TotalProximos próximos</span>
                        <span class="fp-score-filter">@Model.TotalFinalizados finalizados</span>
                    </div>

                    <section class="fp-portal-section">
                        <div class="fp-match-list-title">
                            <span>Próximos jogos</span>
                            <a asp-action="Portal"
                               asp-route-id="@Model.Campeonato.Id"
                               asp-route-aba="jogos"
                               asp-route-rodada="@Model.RodadaSelecionada">
                                Ver rodada
                            </a>
                        </div>

                        @if (!Model.ProximosJogos.Any())
                        {
                            <div class="fp-empty-mini m-3">
                                Nenhum jogo futuro cadastrado para esta competição.
                            </div>
                        }
                        else
                        {
                            <div class="fp-score-match-list">
                                @foreach (var jogo in Model.ProximosJogos.Take(5))
                                {
                                    var casaSigla = !string.IsNullOrWhiteSpace(jogo.TimeCasa?.Sigla)
                                        ? jogo.TimeCasa.Sigla
                                        : "CAS";
                                    var visitanteSigla = !string.IsNullOrWhiteSpace(jogo.TimeVisitante?.Sigla)
                                        ? jogo.TimeVisitante.Sigla
                                        : "VIS";

                                    <article class="fp-score-match-row fp-score-match-row-full">
                                        <div class="fp-score-match-time">
                                            <strong>@jogo.DataJogo.ToString("HH:mm")</strong>
                                            <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                        </div>

                                        <div class="fp-score-match-clubs">
                                            <div class="fp-score-club">
                                                <span class="fp-mini-crest">
                                                    @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                                    {
                                                        <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                                    }
                                                    else
                                                    {
                                                        @casaSigla
                                                    }
                                                </span>
                                                <span>@jogo.TimeCasa?.Nome</span>
                                            </div>

                                            <div class="fp-score-club">
                                                <span class="fp-mini-crest">
                                                    @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                                    {
                                                        <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                                    }
                                                    else
                                                    {
                                                        @visitanteSigla
                                                    }
                                                </span>
                                                <span>@jogo.TimeVisitante?.Nome</span>
                                            </div>
                                        </div>

                                        <div class="fp-score-match-score">
                                            <strong>-</strong>
                                            <strong>-</strong>
                                        </div>

                                        <div class="fp-score-match-extra">
                                            <span class="fp-status @StatusCss(jogo.Status)">
                                                @jogo.Status
                                            </span>

                                            <a asp-controller="Jogos"
                                               asp-action="Details"
                                               asp-route-id="@jogo.Id">
                                                Detalhes
                                            </a>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>

                    <section class="fp-portal-section">
                        <div class="fp-match-list-title">
                            <span>Classificação resumida</span>
                            <a asp-action="Portal"
                               asp-route-id="@Model.Campeonato.Id"
                               asp-route-aba="classificacao">
                                Ver completa
                            </a>
                        </div>

                        @if (!classificacaoResumo.Any())
                        {
                            <div class="fp-empty-mini m-3">
                                Nenhuma classificação disponível para esta competição.
                            </div>
                        }
                        else
                        {
                            <div class="fp-standings-compact">
                                @foreach (var item in classificacaoResumo)
                                {
                                    <div class="fp-standing-compact-row">
                                        <span>@item.Posicao</span>
                                        <strong>@item.Time?.Nome</strong>
                                        <b>@item.Pontos pts</b>
                                    </div>
                                }
                            </div>
                        }
                    </section>
                }
                else if (Model.AbaJogosAtiva)
                {
                    <div class="fp-round-toolbar">
                        @if (Model.RodadaAnterior.HasValue)
                        {
                            <a asp-action="Portal"
                               asp-route-id="@Model.Campeonato.Id"
                               asp-route-aba="jogos"
                               asp-route-rodada="@Model.RodadaAnterior"
                               class="fp-round-nav">
                                Anterior
                            </a>
                        }
                        else
                        {
                            <span class="fp-round-nav disabled">Anterior</span>
                        }

                        <form asp-action="Portal" method="get" class="fp-round-select-form">
                            <input type="hidden" name="id" value="@Model.Campeonato.Id" />
                            <input type="hidden" name="aba" value="jogos" />

                            <select name="rodada" class="form-select form-select-sm" onchange="this.form.submit()">
                                @if (!Model.Rodadas.Any())
                                {
                                    <option value="">Sem rodadas</option>
                                }
                                else
                                {
                                    @foreach (var rodada in Model.Rodadas)
                                    {
                                        <option value="@rodada.Rodada" selected="@rodada.Selecionada">
                                            Rodada @rodada.Rodada - @rodada.TotalJogos jogo(s)
                                        </option>
                                    }
                                }
                            </select>
                        </form>

                        @if (Model.ProximaRodada.HasValue)
                        {
                            <a asp-action="Portal"
                               asp-route-id="@Model.Campeonato.Id"
                               asp-route-aba="jogos"
                               asp-route-rodada="@Model.ProximaRodada"
                               class="fp-round-nav">
                                Próxima
                            </a>
                        }
                        else
                        {
                            <span class="fp-round-nav disabled">Próxima</span>
                        }
                    </div>

                    <div class="fp-score-filter-row">
                        <span class="fp-score-filter active">@rodadaTitulo</span>
                        <span class="fp-score-filter">@Model.JogosDaRodada.Count jogo(s)</span>
                        <span class="fp-score-filter">@Model.Campeonato.Nome</span>
                    </div>

                    @if (!Model.JogosDaRodada.Any())
                    {
                        <div class="fp-empty-mini m-3">
                            Nenhum jogo encontrado para a rodada selecionada.
                        </div>
                    }
                    else
                    {
                        <div class="fp-score-match-list">
                            @foreach (var grupo in jogosPorDia)
                            {
                                <div class="fp-match-list-title">
                                    <span>@grupo.Key</span>
                                    <small>@grupo.Count() jogo(s)</small>
                                </div>

                                @foreach (var jogo in grupo.OrderBy(j => j.DataJogo))
                                {
                                    var casaSigla = !string.IsNullOrWhiteSpace(jogo.TimeCasa?.Sigla)
                                        ? jogo.TimeCasa.Sigla
                                        : "CAS";
                                    var visitanteSigla = !string.IsNullOrWhiteSpace(jogo.TimeVisitante?.Sigla)
                                        ? jogo.TimeVisitante.Sigla
                                        : "VIS";

                                    <article class="fp-score-match-row fp-score-match-row-full">
                                        <div class="fp-score-match-time">
                                            <strong>@jogo.DataJogo.ToString("HH:mm")</strong>
                                            <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                        </div>

                                        <div class="fp-score-match-clubs">
                                            <div class="fp-score-club">
                                                <span class="fp-mini-crest">
                                                    @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                                    {
                                                        <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                                    }
                                                    else
                                                    {
                                                        @casaSigla
                                                    }
                                                </span>
                                                <span>@jogo.TimeCasa?.Nome</span>
                                            </div>

                                            <div class="fp-score-club">
                                                <span class="fp-mini-crest">
                                                    @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                                    {
                                                        <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                                    }
                                                    else
                                                    {
                                                        @visitanteSigla
                                                    }
                                                </span>
                                                <span>@jogo.TimeVisitante?.Nome</span>
                                            </div>
                                        </div>

                                        <div class="fp-score-match-score">
                                            @if (jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue)
                                            {
                                                <strong>@jogo.GolsCasa</strong>
                                                <strong>@jogo.GolsVisitante</strong>
                                            }
                                            else
                                            {
                                                <strong>-</strong>
                                                <strong>-</strong>
                                            }
                                        </div>

                                        <div class="fp-score-match-extra">
                                            <span class="fp-status @StatusCss(jogo.Status)">
                                                @jogo.Status
                                            </span>

                                            <a asp-controller="Jogos"
                                               asp-action="Details"
                                               asp-route-id="@jogo.Id">
                                                Detalhes
                                            </a>

                                            @if (User.IsInRole(AppRoles.Administrador))
                                            {
                                                <a asp-controller="Jogos"
                                                   asp-action="Edit"
                                                   asp-route-id="@jogo.Id">
                                                    Editar
                                                </a>
                                            }
                                        </div>
                                    </article>
                                }
                            }
                        </div>
                    }
                }
                else if (Model.AbaClassificacaoAtiva)
                {
                    <div class="fp-score-filter-row">
                        <span class="fp-score-filter active">Classificação</span>
                        <span class="fp-score-filter">@totalTimes times</span>
                        <span class="fp-score-filter">@gruposClassificacao.Count grupo(s)</span>
                    </div>

                    @await Html.PartialAsync("_ClassificacaoTabela", new FutPlay.ViewModels.ClassificacaoTabelaViewModel
                    {
                        Classificacoes = Model.Classificacoes,
                        UltimosResultadosPorTime = Model.UltimosResultadosPorTime,
                        EmptyMessage = "Nenhuma classificação disponível para esta competição."
                    })
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Rodada</h2>
                    <a asp-controller="Jogos"
                       asp-action="Index"
                       asp-route-aba="competicoes"
                       asp-route-campeonatoId="@Model.Campeonato.Id"
                       asp-route-rodada="@Model.RodadaSelecionada">
                        Abrir jogos
                    </a>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Selecionada</span>
                        <strong>@(Model.RodadaSelecionada?.ToString() ?? "-")</strong>
                    </div>

                    <div>
                        <span>Partidas</span>
                        <strong>@Model.JogosDaRodada.Count</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Resultados recentes</h2>
                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="jogos">
                        Ver jogos
                    </a>
                </div>

                @if (!Model.JogosFinalizados.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhum resultado recente cadastrado.
                    </div>
                }
                else
                {
                    <div class="fp-result-list">
                        @foreach (var jogo in Model.JogosFinalizados.Take(6))
                        {
                            <article class="fp-result-row">
                                <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                <strong>@jogo.TimeCasa?.Nome</strong>
                                <b>
                                    @(jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue
                                        ? $"{jogo.GolsCasa} x {jogo.GolsVisitante}"
                                        : "x")
                                </b>
                                <strong>@jogo.TimeVisitante?.Nome</strong>
                            </article>
                        }
                    </div>
                }
            </section>
        </aside>
    </div>
</div>
