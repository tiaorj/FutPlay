@model FutPlay.ViewModels.PortalCampeonatoViewModel

@{
    ViewData["Title"] = "Portal do Campeonato";
}

<div class="container mt-4">
    <section class="futplay-page-hero futplay-page-hero-dark mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
            <div class="d-flex align-items-center gap-3">
                <span class="futplay-logo-lg">
                    @if (!string.IsNullOrWhiteSpace(Model.Campeonato.LogoUrl))
                    {
                        <img src="@Model.Campeonato.LogoUrl" alt="@Model.Campeonato.Nome" />
                    }
                    else
                    {
                        <span>🏆</span>
                    }
                </span>

                <div>
                    <div class="futplay-card-kicker text-white-50">Portal do campeonato</div>
                    <h1 class="futplay-page-title mb-1">
                        @Model.Campeonato.Nome @Model.Campeonato.Ano
                    </h1>
                    <p class="futplay-subtitle mb-0">
                        @Model.Campeonato.Tipo
                        @if (!string.IsNullOrWhiteSpace(Model.Campeonato.Pais))
                        {
                            <span> · @Model.Campeonato.Pais</span>
                        }
                    </p>
                </div>
            </div>

            <div class="futplay-actions">
                <a asp-action="Classificacao"
                   asp-route-id="@Model.Campeonato.Id"
                   class="btn btn-light">
                    Ver Classificação
                </a>

                <a asp-action="Index" class="btn btn-outline-light">
                    Voltar
                </a>
            </div>
        </div>

        <div class="row mt-4 g-3">
            <div class="col-6 col-md-3">
                <div class="futplay-hero-metric">
                    <span class="small text-white-50 d-block">Status</span>
                    @if (Model.Campeonato.Ativo)
                    {
                        <strong>Ativo</strong>
                    }
                    else
                    {
                        <strong>Inativo</strong>
                    }
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="futplay-hero-metric">
                    <span class="small text-white-50 d-block">Início</span>
                    <strong>@(Model.Campeonato.DataInicio.HasValue ? Model.Campeonato.DataInicio.Value.ToString("dd/MM/yyyy") : "-")</strong>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="futplay-hero-metric">
                    <span class="small text-white-50 d-block">Fim</span>
                    <strong>@(Model.Campeonato.DataFim.HasValue ? Model.Campeonato.DataFim.Value.ToString("dd/MM/yyyy") : "-")</strong>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="futplay-hero-metric">
                    <span class="small text-white-50 d-block">Jogos</span>
                    <strong>@(Model.ProximosJogos.Count + Model.JogosFinalizados.Count)</strong>
                </div>
            </div>
        </div>
    </section>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="futplay-section-title">
                <h2>Classificação</h2>

                @if (User.IsInRole(AppRoles.Administrador))
                {
                    <div class="futplay-actions">
                        <a asp-action="RecalcularClassificacao"
                           asp-route-id="@Model.Campeonato.Id"
                           class="btn btn-sm btn-outline-success">
                            Recalcular
                        </a>

                        @if (Model.Campeonato.ApiLeagueId.HasValue)
                        {
                            <form asp-controller="Importacoes"
                                  asp-action="SincronizarCampeonato"
                                  method="post">
                                <input type="hidden" name="campeonatoId" value="@Model.Campeonato.Id" />

                                <button type="submit" class="btn btn-sm btn-success">
                                    Sincronizar
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>

            @if (!Model.Classificacoes.Any())
            {
                <div class="futplay-empty">
                    Nenhuma classificação disponível para este campeonato.
                </div>
            }
            else
            {
                var grupos = Model.Classificacoes
                    .GroupBy(c => string.IsNullOrWhiteSpace(c.Grupo) ? "Classificação Geral" : $"Grupo {c.Grupo}")
                    .ToList();

                foreach (var grupo in grupos)
                {
                    <div class="futplay-table-card mb-4">
                        <div class="px-3 py-2 border-bottom bg-white">
                            <strong>@grupo.Key</strong>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Pos</th>
                                        <th>Time</th>
                                        <th>Pts</th>
                                        <th>J</th>
                                        <th>V</th>
                                        <th>E</th>
                                        <th>D</th>
                                        <th>SG</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in grupo)
                                    {
                                        <tr>
                                            <td>
                                                <span class="futplay-rank-number">@item.Posicao</span>
                                            </td>
                                            <td>
                                                <div class="futplay-team-line">
                                                    <span class="futplay-logo-sm">
                                                        @if (!string.IsNullOrWhiteSpace(item.Time?.EscudoUrl))
                                                        {
                                                            <img src="@item.Time.EscudoUrl" alt="@item.Time.Nome" />
                                                        }
                                                        else
                                                        {
                                                            <span>⚽</span>
                                                        }
                                                    </span>
                                                    <div>
                                                        <strong>@item.Time?.Nome</strong>
                                                        @if (!string.IsNullOrWhiteSpace(item.Time?.Sigla))
                                                        {
                                                            <small class="text-muted d-block">@item.Time.Sigla</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td><strong>@item.Pontos</strong></td>
                                            <td>@item.Jogos</td>
                                            <td>@item.Vitorias</td>
                                            <td>@item.Empates</td>
                                            <td>@item.Derrotas</td>
                                            <td>@item.SaldoGols</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-5 mb-4">
            <div class="futplay-section-title">
                <h2>Próximos jogos</h2>
            </div>

            <div class="futplay-panel p-3 mb-4">
                @if (!Model.ProximosJogos.Any())
                {
                    <div class="futplay-empty">
                        Nenhum jogo futuro cadastrado.
                    </div>
                }
                else
                {
                    @foreach (var jogo in Model.ProximosJogos)
                    {
                        <div class="futplay-match-row">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <small class="text-muted">@jogo.DataJogo.ToString("dd/MM/yyyy HH:mm")</small>
                                <span class="futplay-status futplay-status-live">@jogo.Status</span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="futplay-team-line">
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                    <strong class="futplay-team-name">@jogo.TimeCasa?.Nome</strong>
                                </div>
                                <span class="futplay-versus">x</span>
                                <div class="futplay-team-line justify-content-end">
                                    <strong class="futplay-team-name text-end">@jogo.TimeVisitante?.Nome</strong>
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(jogo.Grupo))
                            {
                                <span class="badge bg-light text-dark border mt-2">Grupo @jogo.Grupo</span>
                            }
                        </div>
                    }
                }
            </div>

            <div class="futplay-section-title">
                <h2>Resultados recentes</h2>
            </div>

            <div class="futplay-panel p-3">
                @if (!Model.JogosFinalizados.Any())
                {
                    <div class="futplay-empty">
                        Nenhum jogo finalizado cadastrado.
                    </div>
                }
                else
                {
                    @foreach (var jogo in Model.JogosFinalizados.Take(8))
                    {
                        <div class="futplay-match-row">
                            <small class="text-muted d-block mb-2">@jogo.DataJogo.ToString("dd/MM/yyyy HH:mm")</small>

                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="futplay-team-line">
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                    <strong class="futplay-team-name">@jogo.TimeCasa?.Nome</strong>
                                </div>
                                <span class="futplay-score">@jogo.GolsCasa x @jogo.GolsVisitante</span>
                                <div class="futplay-team-line justify-content-end">
                                    <strong class="futplay-team-name text-end">@jogo.TimeVisitante?.Nome</strong>
                                    <span class="futplay-logo-sm">
                                        @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                        {
                                            <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                        }
                                        else
                                        {
                                            <span>⚽</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
