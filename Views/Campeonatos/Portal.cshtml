@model FutPlay.ViewModels.PortalCampeonatoViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Portal do Campeonato";

    var usuarioAdministrador = User.IsInRole(AppRoles.Administrador);
    var exibirPorGrupos = Model.ExibirClassificacaoPorGrupos;
    var isPontosCorridos = !exibirPorGrupos;
    var totalTimes = exibirPorGrupos && Model.CampeonatoTimes.Any()
        ? Model.CampeonatoTimes.Select(ct => ct.TimeId).Distinct().Count()
        : Model.Classificacoes.Select(c => c.TimeId).Distinct().Count();
    var grupoPorTimeId = Model.CampeonatoTimes
        .Where(ct => ct.Grupo != null && !string.IsNullOrWhiteSpace(ct.Grupo.Nome))
        .GroupBy(ct => ct.TimeId)
        .ToDictionary(g => g.Key, g => g.First().Grupo?.Nome ?? string.Empty);
    var gruposAtivosVisaoGeral = Model.Grupos
        .Where(g => g.Ativo)
        .OrderBy(g => NomeGrupo(g.Nome))
        .ToList();
    var grupoVisaoGeralSelecionado = gruposAtivosVisaoGeral.FirstOrDefault(g =>
        string.Equals(ChaveGrupo(g.Nome), ChaveGrupo(Model.GrupoSelecionado), StringComparison.OrdinalIgnoreCase))
        ?? gruposAtivosVisaoGeral.FirstOrDefault();
    var campeonatoTimesGrupoVisaoGeral = grupoVisaoGeralSelecionado == null
        ? new List<CampeonatoTime>()
        : Model.CampeonatoTimes
            .Where(ct => ct.Ativo &&
                (ct.GrupoId == grupoVisaoGeralSelecionado.Id ||
                 string.Equals(ChaveGrupo(ct.Grupo?.Nome), ChaveGrupo(grupoVisaoGeralSelecionado.Nome), StringComparison.OrdinalIgnoreCase)))
            .ToList();
    var timeIdsGrupoVisaoGeral = campeonatoTimesGrupoVisaoGeral
        .Select(ct => ct.TimeId)
        .ToHashSet();
    var classificacoesGrupoVisaoGeral = grupoVisaoGeralSelecionado == null
        ? new List<Classificacao>()
        : (timeIdsGrupoVisaoGeral.Any()
            ? Model.Classificacoes.Where(c => timeIdsGrupoVisaoGeral.Contains(c.TimeId))
            : Model.Classificacoes.Where(c =>
                grupoPorTimeId.TryGetValue(c.TimeId, out var grupoTime) &&
                string.Equals(ChaveGrupo(grupoTime), ChaveGrupo(grupoVisaoGeralSelecionado.Nome), StringComparison.OrdinalIgnoreCase)))
            .OrderBy(c => c.Posicao)
            .ToList();
    var agruparJogosPorGrupo = Model.Modo == "grupo" && string.IsNullOrWhiteSpace(Model.GrupoSelecionado);
    IEnumerable<FutPlay.Models.Jogo> jogosParaAgrupar = agruparJogosPorGrupo
        ? Model.JogosDaRodada
        : Model.JogosDaRodada.OrderBy(j => j.DataJogo).ToList();
    var jogosPorDiaBase = jogosParaAgrupar
        .GroupBy(j => agruparJogosPorGrupo ? GrupoDoJogo(j) : j.DataJogo.ToString("dd/MM/yyyy"));
    var jogosPorDia = agruparJogosPorGrupo
        ? jogosPorDiaBase.OrderBy(g => ChaveGrupo(g.Key)).ToList()
        : jogosPorDiaBase.ToList();
    var jogosDestaque = Model.JogosDaRodada
        .OrderBy(j => j.DataJogo)
        .Take(4)
        .ToList();
    var jogoDestaque = Model.ProximosJogos.FirstOrDefault()
        ?? Model.JogosFinalizados.FirstOrDefault()
        ?? Model.JogosDaRodada.FirstOrDefault();
    var rodadaTitulo = Model.RodadaSelecionada.HasValue
        ? $"Rodada {Model.RodadaSelecionada}"
        : "Rodada";

    string Sigla(FutPlay.Models.Time? time, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(time?.Sigla))
        {
            return time.Sigla;
        }

        if (!string.IsNullOrWhiteSpace(time?.Nome))
        {
            return time.Nome.Substring(0, Math.Min(3, time.Nome.Length)).ToUpperInvariant();
        }

        return fallback;
    }

    string NomeGrupo(string? grupo)
    {
        if (string.IsNullOrWhiteSpace(grupo))
        {
            return "Geral";
        }

        var texto = grupo.Trim();

        return texto.StartsWith("Grupo ", StringComparison.OrdinalIgnoreCase)
            ? texto
            : $"Grupo {texto}";
    }

    string ChaveGrupo(string? grupo)
    {
        if (string.IsNullOrWhiteSpace(grupo))
        {
            return string.Empty;
        }

        var texto = grupo.Trim();

        return texto.StartsWith("Grupo ", StringComparison.OrdinalIgnoreCase)
            ? texto.Substring("Grupo ".Length).Trim()
            : texto;
    }

    string GrupoDoJogo(FutPlay.Models.Jogo jogo)
    {
        grupoPorTimeId.TryGetValue(jogo.TimeCasaId, out var grupoCasa);
        grupoPorTimeId.TryGetValue(jogo.TimeVisitanteId, out var grupoVisitante);

        if (!string.IsNullOrWhiteSpace(grupoCasa) &&
            (string.IsNullOrWhiteSpace(grupoVisitante) ||
             string.Equals(grupoCasa, grupoVisitante, StringComparison.OrdinalIgnoreCase)))
        {
            return NomeGrupo(grupoCasa);
        }

        if (!string.IsNullOrWhiteSpace(grupoVisitante) && string.IsNullOrWhiteSpace(grupoCasa))
        {
            return NomeGrupo(grupoVisitante);
        }

        return !string.IsNullOrWhiteSpace(jogo.Grupo)
            ? NomeGrupo(jogo.Grupo)
            : "Sem grupo";
    }

    var gruposFiltro = Model.Grupos
        .Select(g => ChaveGrupo(g.Nome))
        .Concat(Model.Jogos
            .Select(j => ChaveGrupo(GrupoDoJogo(j)))
            .Where(g => !string.IsNullOrWhiteSpace(g) &&
                !string.Equals(g, "Sem grupo", StringComparison.OrdinalIgnoreCase)))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(g => g)
        .ToList();

    // Helper para exibir horário com pt-BR e "Horário a definir" quando 00:00
    string FormatarHorario(DateTime dt)
    {
        if (dt.TimeOfDay == TimeSpan.Zero)
        {
            return "Horário a definir";
        }

        return dt.ToString("HH:mm", CultureInfo.GetCultureInfo("pt-BR"));
    }

    // Abreviação do dia da semana em pt-BR com capitalização inicial
    string DiaAbreviado(DateTime dt)
    {
        var cultura = CultureInfo.GetCultureInfo("pt-BR");
        var abbr = cultura.DateTimeFormat.GetAbbreviatedDayName(dt.DayOfWeek) ?? string.Empty;
        if (string.IsNullOrEmpty(abbr)) return string.Empty;
        var txt = char.ToUpperInvariant(abbr[0]) + (abbr.Length > 1 ? abbr.Substring(1) : string.Empty);
        return txt.Replace(".", "");
    }
}

<div class="container fp-competition-tv-page">
    <section class="fp-tv-titlebar">
        <div class="fp-tv-title-logo">
            @if (!string.IsNullOrWhiteSpace(Model.Campeonato.LogoUrl))
            {
                <img src="@Model.Campeonato.LogoUrl" alt="@Model.Campeonato.Nome" />
            }
            else
            {
                <span>FP</span>
            }
        </div>

        <div>
            <span>@Model.FormatoDescricao</span>
            <h1>@Model.Campeonato.Nome @Model.Campeonato.Ano</h1>
            <p>
                @Model.Campeonato.Tipo
                @if (!string.IsNullOrWhiteSpace(Model.Campeonato.Pais))
                {
                    <span> &middot; @PaisExibicao.Normalizar(Model.Campeonato.Pais)</span>
                }
            </p>
        </div>

        <div class="fp-tv-title-actions">
            <a asp-action="Index" asp-route-ano="@Model.Campeonato.Ano">Competições</a>

            @if (usuarioAdministrador && Model.Campeonato.ApiLeagueId.HasValue)
            {
                <form asp-controller="Importacoes" asp-action="SincronizarJogos" method="post">
                    <input type="hidden" name="campeonatoId" value="@Model.Campeonato.Id" />
                    <button type="submit">Sincronizar jogos</button>
                </form>

                <form asp-controller="Importacoes" asp-action="AtualizarResultados" method="post">
                    <input type="hidden" name="campeonatoId" value="@Model.Campeonato.Id" />
                    <button type="submit">Atualizar resultados</button>
                </form>
            }

            @if (usuarioAdministrador && Model.Campeonato.FootballDataCompetitionId.HasValue)
            {
                <form asp-controller="Importacoes" asp-action="AtualizarResultadosFootballDataOrg" method="post">
                    <input type="hidden" name="campeonatoId" value="@Model.Campeonato.Id" />
                    <button type="submit">Atualizar football-data.org</button>
                </form>
            }
        </div>
    </section>

    <div class="fp-tv-grid @(isPontosCorridos ? "league" : "cup")">
        <aside class="fp-tv-left">
            @if (isPontosCorridos && jogoDestaque != null)
            {
                <section class="fp-tv-card fp-featured-match">
                    <h2>Destacado</h2>

                    <div class="fp-featured-match-grid">
                        <div class="fp-featured-team">
                            <span class="fp-tv-crest large">
                                @if (!string.IsNullOrWhiteSpace(jogoDestaque.TimeCasa?.EscudoUrl))
                                {
                                    <img src="@jogoDestaque.TimeCasa.EscudoUrl" alt="@jogoDestaque.TimeCasa.Nome" />
                                }
                                else
                                {
                                    @Sigla(jogoDestaque.TimeCasa, "CAS")
                                }
                            </span>
                            <strong>@jogoDestaque.TimeCasa?.Nome</strong>
                        </div>

                        <div class="fp-featured-date">
                            <strong>@jogoDestaque.DataJogo.ToString("dd/MM/yyyy", CultureInfo.GetCultureInfo("pt-BR"))</strong>
                            <span>
                                @if (string.Equals(jogoDestaque.Status, "Finalizado", StringComparison.OrdinalIgnoreCase))
                                {
                                    <text>FT</text>
                                }
                                else
                                {
                                    <text>@DiaAbreviado(jogoDestaque.DataJogo), @FormatarHorario(jogoDestaque.DataJogo)</text>
                                }
                            </span>
                        </div>

                        <div class="fp-featured-team">
                            <span class="fp-tv-crest large">
                                @if (!string.IsNullOrWhiteSpace(jogoDestaque.TimeVisitante?.EscudoUrl))
                                {
                                    <img src="@jogoDestaque.TimeVisitante.EscudoUrl" alt="@jogoDestaque.TimeVisitante.Nome" />
                                }
                                else
                                {
                                    @Sigla(jogoDestaque.TimeVisitante, "VIS")
                                }
                            </span>
                            <strong>@jogoDestaque.TimeVisitante?.Nome</strong>
                        </div>
                    </div>
                </section>
            }

            <section class="fp-tv-card fp-tv-fixtures-card">
                <h2>Partidas</h2>

                <div class="fp-tv-segmented">
                    <a asp-action="Portal"
                       asp-route-id="@Model.Campeonato.Id"
                       asp-route-aba="@Model.Aba"
                       asp-route-modo="data"
                       class="@(Model.Modo == "data" ? "active" : "")">Por data</a>
                    @if (isPontosCorridos)
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="rodada"
                           class="@(Model.Modo == "rodada" ? "active" : "")">Por rodada</a>
                    }
                    else
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="fase"
                           class="@(Model.Modo == "fase" ? "active" : "")">Por fase</a>
                    }
                    @if (exibirPorGrupos)
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="grupo"
                           class="@(Model.Modo == "grupo" ? "active" : "")">
                            Por grupo
                        </a>
                    }
                </div>

                <div class="fp-tv-roundbar">
                    @if (!string.IsNullOrWhiteSpace(Model.FaseAnterior) && Model.Modo == "fase")
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="fase"
                           asp-route-faseSelecionada="@Model.FaseAnterior"
                           aria-label="Fase anterior">
                            ‹
                        </a>
                    }
                    else if (Model.RodadaAnterior.HasValue && Model.Modo == "rodada")
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="rodada"
                           asp-route-rodadaSelecionada="@Model.RodadaAnterior"
                           aria-label="Rodada anterior">
                            ‹
                        </a>
                    }
                    else
                    {
                        <span class="disabled">‹</span>
                    }

                    @if (Model.Modo == "data")
                    {
                        <form asp-action="Portal" method="get">
                            <input type="hidden" name="id" value="@Model.Campeonato.Id" />
                            <input type="hidden" name="aba" value="@Model.Aba" />
                            <input type="hidden" name="modo" value="data" />
                            <select name="dataSelecionada" class="form-select form-select-sm" onchange="this.form.submit()">
                                @if (!Model.Datas.Any())
                                {
                                    <option value="">Sem datas</option>
                                }
                                else
                                {
                                    @foreach (var d in Model.Datas)
                                    {
                                        var value = d.Data.ToString("yyyy-MM-dd");
                                        <option value="@value" selected="@(d.Selecionada)">@d.Data.ToString("dd/MM/yyyy") (@d.TotalJogos partidas)</option>
                                    }
                                }
                            </select>
                        </form>
                    }
                    else if (Model.Modo == "fase")
                    {
                        <form asp-action="Portal" method="get">
                            <input type="hidden" name="id" value="@Model.Campeonato.Id" />
                            <input type="hidden" name="aba" value="@Model.Aba" />
                            <input type="hidden" name="modo" value="fase" />
                            <select name="faseSelecionada" class="form-select form-select-sm" onchange="this.form.submit()">
                                @if (!Model.Fases.Any())
                                {
                                    <option value="">Sem fases</option>
                                }
                                else
                                {
                                    @foreach (var fase in Model.Fases)
                                    {
                                        <option value="@fase.Nome" selected="@fase.Selecionada">
                                            @fase.Nome (@fase.TotalJogos partidas)
                                        </option>
                                    }
                                }
                            </select>
                        </form>
                    }
                    else if (Model.Modo == "grupo")
                    {
                        <form asp-action="Portal" method="get">
                            <input type="hidden" name="id" value="@Model.Campeonato.Id" />
                            <input type="hidden" name="aba" value="@Model.Aba" />
                            <input type="hidden" name="modo" value="grupo" />
                            <select name="grupoSelecionado" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.GrupoSelecionado))">Todos os grupos</option>
                                @foreach (var grupo in gruposFiltro)
                                {
                                    <option value="@grupo" selected="@(string.Equals(ChaveGrupo(Model.GrupoSelecionado), grupo, StringComparison.OrdinalIgnoreCase))">
                                        @NomeGrupo(grupo)
                                    </option>
                                }
                            </select>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Portal" method="get">
                            <input type="hidden" name="id" value="@Model.Campeonato.Id" />
                            <input type="hidden" name="aba" value="@Model.Aba" />
                            <input type="hidden" name="modo" value="rodada" />
                            <select name="rodadaSelecionada" class="form-select form-select-sm" onchange="this.form.submit()">
                                @if (!Model.Rodadas.Any())
                                {
                                    <option value="">Sem rodadas</option>
                                }
                                else
                                {
                                    @foreach (var rodada in Model.Rodadas)
                                    {
                                        <option value="@rodada.Rodada" selected="@rodada.Selecionada">
                                            Rodada @rodada.Rodada
                                        </option>
                                    }
                                }
                            </select>
                        </form>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ProximaFase) && Model.Modo == "fase")
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="fase"
                           asp-route-faseSelecionada="@Model.ProximaFase"
                           aria-label="Próxima fase">
                            ›
                        </a>
                    }
                    else if (Model.ProximaRodada.HasValue && Model.Modo == "rodada")
                    {
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="@Model.Aba"
                           asp-route-modo="rodada"
                           asp-route-rodadaSelecionada="@Model.ProximaRodada"
                           aria-label="Próxima rodada">
                            ›
                        </a>
                    }
                    else
                    {
                        <span class="disabled">›</span>
                    }
                </div>

                @if (!Model.JogosDaRodada.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhuma partida encontrada para a seleção atual.
                    </div>
                }
                else
                {
                    <div class="fp-tv-fixture-list">
                        @foreach (var grupoDia in jogosPorDia)
                        {
                            <div class="fp-tv-date-row">@grupoDia.Key</div>

                            @foreach (var jogo in grupoDia)
                            {
                                var serieLabel = Model.SerieJogoLabels.TryGetValue(jogo.Id, out var label)
                                    ? label
                                    : null;

                                <a asp-controller="Jogos"
                                   asp-action="Details"
                                   asp-route-id="@jogo.Id"
                                   class="fp-tv-fixture-row">
                                    <span class="fp-tv-fixture-time">
                                        <b>@jogo.DataJogo.ToString("dd/MM")</b>
                                        <small>
                                            @(string.Equals(jogo.Status, "Finalizado", StringComparison.OrdinalIgnoreCase)
                                                ? "FT"
                                                : FormatarHorario(jogo.DataJogo))
                                        </small>
                                    </span>

                                    <span class="fp-tv-fixture-teams">
                                        @if (!string.IsNullOrWhiteSpace(serieLabel))
                                        {
                                            <small class="fp-tv-fixture-series">@serieLabel</small>
                                        }

                                        <span>
                                            <span class="fp-tv-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                                {
                                                    <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                                }
                                                else
                                                {
                                                    @Sigla(jogo.TimeCasa, "CAS")
                                                }
                                            </span>
                                            @jogo.TimeCasa?.Nome
                                        </span>

                                        <span>
                                            <span class="fp-tv-crest">
                                                @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                                {
                                                    <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                                }
                                                else
                                                {
                                                    @Sigla(jogo.TimeVisitante, "VIS")
                                                }
                                            </span>
                                            @jogo.TimeVisitante?.Nome
                                        </span>
                                    </span>

                                    <span class="fp-tv-fixture-score">
                                        @if (jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue)
                                        {
                                            <b>@jogo.GolsCasa</b>
                                            <b>@jogo.GolsVisitante</b>
                                        }
                                        else
                                        {
                                            <b>-</b>
                                            <b>-</b>
                                        }
                                    </span>
                                </a>
                            }
                        }
                    </div>
                }
            </section>
        </aside>

        <main class="fp-tv-main">
            @if (isPontosCorridos)
            {
                <section class="fp-tv-card fp-league-standings-panel">
                    <nav class="fp-tv-tabs compact">
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="classificacao"
                           class="@(Model.AbaClassificacaoAtiva || Model.AbaVisaoGeralAtiva ? "active" : "")">
                            Classificação
                        </a>

                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="estatisticas"
                           class="@(Model.AbaEstatisticasAtiva ? "active" : "")">
                            Estatísticas
                        </a>

                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="detalhes"
                           class="@(Model.AbaMidiaAtiva ? "active" : "")">
                            Detalhes
                        </a>
                    </nav>

                    @if (Model.AbaEstatisticasAtiva)
                    {
                        <div class="fp-tv-stats-grid">
                            <div>
                                <span>Jogos</span>
                                <strong>@Model.TotalJogos</strong>
                            </div>
                            <div>
                                <span>Finalizados</span>
                                <strong>@Model.TotalFinalizados</strong>
                            </div>
                            <div>
                                <span>Próximos</span>
                                <strong>@Model.TotalProximos</strong>
                            </div>
                            <div>
                                <span>Times</span>
                                <strong>@totalTimes</strong>
                            </div>
                        </div>
                    }                    
                    else
                    {
                        <div class="fp-standings-toolbar">
                            <div class="fp-tv-table-switch">
                                <span class="active">Todos</span>
                                <span>Casa</span>
                                <span>Fora</span>
                            </div>

                            @if (usuarioAdministrador)
                            {
                                <form asp-action="RecalcularClassificacao"
                                      asp-route-id="@Model.Campeonato.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="fp-admin-recalc-form">
                                    <button type="submit">Recalcular classificação</button>
                                </form>
                            }
                        </div>

                        @await Html.PartialAsync("_ClassificacaoTabela", new FutPlay.ViewModels.ClassificacaoTabelaViewModel
                        {
                            Classificacoes = Model.Classificacoes,
                            Grupos = Model.Grupos,
                            CampeonatoTimes = Model.CampeonatoTimes,
                            GruposPorTimeId = grupoPorTimeId,
                            UltimosResultadosPorTime = Model.UltimosResultadosPorTime,
                            AgruparPorGrupo = false,
                            EmptyMessage = "Nenhuma classificação disponível para esta competição."
                        })
                    }
                </section>
            }
            else
            {
                <section class="fp-tv-card fp-cup-panel">
                    <nav class="fp-tv-tabs compact">
                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="visao-geral"
                           asp-route-rodadaSelecionada="@Model.RodadaSelecionada"
                           class="@(Model.AbaVisaoGeralAtiva || Model.AbaJogosAtiva ? "active" : "")">
                            Visão geral
                        </a>

                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="classificacao"
                           class="@(Model.AbaClassificacaoAtiva ? "active" : "")">
                            Classificação
                        </a>

                        <a asp-action="Portal"
                           asp-route-id="@Model.Campeonato.Id"
                           asp-route-aba="fase-eliminatoria"
                           asp-route-modo="fase"
                           asp-route-faseSelecionada="@Model.FaseSelecionada"
                           class="@(Model.AbaFaseEliminatoriaAtiva ? "active" : "")">
                            Fase eliminatória
                        </a>
                       
                    </nav>

                    @if (Model.AbaClassificacaoAtiva)
                    {
                        @if (usuarioAdministrador)
                        {
                            <div class="fp-standings-toolbar">
                                <form asp-action="RecalcularClassificacao"
                                      asp-route-id="@Model.Campeonato.Id"
                                      method="post"
                                      asp-antiforgery="true"
                                      class="fp-admin-recalc-form">
                                    <button type="submit">Recalcular classificação</button>
                                </form>
                            </div>
                        }

                        @await Html.PartialAsync("_ClassificacaoTabela", new FutPlay.ViewModels.ClassificacaoTabelaViewModel
                        {
                            Classificacoes = Model.Classificacoes
                            .OrderBy(c => c.Posicao)
                            .ToList(),
                            Grupos = Model.Grupos,
                            CampeonatoTimes = Model.CampeonatoTimes,
                            GruposPorTimeId = grupoPorTimeId,
                            UltimosResultadosPorTime = Model.UltimosResultadosPorTime,
                            AgruparPorGrupo = true,
                            EmptyMessage = "Nenhuma classificação disponível para esta competição."
                        })
                    }
                    else if (Model.AbaFaseEliminatoriaAtiva)
                    {
                        var faseChaveamentoAtual = Model.ChaveamentoFases.FirstOrDefault(f => f.Selecionada)?.Nome
                            ?? Model.FaseSelecionada
                            ?? "Fase eliminatória";

                        <div class="fp-bracket-toolbar">
                            <span>&lt;/&gt;</span>
                            <b>@faseChaveamentoAtual</b>
                            @if (!string.IsNullOrWhiteSpace(Model.FaseAnterior))
                            {
                                <a asp-action="Portal"
                                   asp-route-id="@Model.Campeonato.Id"
                                   asp-route-aba="fase-eliminatoria"
                                   asp-route-modo="fase"
                                   asp-route-faseSelecionada="@Model.FaseAnterior"
                                   aria-label="Fase anterior">‹</a>
                            }
                            else
                            {
                                <span class="disabled">‹</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.ProximaFase))
                            {
                                <a asp-action="Portal"
                                   asp-route-id="@Model.Campeonato.Id"
                                   asp-route-aba="fase-eliminatoria"
                                   asp-route-modo="fase"
                                   asp-route-faseSelecionada="@Model.ProximaFase"
                                   aria-label="Próxima fase">›</a>
                            }
                            else
                            {
                                <span class="disabled">›</span>
                            }
                        </div>

                        @if (!Model.ChaveamentoFases.Any())
                        {
                            <div class="fp-stage-empty-card">
                                <div class="fp-stage-empty-icon" aria-hidden="true">&#127942;</div>
                                <div>
                                    <h2>Mata-mata em breve</h2>
                                    <p>A fase eliminatória aparecerá aqui quando os jogos de mata-mata forem cadastrados.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="fp-bracket-board">
                                @foreach (var fase in Model.ChaveamentoFases)
                                {
                                    var faseFinal = fase.Nome.Contains("Final", StringComparison.OrdinalIgnoreCase) &&
                                        !fase.Nome.Contains("Semi", StringComparison.OrdinalIgnoreCase);

                                    <section class="fp-bracket-stage @fase.PosicaoCss @(faseFinal ? "is-final" : "")">
                                        <h3>@fase.Nome</h3>

                                        @foreach (var serie in fase.Series)
                                        {
                                            var agregadoTimeA = serie.AgregadoTimeA.HasValue ? serie.AgregadoTimeA.Value.ToString() : "-";
                                            var agregadoTimeB = serie.AgregadoTimeB.HasValue ? serie.AgregadoTimeB.Value.ToString() : "-";

                                            <article class="fp-bracket-match fp-bracket-series @(serie.TemIdaVolta ? "has-two-legs" : "has-single-leg")"
                                                     data-team-ids="@($"{serie.TimeAId},{serie.TimeBId}")">
                                                <div class="fp-series-summary">
                                                    <span class="fp-bracket-team @(serie.ClassificadoTimeId == serie.TimeAId ? "qualified" : "")"
                                                          data-team-id="@serie.TimeAId"
                                                          tabindex="0">
                                                        <span class="fp-tv-crest">
                                                            @if (!string.IsNullOrWhiteSpace(serie.TimeAEscudoUrl))
                                                            {
                                                                <img src="@serie.TimeAEscudoUrl" alt="@serie.TimeANome" />
                                                            }
                                                            else
                                                            {
                                                                @serie.TimeASigla
                                                            }
                                                        </span>
                                                        <b>@serie.TimeANome</b>
                                                    </span>
                                                    <small>@agregadoTimeA</small>

                                                    <span class="fp-bracket-team @(serie.ClassificadoTimeId == serie.TimeBId ? "qualified" : "")"
                                                          data-team-id="@serie.TimeBId"
                                                          tabindex="0">
                                                        <span class="fp-tv-crest">
                                                            @if (!string.IsNullOrWhiteSpace(serie.TimeBEscudoUrl))
                                                            {
                                                                <img src="@serie.TimeBEscudoUrl" alt="@serie.TimeBNome" />
                                                            }
                                                            else
                                                            {
                                                                @serie.TimeBSigla
                                                            }
                                                        </span>
                                                        <b>@serie.TimeBNome</b>
                                                    </span>
                                                    <small>@agregadoTimeB</small>
                                                </div>

                                                <div class="fp-series-legs">
                                                    @foreach (var jogoSerie in serie.Jogos)
                                                    {
                                                        var placarJogo = jogoSerie.GolsMandante.HasValue && jogoSerie.GolsVisitante.HasValue
                                                            ? $"{jogoSerie.GolsMandante} x {jogoSerie.GolsVisitante}"
                                                            : "- x -";

                                                        <div class="fp-series-leg">
                                                            <span>@jogoSerie.Ordem <em>@jogoSerie.DataJogo.ToString("dd/MM")</em></span>
                                                            <b>@jogoSerie.MandanteNome</b>
                                                            <strong>@placarJogo</strong>
                                                            <b>@jogoSerie.VisitanteNome</b>
                                                        </div>
                                                    }
                                                </div>

                                                <span class="fp-series-status @(serie.ClassificadoTimeId.HasValue ? "qualified" : "")">
                                                    @serie.StatusSerie
                                                </span>
                                            </article>
                                        }
                                    </section>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="fp-cup-match-grid">
                            @foreach (var jogo in jogosDestaque)
                            {
                                <article class="fp-cup-match-card">
                                    <header>
                                        <span>@GrupoDoJogo(jogo), @rodadaTitulo</span>
                                        <small>@(string.IsNullOrWhiteSpace(jogo.Fase) ? "Sede a definir" : jogo.Fase)</small>
                                    </header>

                                    <div>
                                        <span class="fp-tv-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                @Sigla(jogo.TimeCasa, "CAS")
                                            }
                                        </span>

                                        <strong>@jogo.DataJogo.ToString("dd/MM/yyyy", CultureInfo.GetCultureInfo("pt-BR"))</strong>

                                        <span class="fp-tv-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                @Sigla(jogo.TimeVisitante, "VIS")
                                            }
                                        </span>
                                    </div>

                                    <footer>
                                        <b>@jogo.TimeCasa?.Nome</b>
                                        <span>@DiaAbreviado(jogo.DataJogo), @FormatarHorario(jogo.DataJogo)</span>
                                        <b>@jogo.TimeVisitante?.Nome</b>
                                    </footer>
                                </article>
                            }
                        </div>

                        <div class="fp-cup-summary-heading">
                            <h2>Classificação</h2>
                            <div class="fp-cup-summary-actions">
                                @if (usuarioAdministrador)
                                {
                                    <form asp-action="RecalcularClassificacao"
                                          asp-route-id="@Model.Campeonato.Id"
                                          method="post"
                                          asp-antiforgery="true"
                                          class="fp-admin-recalc-form">
                                        <button type="submit">Recalcular classificação</button>
                                    </form>
                                }

                                <a asp-action="Portal" asp-route-id="@Model.Campeonato.Id" asp-route-aba="classificacao">Visão completa</a>
                            </div>
                        </div>

                        @if (gruposAtivosVisaoGeral.Any())
                        {
                            <div class="fp-group-pill-row" aria-label="Grupos da classificação">
                                @foreach (var grupo in gruposAtivosVisaoGeral)
                                {
                                    var grupoAtivo = grupoVisaoGeralSelecionado != null && grupo.Id == grupoVisaoGeralSelecionado.Id;

                                    <a asp-action="Portal"
                                       asp-route-id="@Model.Campeonato.Id"
                                       asp-route-aba="visao-geral"
                                       asp-route-modo="@Model.Modo"
                                       asp-route-rodadaSelecionada="@Model.RodadaSelecionada"
                                       asp-route-grupoSelecionado="@grupo.Nome"
                                       class="@(grupoAtivo ? "active" : "")">
                                        @NomeGrupo(grupo.Nome)
                                    </a>
                                }
                            </div>
                        }

                        @await Html.PartialAsync("_ClassificacaoTabela", new FutPlay.ViewModels.ClassificacaoTabelaViewModel
                        {
                            Classificacoes = classificacoesGrupoVisaoGeral,
                            Grupos = grupoVisaoGeralSelecionado == null
                                ? new List<Grupo>()
                                : new List<Grupo> { grupoVisaoGeralSelecionado },
                            CampeonatoTimes = campeonatoTimesGrupoVisaoGeral,
                            GruposPorTimeId = grupoPorTimeId,
                            UltimosResultadosPorTime = Model.UltimosResultadosPorTime,
                            AgruparPorGrupo = true,
                            EmptyMessage = "Nenhuma classificação disponível para esta competição."
                        })
                    }
                </section>
            }
        </main>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            document.querySelectorAll('.fp-bracket-board').forEach((board) => {
                const matches = Array.from(board.querySelectorAll('.fp-bracket-match'));
                const teams = Array.from(board.querySelectorAll('.fp-bracket-team[data-team-id]'));

                const clearPath = () => {
                    board.classList.remove('is-hovering');
                    matches.forEach((match) => match.classList.remove('is-path', 'is-dimmed'));
                    teams.forEach((team) => team.classList.remove('selected'));
                };

                const highlightTeam = (teamId) => {
                    if (!teamId) {
                        clearPath();
                        return;
                    }

                    board.classList.add('is-hovering');

                    matches.forEach((match) => {
                        const teamIds = (match.dataset.teamIds || '').split(',').map((id) => id.trim());
                        const belongsToPath = teamIds.includes(teamId);
                        match.classList.toggle('is-path', belongsToPath);
                        match.classList.toggle('is-dimmed', !belongsToPath);
                    });

                    teams.forEach((team) => {
                        team.classList.toggle('selected', team.dataset.teamId === teamId);
                    });
                };

                teams.forEach((team) => {
                    team.addEventListener('mouseenter', () => highlightTeam(team.dataset.teamId));
                    team.addEventListener('focusin', () => highlightTeam(team.dataset.teamId));
                });

                board.addEventListener('mouseleave', clearPath);
                board.addEventListener('focusout', (event) => {
                    if (!board.contains(event.relatedTarget)) {
                        clearPath();
                    }
                });
            });
        })();
    </script>
}
