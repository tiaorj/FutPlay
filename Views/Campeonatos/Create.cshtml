@model FutPlay.Models.Campeonato

@{
    ViewData["Title"] = "Novo Campeonato";
}

<div class="container mt-4">
    <h1>Novo Campeonato</h1>

    <p class="text-muted">
        Cadastre um campeonato para ser usado no FutPlay.
    </p>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Copa do Mundo" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Ano" class="form-label"></label>
                    <input asp-for="Ano" class="form-control" placeholder="Ex: 2026" />
                    <span asp-validation-for="Ano" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label"></label>
                    <input asp-for="Tipo" class="form-control" placeholder="Ex: Mundial, Nacional, Estadual" />
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Formato" class="form-label"></label>
                    <select asp-for="Formato" class="form-select">
                        <option value="@CampeonatoFormato.PontosCorridos">Pontos corridos</option>
                        <option value="@CampeonatoFormato.GruposEMataMata">Grupos + mata-mata</option>
                    </select>
                    <span asp-validation-for="Formato" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DataInicio" class="form-label"></label>
                    <input asp-for="DataInicio" class="form-control" type="date" />
                    <span asp-validation-for="DataInicio" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DataFim" class="form-label"></label>
                    <input asp-for="DataFim" class="form-control" type="date" />
                    <span asp-validation-for="DataFim" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Salvar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
