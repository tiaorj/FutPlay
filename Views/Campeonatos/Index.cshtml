@model List<FutPlay.Models.Campeonato>

@{
    ViewData["Title"] = "Campeonatos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Campeonatos</h1>
            <p class="text-muted mb-0">
                Campeonatos disponíveis no FutPlay.
            </p>
        </div>

        <a href="#" class="btn btn-success">
            Novo Campeonato
        </a>
    </div>

    <div class="row">
        @foreach (var campeonato in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            @campeonato.Nome @campeonato.Ano
                        </h5>

                        <p class="card-text mb-1">
                            <strong>Tipo:</strong> @campeonato.Tipo
                        </p>

                        @if (campeonato.DataInicio.HasValue)
                        {
                            <p class="card-text mb-1">
                                <strong>Início:</strong> @campeonato.DataInicio.Value.ToString("dd/MM/yyyy")
                            </p>
                        }

                        @if (campeonato.DataFim.HasValue)
                        {
                            <p class="card-text mb-1">
                                <strong>Fim:</strong> @campeonato.DataFim.Value.ToString("dd/MM/yyyy")
                            </p>
                        }

                        <p class="card-text mt-2">
                            @if (campeonato.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </p>

                        <a href="#" class="btn btn-outline-primary btn-sm">
                            Ver detalhes
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>