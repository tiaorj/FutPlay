@model List<FutPlay.Models.Campeonato>

@{
    ViewData["Title"] = "Campeonatos";
}

<div class="container mt-4">
    <section class="futplay-page-hero mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="futplay-card-kicker">Portal público</div>
                <h1 class="futplay-page-title mb-1">Campeonatos</h1>
                <p class="futplay-subtitle mb-0">
                    Escolha um campeonato para acompanhar tabela, calendário, resultados e classificação.
                </p>
            </div>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <a asp-action="Create" class="btn btn-success">
                    Novo Campeonato
                </a>
            }
        </div>
    </section>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-warning border-0 shadow-sm">
            @TempData["Erro"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="futplay-empty">
            Nenhum campeonato cadastrado ainda.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var campeonato in Model)
            {
                <div class="col-xl-4 col-md-6 mb-3">
                    <article class="futplay-entity-card">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div class="d-flex align-items-start gap-3">
                                <span class="futplay-logo">
                                    @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                    {
                                        <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                    }
                                    else
                                    {
                                        <span>🏆</span>
                                    }
                                </span>

                                <div>
                                    <div class="futplay-card-kicker">@campeonato.Tipo</div>
                                    <h5 class="mb-1">@campeonato.Nome @campeonato.Ano</h5>

                                    @if (!string.IsNullOrWhiteSpace(campeonato.Pais))
                                    {
                                        <p class="text-muted small mb-0">@campeonato.Pais</p>
                                    }
                                </div>
                            </div>

                            @if (campeonato.Ativo)
                            {
                                <span class="futplay-status futplay-status-done">Ativo</span>
                            }
                            else
                            {
                                <span class="futplay-status futplay-status-locked">Inativo</span>
                            }
                        </div>

                        <div class="row g-2 mb-3 small">
                            <div class="col-6">
                                <span class="text-muted d-block">Início</span>
                                <strong>@(campeonato.DataInicio.HasValue ? campeonato.DataInicio.Value.ToString("dd/MM/yyyy") : "-")</strong>
                            </div>
                            <div class="col-6">
                                <span class="text-muted d-block">Fim</span>
                                <strong>@(campeonato.DataFim.HasValue ? campeonato.DataFim.Value.ToString("dd/MM/yyyy") : "-")</strong>
                            </div>
                        </div>

                        <div class="futplay-actions">
                            <a asp-action="Portal" asp-route-id="@campeonato.Id" class="btn btn-success btn-sm">
                                Portal
                            </a>

                            <a asp-action="Classificacao" asp-route-id="@campeonato.Id" class="btn btn-outline-dark btn-sm">
                                Classificação
                            </a>

                            <a asp-action="Details" asp-route-id="@campeonato.Id" class="btn btn-outline-primary btn-sm">
                                Detalhes
                            </a>

                            @if (User.IsInRole(AppRoles.Administrador))
                            {
                                <a asp-action="Edit" asp-route-id="@campeonato.Id" class="btn btn-outline-success btn-sm">
                                    Editar
                                </a>

                                @if (campeonato.Ativo)
                                {
                                    <a asp-action="Delete" asp-route-id="@campeonato.Id" class="btn btn-outline-warning btn-sm">
                                        Inativar
                                    </a>
                                }

                                @if (campeonato.ApiLeagueId.HasValue)
                                {
                                    <form asp-controller="Importacoes"
                                          asp-action="ImportarJogos"
                                          method="post">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-outline-dark btn-sm">
                                            Importar Jogos
                                        </button>
                                    </form>

                                    <form asp-controller="Importacoes"
                                          asp-action="AtualizarResultados"
                                          method="post">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                            Atualizar Resultados
                                        </button>
                                    </form>

                                    <form asp-controller="Importacoes"
                                          asp-action="SincronizarCampeonato"
                                          method="post">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-primary btn-sm">
                                            Sincronizar
                                        </button>
                                    </form>
                                }
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
