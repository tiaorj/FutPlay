@model List<FutPlay.Models.Campeonato>

@{
    ViewData["Title"] = "Campeonatos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Campeonatos</h1>
            <p class="text-muted mb-0">
                Campeonatos disponíveis no FutPlay.
            </p>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a asp-action="Create" class="btn btn-success">
                Novo Campeonato
            </a>
        }
    </div>
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Erro"]
        </div>
    }

    <div class="row">
        @foreach (var campeonato in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                        {
                            <img src="@campeonato.LogoUrl"
                                 alt="@campeonato.Nome"
                                 style="width: 42px; height: 42px; object-fit: contain;"
                                 class="mb-2" />
                        }
                        @if (!string.IsNullOrWhiteSpace(campeonato.Pais))
                        {
                            <p class="card-text mb-1">
                                <strong>País:</strong> @campeonato.Pais
                            </p>
                        }
                        <h5 class="card-title">
                            @campeonato.Nome @campeonato.Ano
                        </h5>

                        <p class="card-text mb-1">
                            <strong>Tipo:</strong> @campeonato.Tipo
                        </p>

                        @if (campeonato.DataInicio.HasValue)
                        {
                            <p class="card-text mb-1">
                                <strong>Início:</strong> @campeonato.DataInicio.Value.ToString("dd/MM/yyyy")
                            </p>
                        }

                        @if (campeonato.DataFim.HasValue)
                        {
                            <p class="card-text mb-1">
                                <strong>Fim:</strong> @campeonato.DataFim.Value.ToString("dd/MM/yyyy")
                            </p>
                        }

                        <p class="card-text mt-2">
                            @if (campeonato.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </p>
                        <a asp-action="Portal" asp-route-id="@campeonato.Id" class="btn btn-success btn-sm">
                            Portal
                        </a>

                        <div class="futplay-actions">
                            <a asp-action="Details" asp-route-id="@campeonato.Id" class="btn btn-outline-primary btn-sm">
                                Detalhes
                            </a>

                            <a asp-action="Classificacao" asp-route-id="@campeonato.Id" class="btn btn-outline-dark btn-sm">
                                Classificação
                            </a>

                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a asp-action="Edit" asp-route-id="@campeonato.Id" class="btn btn-outline-success btn-sm">
                                    Editar
                                </a>

                                @if (campeonato.Ativo)
                                {
                                    <a asp-action="Delete" asp-route-id="@campeonato.Id" class="btn btn-outline-warning btn-sm">
                                        Inativar
                                    </a>
                                }

                                @if (campeonato.ApiLeagueId.HasValue)
                                {
                                    <form asp-controller="Importacoes"
                                          asp-action="ImportarJogos"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-outline-dark btn-sm">
                                            Importar Jogos
                                        </button>
                                    </form>

                                    <form asp-controller="Importacoes"
                                          asp-action="AtualizarResultados"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                            Atualizar Resultados
                                        </button>
                                    </form>

                                    <form asp-controller="Importacoes"
                                          asp-action="SincronizarCampeonato"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />

                                        <button type="submit" class="btn btn-primary btn-sm">
                                            Sincronizar
                                        </button>
                                    </form>

                                }

                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>