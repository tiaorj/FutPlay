@model List<FutPlay.Models.Campeonato>

@{
    ViewData["Title"] = "Campeonatos";
    var principais = Model.Where(c => c.Ativo).Take(12).ToList();
    var grupos = Model
        .GroupBy(c => string.IsNullOrWhiteSpace(c.Pais) ? "Mundo" : c.Pais)
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="container futplay-portal-shell">
    <section class="futplay-competition-shell">
        <div class="futplay-competition-tabs">
            <span>Todos</span>
            <span>Favoritos</span>
            <strong>Competições</strong>
        </div>

        <div class="futplay-competition-head">
            <div>
                <h1>Competições</h1>
                <p>Escolha um campeonato para ver portal, tabela, jogos e resultados.</p>
            </div>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <a asp-action="Create" class="futplay-competition-admin-link">Novo campeonato</a>
            }
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success border-0">
                @TempData["Sucesso"]
            </div>
        }

        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-warning border-0">
                @TempData["Erro"]
            </div>
        }

        @if (!Model.Any())
        {
            <div class="futplay-section-empty">Nenhum campeonato cadastrado ainda.</div>
        }
        else
        {
            <section class="futplay-competition-featured">
                <h2>Principais competições</h2>

                <div class="futplay-competition-grid">
                    @foreach (var campeonato in principais)
                    {
                        <article class="futplay-competition-card">
                            <a asp-action="Portal"
                               asp-route-id="@campeonato.Id"
                               class="futplay-competition-card-link">
                                <span class="futplay-competition-logo">
                                    @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                    {
                                        <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                    }
                                    else
                                    {
                                        <span>FP</span>
                                    }
                                </span>
                                <strong>@campeonato.Nome</strong>
                            </a>

                            <span class="futplay-competition-favorite" aria-label="Favorito">☆</span>
                        </article>
                    }
                </div>
            </section>

            <section class="futplay-competition-groups">
                <h2>Ligas</h2>

                @for (int grupoIndex = 0; grupoIndex < grupos.Count; grupoIndex++)
                {
                    var grupo = grupos[grupoIndex];

                    <div class="futplay-competition-group">
                        <button type="button"
                                class="futplay-competition-group-button"
                                data-bs-toggle="collapse"
                                data-bs-target="#competicao-@grupoIndex"
                                aria-expanded="false">
                            <span class="futplay-competition-country">
                                <span class="futplay-competition-country-mark">@grupo.Key.Substring(0, 1).ToUpperInvariant()</span>
                                @grupo.Key
                            </span>
                            <span>@grupo.Count(c => c.Ativo)/@grupo.Count()</span>
                        </button>

                        <div class="collapse" id="competicao-@grupoIndex">
                            <div class="futplay-competition-group-list">
                                @foreach (var campeonato in grupo.OrderByDescending(c => c.Ativo).ThenByDescending(c => c.Ano).ThenBy(c => c.Nome))
                                {
                                    <article class="futplay-competition-row">
                                        <div class="futplay-competition-logo futplay-competition-logo-small">
                                            @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                            {
                                                <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                            }
                                            else
                                            {
                                                <span>FP</span>
                                            }
                                        </div>

                                        <div class="futplay-competition-row-body">
                                            <strong>@campeonato.Nome @campeonato.Ano</strong>
                                            <span>@campeonato.Tipo</span>
                                        </div>

                                        <div class="futplay-competition-row-actions">
                                            <a asp-action="Portal" asp-route-id="@campeonato.Id">Portal</a>
                                            <a asp-action="Classificacao" asp-route-id="@campeonato.Id">Tabela</a>
                                            <a asp-action="Details" asp-route-id="@campeonato.Id">Detalhes</a>

                                            @if (User.IsInRole(AppRoles.Administrador))
                                            {
                                                <a asp-action="Edit" asp-route-id="@campeonato.Id">Editar</a>

                                                @if (campeonato.Ativo)
                                                {
                                                    <a asp-action="Delete" asp-route-id="@campeonato.Id">Inativar</a>
                                                }

                                                @if (campeonato.ApiLeagueId.HasValue)
                                                {
                                                    <form asp-controller="Importacoes"
                                                          asp-action="ImportarJogos"
                                                          method="post">
                                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />
                                                        <button type="submit">Importar jogos</button>
                                                    </form>

                                                    <form asp-controller="Importacoes"
                                                          asp-action="AtualizarResultados"
                                                          method="post">
                                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />
                                                        <button type="submit">Atualizar</button>
                                                    </form>

                                                    <form asp-controller="Importacoes"
                                                          asp-action="SincronizarCampeonato"
                                                          method="post">
                                                        <input type="hidden" name="campeonatoId" value="@campeonato.Id" />
                                                        <button type="submit">Sincronizar</button>
                                                    </form>
                                                }
                                            }
                                        </div>
                                    </article>
                                }
                            </div>
                        </div>
                    </div>
                }
            </section>
        }
    </section>
</div>
