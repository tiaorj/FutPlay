@model FutPlay.ViewModels.CampeonatosIndexViewModel

@{
    ViewData["Title"] = "Campeonatos";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var competicoes = Model.Campeonatos
        .OrderByDescending(c => c.Ativo)
        .ThenByDescending(c => c.Ano)
        .ThenBy(c => c.Nome)
        .ToList();

    var grupos = competicoes
        .GroupBy(c => PaisExibicao.Normalizar(c.Pais))
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="container fp-score-home">

    <div class="fp-score-page-title d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>Escolha uma competição de @Model.Ano para ver jogos, classificação e resumo</span>

        @if (User.IsInRole(AppRoles.Administrador))
        {
            <a asp-action="Create" class="fp-score-admin-link">
                + Novo campeonato
            </a>
        }
    </div>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Total</span>
                        <strong>@Model.TotalCampeonatos</strong>
                    </div>

                    <div>
                        <span>Ativos</span>
                        <strong>@Model.TotalAtivos</strong>
                    </div>

                    <div>
                        <span>Favoritos</span>
                        <strong>@Model.TotalFavoritos</strong>
                    </div>

                    <div>
                        <span>Países</span>
                        <strong>@Model.TotalPaises</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Filtros</h2>
                </div>

                <div class="fp-score-filter-column">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="todos"
                       class="fp-score-filter @(Model.Filtro == "todos" ? "active" : "")">
                        Todos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="ativos"
                       class="fp-score-filter @(Model.Filtro == "ativos" ? "active" : "")">
                        Ativos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="favoritos"
                       class="fp-score-filter @(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos
                    </a>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>País e tipo</h2>
                </div>

                <form asp-action="Index" method="get" class="fp-compact-filter-form">
                    <input type="hidden" name="filtro" value="@Model.Filtro" />

                    <select class="form-select form-select-sm" name="ano" onchange="this.form.submit()">
                        @if (!Model.Anos.Any())
                        {
                            <option value="@Model.Ano" selected>@Model.Ano</option>
                        }
                        else
                        {
                            @foreach (var ano in Model.Anos)
                            {
                                <option value="@ano" selected="@(Model.Ano == ano)">
                                    @ano
                                </option>
                            }
                        }
                    </select>

                    <select class="form-select form-select-sm" name="pais" onchange="this.form.submit()">
                        <option value="">Todos os países</option>
                        @foreach (var pais in Model.Paises)
                        {
                            <option value="@pais" selected="@(string.Equals(Model.Pais, pais, StringComparison.OrdinalIgnoreCase))">
                                @pais
                            </option>
                        }
                    </select>

                    <select class="form-select form-select-sm" name="tipo" onchange="this.form.submit()">
                        <option value="">Todos os tipos</option>
                        @foreach (var tipo in Model.Tipos)
                        {
                            <option value="@tipo" selected="@(string.Equals(Model.Tipo, tipo, StringComparison.OrdinalIgnoreCase))">
                                @tipo
                            </option>
                        }
                    </select>

                    <button class="btn btn-sm btn-outline-primary" type="submit">Aplicar</button>
                </form>
            </section>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <section class="fp-home-card mt-3">
                    <div class="fp-card-header-link">
                        <h2>Admin</h2>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-action="Create" class="btn btn-success">
                            Novo campeonato
                        </a>

                        <a asp-controller="Importacoes"
                           asp-action="Index"
                           class="btn btn-outline-primary">
                            Importações
                        </a>
                    </div>
                </section>
            }
        </aside>

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="todos"
                       class="@(Model.Filtro == "todos" ? "active" : "")">
                        Todos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="ativos"
                       class="@(Model.Filtro == "ativos" ? "active" : "")">
                        Ativos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="favoritos"
                       class="@(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos
                    </a>

                    <a asp-controller="Jogos"
                       asp-action="Index"
                       asp-route-aba="competicoes">
                        Jogos
                    </a>
                </div>

                <div class="fp-score-filter-row">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="todos"
                       class="fp-score-filter @(Model.Filtro == "todos" ? "active" : "")">
                        Todos (@Model.TotalCampeonatos)
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="ativos"
                       class="fp-score-filter @(Model.Filtro == "ativos" ? "active" : "")">
                        Ativos (@Model.TotalAtivos)
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-tipo="@Model.Tipo"
                       asp-route-ano="@Model.Ano"
                       asp-route-filtro="favoritos"
                       class="fp-score-filter @(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos (@Model.TotalFavoritos)
                    </a>

                    <span class="fp-score-filter active">
                        @Model.Ano
                    </span>

                    @if (!string.IsNullOrWhiteSpace(Model.Pais))
                    {
                        <a asp-action="Index"
                           asp-route-tipo="@Model.Tipo"
                           asp-route-ano="@Model.Ano"
                           asp-route-filtro="@Model.Filtro"
                           class="fp-score-filter active">
                            @Model.Pais
                        </a>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Tipo))
                    {
                        <a asp-action="Index"
                           asp-route-pais="@Model.Pais"
                           asp-route-ano="@Model.Ano"
                           asp-route-filtro="@Model.Filtro"
                           class="fp-score-filter active">
                            @Model.Tipo
                        </a>
                    }
                </div>

                @if (Model.Filtro == "favoritos" && !Model.UsuarioAutenticado)
                {
                    <div class="fp-empty-mini m-3">
                        Entre na sua conta para ver e salvar campeonatos favoritos.
                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@returnUrl">
                            Fazer login
                        </a>
                    </div>
                }
                else if (!competicoes.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Nenhuma competição encontrada para estes filtros.
                    </div>
                }
                else
                {
                    <section class="fp-competition-feature-panel">
                        <div class="fp-match-list-title">
                            <span>Escolha uma competição</span>
                            <small>@competicoes.Count opção(ões)</small>
                        </div>

                        <div class="fp-competition-app-grid">
                            @foreach (var campeonato in competicoes)
                            {
                                var favorito = Model.CampeonatosFavoritosIds.Contains(campeonato.Id);
                                var paisCampeonato = PaisExibicao.Normalizar(campeonato.Pais);

                                <article class="fp-competition-app-card">
                                    <a asp-action="Portal"
                                       asp-route-id="@campeonato.Id"
                                       class="fp-competition-app-link">
                                        <span class="fp-competition-app-logo">
                                            @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                            {
                                                <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                            }
                                            else
                                            {
                                                <span>FP</span>
                                            }
                                        </span>

                                        <strong>@campeonato.Nome</strong>

                                        <span class="fp-competition-app-meta">
                                            <small>@campeonato.Ano</small>
                                            <small>@campeonato.Tipo</small>
                                            <small>@paisCampeonato</small>
                                        </span>

                                        <small class="fp-competition-app-format">@CampeonatoFormato.ObterDescricao(campeonato.Formato)</small>
                                        <span class="fp-competition-app-button">Ver competição</span>
                                    </a>

                                    <form asp-action="AlternarFavorito"
                                          method="post"
                                          class="fp-inline-favorite-form fp-competition-star">
                                        <input type="hidden" name="id" value="@campeonato.Id" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit"
                                                class="fp-favorite-button @(favorito ? "active" : "")"
                                                title="@(favorito ? "Remover dos favoritos" : "Adicionar aos favoritos")">
                                            @(favorito ? "★" : "☆")
                                        </button>
                                    </form>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="fp-competition-country-panel">
                        <div class="fp-match-list-title">
                            <span>Outras competições por país</span>
                            <small>@grupos.Count grupo(s)</small>
                        </div>

                        <div class="fp-competition-country-list">
                            @for (int grupoIndex = 0; grupoIndex < grupos.Count; grupoIndex++)
                            {
                                var grupo = grupos[grupoIndex];
                                var collapseId = $"competicao-pais-{grupoIndex}";

                                <div class="fp-competition-country-group">
                                    <button type="button"
                                            class="fp-competition-country-button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="@(grupoIndex == 0 ? "true" : "false")">
                                        <span>
                                            <b>@grupo.Key.Substring(0, 1).ToUpperInvariant()</b>
                                            @grupo.Key
                                        </span>

                                        <small>@grupo.Count(c => c.Ativo)/@grupo.Count()</small>
                                    </button>

                                    <div class="collapse @(grupoIndex == 0 ? "show" : "")" id="@collapseId">
                                        <div class="fp-competition-country-items">
                                            @foreach (var campeonato in grupo.OrderByDescending(c => c.Ativo).ThenByDescending(c => c.Ano).ThenBy(c => c.Nome))
                                            {
                                                var favorito = Model.CampeonatosFavoritosIds.Contains(campeonato.Id);
                                                var paisCampeonato = PaisExibicao.Normalizar(campeonato.Pais);

                                                <article class="fp-competition-row-app">
                                                    <div class="fp-competition-row-logo">
                                                        @if (!string.IsNullOrWhiteSpace(campeonato.LogoUrl))
                                                        {
                                                            <img src="@campeonato.LogoUrl" alt="@campeonato.Nome" />
                                                        }
                                                        else
                                                        {
                                                            <span>FP</span>
                                                        }
                                                    </div>

                                                    <div class="fp-competition-row-info">
                                                        <strong>@campeonato.Nome @campeonato.Ano</strong>
                                                        <span>
                                                            @campeonato.Tipo &middot; @paisCampeonato &middot; @CampeonatoFormato.ObterDescricao(campeonato.Formato)
                                                            @if (!campeonato.Ativo)
                                                            {
                                                                <span> &middot; Inativo</span>
                                                            }
                                                        </span>
                                                    </div>

                                                    <div class="fp-competition-row-actions-app">
                                                        <form asp-action="AlternarFavorito"
                                                              method="post"
                                                              class="fp-inline-favorite-form">
                                                            <input type="hidden" name="id" value="@campeonato.Id" />
                                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                            <button type="submit"
                                                                    class="fp-favorite-button @(favorito ? "active" : "")"
                                                                    title="@(favorito ? "Remover dos favoritos" : "Adicionar aos favoritos")">
                                                                @(favorito ? "★" : "☆")
                                                            </button>
                                                        </form>

                                                        <a asp-action="Portal" asp-route-id="@campeonato.Id">Ver competição</a>
                                                        <a asp-controller="Jogos"
                                                           asp-action="Index"
                                                           asp-route-aba="competicoes"
                                                           asp-route-campeonatoId="@campeonato.Id">
                                                            Jogos
                                                        </a>
                                                        <a asp-action="Portal"
                                                           asp-route-id="@campeonato.Id"
                                                           asp-route-aba="classificacao">
                                                            Classificação
                                                        </a>
                                                        <a asp-action="Details" asp-route-id="@campeonato.Id">Detalhes</a>

                                                        @if (User.IsInRole(AppRoles.Administrador))
                                                        {
                                                            <a asp-action="Edit" asp-route-id="@campeonato.Id">Editar</a>

                                                            @if (campeonato.Ativo)
                                                            {
                                                                <a asp-action="Delete" asp-route-id="@campeonato.Id">Inativar</a>
                                                            }
                                                        }
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>Meu Pitaco FC</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações rápidas</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="Jogos"
                       asp-action="Index"
                       asp-route-aba="competicoes"
                       class="btn btn-outline-primary">
                        Ver jogos
                    </a>

                    <a asp-controller="Times"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Ver times
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Index"
                       class="btn btn-success">
                        Ligas públicas
                    </a>
                </div>
            </section>
        </aside>

    </div>
</div>
