@model FutPlay.Models.Campeonato

@{
    ViewData["Title"] = "Detalhes do Campeonato";
}

<div class="container mt-4">
    <h1>Detalhes do Campeonato</h1>

    <p class="text-muted">
        Informações cadastradas para este campeonato.
    </p>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nome</dt>
                <dd class="col-sm-9">@Model.Nome</dd>

                <dt class="col-sm-3">Ano</dt>
                <dd class="col-sm-9">@Model.Ano</dd>

                <dt class="col-sm-3">Tipo</dt>
                <dd class="col-sm-9">@Model.Tipo</dd>

                <dt class="col-sm-3">Data de Início</dt>
                <dd class="col-sm-9">
                    @(Model.DataInicio.HasValue? Model.DataInicio.Value.ToString("dd/MM/yyyy") : "-")
                </dd>

                <dt class="col-sm-3">Data de Fim</dt>
                <dd class="col-sm-9">
                    @(Model.DataFim.HasValue? Model.DataFim.Value.ToString("dd/MM/yyyy") : "-")
                </dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.Ativo)
                    {
                        <span class="badge bg-success">Ativo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inativo</span>
                    }
                </dd>
            </dl>

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    Editar
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Voltar
                </a>
            </div>
        </div>
    </div>
</div>