@model FutPlay.ViewModels.ClassificacaoTabelaViewModel

@{
    string TituloGrupo(string? grupo)
    {
        if (string.IsNullOrWhiteSpace(grupo) || string.Equals(grupo, "Sem grupo", StringComparison.OrdinalIgnoreCase))
        {
            return "Classificação";
        }

        var texto = grupo.Trim();
        return texto.StartsWith("Grupo ", StringComparison.OrdinalIgnoreCase)
            ? texto
            : $"Grupo {texto}";
    }

    string OrdemGrupo(string? grupo)
    {
        var titulo = TituloGrupo(grupo);
        return string.Equals(titulo, "Classificação", StringComparison.OrdinalIgnoreCase)
            ? "ZZZ"
            : titulo;
    }

    Classificacao ObterLinhaClassificacao(
        CampeonatoTime campeonatoTime,
        Dictionary<int, Classificacao> classificacoesPorTime)
    {
        if (classificacoesPorTime.TryGetValue(campeonatoTime.TimeId, out var classificacao))
        {
            return classificacao;
        }

        return new Classificacao
        {
            CampeonatoId = campeonatoTime.CampeonatoId,
            TimeId = campeonatoTime.TimeId,
            Time = campeonatoTime.Time,
            Posicao = 0,
            Pontos = 0,
            Jogos = 0,
            Vitorias = 0,
            Empates = 0,
            Derrotas = 0,
            GolsPro = 0,
            GolsContra = 0,
            SaldoGols = 0,
            Ativo = true
        };
    }

    var classificacoes = Model.Classificacoes ?? new List<Classificacao>();
    var campeonatoTimes = Model.CampeonatoTimes ?? new List<CampeonatoTime>();
}

@if (!classificacoes.Any() &&
     (!Model.AgruparPorGrupo || !campeonatoTimes.Any()))
{
    <div class="fp-empty-mini">
        @Model.EmptyMessage
    </div>
}
else if (Model.AgruparPorGrupo)
{
    var classificacoesPorTime = classificacoes
        .GroupBy(c => c.TimeId)
        .ToDictionary(g => g.Key, g => g.First());

    var grupos = new List<(string Key, List<Classificacao> Linhas)>();

    if (campeonatoTimes.Any())
    {
        grupos = campeonatoTimes
            .Where(ct => ct.Ativo)
            .GroupBy(ct => string.IsNullOrWhiteSpace(ct.Grupo?.Nome) ? "Sem grupo" : ct.Grupo!.Nome.Trim())
            .Select(g => (
                Key: g.Key,
                Linhas: g
                    .Select(ct => ObterLinhaClassificacao(ct, classificacoesPorTime))
                    .OrderBy(c => c.Posicao <= 0 ? int.MaxValue : c.Posicao)
                    .ThenBy(c => c.Time?.Nome)
                    .ToList()))
            .OrderBy(g => OrdemGrupo(g.Key))
            .ToList();
    }
    else
    {
        grupos = classificacoes
            .GroupBy(c => Model.GruposPorTimeId.TryGetValue(c.TimeId, out var grupoTime) && !string.IsNullOrWhiteSpace(grupoTime)
                ? grupoTime.Trim()
                : "Sem grupo")
            .Select(g => (
                Key: g.Key,
                Linhas: g
                    .OrderBy(c => c.Posicao <= 0 ? int.MaxValue : c.Posicao)
                    .ThenBy(c => c.Time?.Nome)
                    .ToList()))
            .OrderBy(g => OrdemGrupo(g.Key))
            .ToList();
    }

    foreach (var grupo in grupos)
    {
        var grupoIndex = grupos.IndexOf(grupo);

        <div class="fp-standing-group" id="grupo-@grupoIndex">
            <div class="fp-standing-group-heading">
                <span>
                    <span class="fp-group-trophy" aria-hidden="true">&#127942;</span>
                    @TituloGrupo(grupo.Key)
                </span>
                <small>@grupo.Linhas.Count time(s)</small>
            </div>

            <div class="table-responsive">
                <table class="table fp-standing-table align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Time</th>
                            <th>J</th>
                            <th>V</th>
                            <th>E</th>
                            <th>D</th>
                            <th>SG</th>
                            <th>GP:GC</th>
                            <th>Últimos 5</th>
                            <th>PTS</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in grupo.Linhas)
                        {
                            var posicao = item.Posicao > 0 ? item.Posicao : grupo.Linhas.IndexOf(item) + 1;
                            var forma = Model.UltimosResultadosPorTime.TryGetValue(item.TimeId, out var resultados)
                                ? resultados
                                : new List<string>();

                            <tr>
                                <td>
                                    <span class="fp-standing-position">@posicao</span>
                                </td>

                                <td>
                                    <div class="fp-standing-team">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(item.Time?.EscudoUrl))
                                            {
                                                <img src="@item.Time.EscudoUrl" alt="@item.Time.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(item.Time?.Sigla ?? "FC")</span>
                                            }
                                        </span>

                                        <strong>@item.Time?.Nome</strong>
                                    </div>
                                </td>

                                <td>@item.Jogos</td>
                                <td>@item.Vitorias</td>
                                <td>@item.Empates</td>
                                <td>@item.Derrotas</td>
                                <td>@item.SaldoGols</td>
                                <td>@item.GolsPro:@item.GolsContra</td>

                                <td>
                                    <div class="fp-form-dots">
                                        @foreach (var resultado in forma)
                                        {
                                            var dotClass = resultado == "V"
                                                ? "win"
                                                : resultado == "E" ? "draw" : "loss";

                                            <span class="fp-form-dot @dotClass" title="@resultado"></span>
                                        }

                                        @for (int i = forma.Count; i < 5; i++)
                                        {
                                            <span class="fp-form-dot empty"></span>
                                        }
                                    </div>
                                </td>

                                <td class="fp-standing-points">@item.Pontos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <div class="table-responsive">
        <table class="table fp-standing-table align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Time</th>
                    <th>J</th>
                    <th>V</th>
                    <th>E</th>
                    <th>D</th>
                    <th>SG</th>
                    <th>GP:GC</th>
                    <th>Últimos 5</th>
                    <th>PTS</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in classificacoes.OrderBy(c => c.Posicao))
                {
                    var forma = Model.UltimosResultadosPorTime.TryGetValue(item.TimeId, out var resultados)
                        ? resultados
                        : new List<string>();

                    <tr>
                        <td>
                            <span class="fp-standing-position">@item.Posicao</span>
                        </td>

                        <td>
                            <div class="fp-standing-team">
                                <span class="fp-mini-crest">
                                    @if (!string.IsNullOrWhiteSpace(item.Time?.EscudoUrl))
                                    {
                                        <img src="@item.Time.EscudoUrl" alt="@item.Time.Nome" />
                                    }
                                    else
                                    {
                                        <span>@(item.Time?.Sigla ?? "FC")</span>
                                    }
                                </span>

                                <strong>@item.Time?.Nome</strong>
                            </div>
                        </td>

                        <td>@item.Jogos</td>
                        <td>@item.Vitorias</td>
                        <td>@item.Empates</td>
                        <td>@item.Derrotas</td>
                        <td>@item.SaldoGols</td>
                        <td>@item.GolsPro:@item.GolsContra</td>

                        <td>
                            <div class="fp-form-dots">
                                @foreach (var resultado in forma)
                                {
                                    var dotClass = resultado == "V"
                                        ? "win"
                                        : resultado == "E" ? "draw" : "loss";

                                    <span class="fp-form-dot @dotClass" title="@resultado"></span>
                                }

                                @for (int i = forma.Count; i < 5; i++)
                                {
                                    <span class="fp-form-dot empty"></span>
                                }
                            </div>
                        </td>

                        <td class="fp-standing-points">@item.Pontos</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
