@model FutPlay.ViewModels.ClassificacaoCampeonatoViewModel

@{
    ViewData["Title"] = "Classificação";
}

<div class="container futplay-portal-shell">
    <section class="futplay-portal-header mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="futplay-portal-logo futplay-portal-logo-large">
                    @if (!string.IsNullOrWhiteSpace(Model.Campeonato.LogoUrl))
                    {
                        <img src="@Model.Campeonato.LogoUrl" alt="@Model.Campeonato.Nome" />
                    }
                    else
                    {
                        <span>FP</span>
                    }
                </div>

                <div>
                    <div class="futplay-portal-kicker">Classificação</div>
                    <h1 class="futplay-portal-title">@Model.Campeonato.Nome @Model.Campeonato.Ano</h1>
                    <p class="futplay-portal-lead mb-0">Tabela completa do campeonato.</p>
                </div>
            </div>

            <div class="futplay-portal-actions">
                @if (User.IsInRole(AppRoles.Administrador))
                {
                    <a asp-action="RecalcularClassificacao" asp-route-id="@Model.Campeonato.Id">Recalcular</a>
                }
                <a asp-action="Portal" asp-route-id="@Model.Campeonato.Id">Portal</a>
                <a asp-action="Index">Competições</a>
            </div>
        </div>
    </section>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <section class="futplay-standings-card">
        <div class="futplay-standings-head">
            <h2>TABELA</h2>
        </div>

        @if (!Model.Classificacoes.Any())
        {
            <div class="futplay-section-empty">Nenhuma classificação cadastrada para este campeonato ainda.</div>
        }
        else
        {
            var grupos = Model.Classificacoes
                .GroupBy(c => string.IsNullOrWhiteSpace(c.Grupo) ? "Classificação" : $"Grupo {c.Grupo}")
                .ToList();

            foreach (var grupo in grupos)
            {
                <div class="futplay-standings-group">
                    <div class="futplay-standings-group-title">@grupo.Key.ToUpperInvariant()</div>

                    <div class="table-responsive">
                        <table class="table futplay-standings-table align-middle">
                            <thead>
                                <tr>
                                    <th class="futplay-standings-club-head">Classificação</th>
                                    <th>P</th>
                                    <th>J</th>
                                    <th>V</th>
                                    <th>E</th>
                                    <th>D</th>
                                    <th>GP</th>
                                    <th>GC</th>
                                    <th>SG</th>
                                    <th>%</th>
                                    <th>Últ. jogos</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in grupo)
                                {
                                    var aproveitamento = item.Jogos > 0
                                        ? Math.Round((double)item.Pontos / (item.Jogos * 3) * 100)
                                        : 0;
                                    var forma = Model.UltimosResultadosPorTime.TryGetValue(item.TimeId, out var resultados)
                                        ? resultados
                                        : new List<string>();

                                    <tr>
                                        <td class="futplay-standings-club">
                                            <span class="futplay-standings-position">@item.Posicao</span>
                                            <span class="futplay-table-crest">
                                                @if (!string.IsNullOrWhiteSpace(item.Time?.EscudoUrl))
                                                {
                                                    <img src="@item.Time.EscudoUrl" alt="@item.Time.Nome" />
                                                }
                                                else
                                                {
                                                    <span>@(item.Time?.Sigla ?? "FC")</span>
                                                }
                                            </span>
                                            <strong>@item.Time?.Nome</strong>
                                        </td>
                                        <td class="futplay-standings-points">@item.Pontos</td>
                                        <td>@item.Jogos</td>
                                        <td>@item.Vitorias</td>
                                        <td>@item.Empates</td>
                                        <td>@item.Derrotas</td>
                                        <td>@item.GolsPro</td>
                                        <td>@item.GolsContra</td>
                                        <td>@item.SaldoGols</td>
                                        <td>@aproveitamento.ToString("0")</td>
                                        <td>
                                            <div class="futplay-form-dots">
                                                @foreach (var resultado in forma)
                                                {
                                                    var dotClass = resultado == "V"
                                                        ? "futplay-form-win"
                                                        : resultado == "E" ? "futplay-form-draw" : "futplay-form-loss";

                                                    <span class="futplay-form-dot @dotClass" title="@resultado"></span>
                                                }
                                                @for (int i = forma.Count; i < 5; i++)
                                                {
                                                    <span class="futplay-form-dot futplay-form-empty"></span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </section>
</div>
