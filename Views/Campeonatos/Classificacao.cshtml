@model FutPlay.ViewModels.ClassificacaoCampeonatoViewModel

@{
    ViewData["Title"] = "Classificação";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Classificação</h1>
            <p class="futplay-subtitle mb-0">
                @Model.Campeonato.Nome @Model.Campeonato.Ano
            </p>
        </div>

        <div class="mt-3 mt-md-0 futplay-actions">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-action="RecalcularClassificacao"
                   asp-route-id="@Model.Campeonato.Id"
                   class="btn btn-success">
                    Recalcular Classificação
                </a>
            }

            <a asp-action="Index" class="btn btn-outline-secondary">
                Voltar
            </a>
        </div>
    </div>
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    @if (!Model.Classificacoes.Any())
    {
        <div class="futplay-empty">
            Nenhuma classificação cadastrada para este campeonato ainda.
        </div>
    }
    else
    {
        var grupos = Model.Classificacoes
        .GroupBy(c => string.IsNullOrWhiteSpace(c.Grupo) ? "Classificação Geral" : $"Grupo {c.Grupo}")
        .ToList();

        foreach (var grupo in grupos)
        {
            <div class="card shadow-sm futplay-section-card mb-4">
                <div class="card-header bg-white">
                    <strong>@grupo.Key</strong>
                </div>

                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Pos</th>
                                <th>Time</th>
                                <th>Pts</th>
                                <th>J</th>
                                <th>V</th>
                                <th>E</th>
                                <th>D</th>
                                <th>GP</th>
                                <th>GC</th>
                                <th>SG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in grupo)
                            {
                                <tr>
                                    <td>
                                        <strong>@(item.Posicao)º</strong>
                                    </td>
                                    <td>
                                        <strong>@item.Time?.Nome</strong>
                                        @if (!string.IsNullOrWhiteSpace(item.Time?.Sigla))
                                        {
                                            <small class="text-muted">(@item.Time.Sigla)</small>
                                        }
                                    </td>
                                    <td><strong>@item.Pontos</strong></td>
                                    <td>@item.Jogos</td>
                                    <td>@item.Vitorias</td>
                                    <td>@item.Empates</td>
                                    <td>@item.Derrotas</td>
                                    <td>@item.GolsPro</td>
                                    <td>@item.GolsContra</td>
                                    <td>@item.SaldoGols</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>