@model List<FutPlay.ViewModels.ApiLigaViewModel>
@using FutPlay.Settings
@{
    ViewData["Title"] = "Importações";
    var campeonatos = ViewBag.Campeonatos as List<Campeonato> ?? new List<Campeonato>();
    var footballDataOrgCompeticoes = ViewBag.FootballDataOrgCompeticoes as List<FutPlay.ViewModels.FootballDataOrgCompeticaoViewModel> ?? new List<FutPlay.ViewModels.FootballDataOrgCompeticaoViewModel>();

    string DataFootballData(DateTime? data)
    {
        return data.HasValue
            ? data.Value.ToString("yyyy-MM-dd")
            : "-";
    }
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="futplay-page-title mb-1">Importações</h1>
            <p class="futplay-subtitle mb-0">
                Integrações administrativas para trazer campeonatos, jogos, resultados e validar a saúde das APIs.
            </p>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-action="Historico" class="btn btn-outline-secondary">
                Histórico de sincronizações
            </a>
        </div>
    </div>

    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Erro
        </div>
    }

    @if (ViewBag.TotalEncontrado != null)
    {
        <div class="alert alert-secondary">
            Total encontrado na API: @ViewBag.TotalEncontrado
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-lg-4">
            <section class="card shadow-sm futplay-section-card h-100">
                <div class="card-header bg-white">
                    <strong>API-Football principal</strong>
                </div>

                <div class="card-body d-flex flex-column gap-3">
                    <p class="text-muted mb-0">
                        Valide autenticação, disponibilidade e consumo diário antes de importar campeonatos ou jogos.
                    </p>

                    <form asp-action="TestarApiFootball" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100">
                            Testar conexão
                        </button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="card shadow-sm futplay-section-card h-100">
                <div class="card-header bg-white">
                    <strong>Histórico e auditoria</strong>
                </div>

                <div class="card-body d-flex flex-column gap-3">
                    <p class="text-muted mb-0">
                        Consulte sucessos, falhas, sincronizações parciais e quantidade de registros alterados.
                    </p>

                    <a asp-action="Historico" class="btn btn-outline-secondary w-100">
                        Abrir histórico
                    </a>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="card shadow-sm futplay-section-card h-100">
                <div class="card-header bg-white">
                    <strong>Ambiente de testes</strong>
                </div>

                <div class="card-body d-flex flex-column gap-3">
                    <p class="text-muted mb-0">
                        Gere e limpe dados mockados para testar portal, classificação, ligas e rankings sem gastar chamadas da API.
                    </p>

                    <a asp-controller="MockData" asp-action="Index" class="btn btn-warning w-100">
                        Administrar dados de teste
                    </a>
                </div>
            </section>
        </div>
    </div>

    <div class="card shadow-sm futplay-section-card mb-4">
        <div class="card-header bg-white d-flex flex-column flex-md-row justify-content-between gap-2">
            <strong>football-data.org (fonte auxiliar gratuita)</strong>

            <form asp-action="ListarFootballDataOrgCompeticoes" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    Listar competições disponíveis
                </button>
            </form>
        </div>

        <div class="card-body">
            <p class="text-muted">
                Use esta integração somente por ação do Admin. Ela atualiza jogos existentes por FootballDataMatchId,
                sem substituir a API-Football e sem chamar APIs em telas públicas.
            </p>
            <p class="text-muted small">
                Campos salvos no campeonato local: <strong>ID</strong> vira FootballDataCompetitionId,
                <strong>Código</strong> vira FootballDataCompetitionCode e <strong>Temporada</strong> vira FootballDataSeason.
                O ApiLeagueId da API-Football não é usado aqui.
            </p>

            <form asp-action="AtualizarResultadosFootballDataOrg" method="post" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()

                <div class="col-lg-4">
                    <label class="form-label">Campeonato local</label>
                    <select name="campeonatoId" class="form-select" required>
                        <option value="">Selecione...</option>
                        @foreach (var campeonato in campeonatos)
                        {
                            <option value="@campeonato.Id">
                                @campeonato.Nome @campeonato.Ano
                                @if (campeonato.FootballDataCompetitionId.HasValue)
                                {
                                    <text> - FD #@campeonato.FootballDataCompetitionId</text>
                                    @if (!string.IsNullOrWhiteSpace(campeonato.FootballDataCompetitionCode))
                                    {
                                        <text>/@campeonato.FootballDataCompetitionCode</text>
                                    }
                                    @if (campeonato.FootballDataSeason.HasValue)
                                    {
                                        <text> @campeonato.FootballDataSeason</text>
                                    }
                                }
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3 col-lg-2">
                    <label class="form-label">Competition ID</label>
                    <input name="footballDataCompetitionId"
                           type="number"
                           class="form-control"
                           placeholder="Ex: 2021"
                           min="1" />
                </div>

                <div class="col-md-3 col-lg-2">
                    <label class="form-label">Código</label>
                    <input name="competitionCode"
                           class="form-control text-uppercase"
                           placeholder="Ex: PL, CL, WC" />
                </div>

                <div class="col-md-3 col-lg-2">
                    <label class="form-label">Temporada</label>
                    <input name="temporada"
                           type="number"
                           class="form-control"
                           placeholder="@DateTime.Now.Year"
                           min="2000"
                           max="2100" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <button type="submit" class="btn btn-success w-100">
                        Atualizar resultados
                    </button>
                </div>
            </form>

            <small class="text-muted d-block mt-3">
                Use o ID listado pela própria football-data.org. Não use o ID da API-Football nessa integração.
            </small>

            @if (campeonatos.Any())
            {
                <div class="table-responsive mt-4">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Campeonato local</th>
                                <th>Vínculo football-data.org</th>
                                <th>ID salvo</th>
                                <th>Code salvo</th>
                                <th>Season salva</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var campeonato in campeonatos)
                            {
                                var vinculado = campeonato.FootballDataCompetitionId.HasValue ||
                                    !string.IsNullOrWhiteSpace(campeonato.FootballDataCompetitionCode);

                                <tr>
                                    <td>@campeonato.Nome @campeonato.Ano</td>
                                    <td>
                                        @if (vinculado)
                                        {
                                            <span class="badge bg-success">Vinculado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Não vinculado</span>
                                        }
                                    </td>
                                    <td>@(campeonato.FootballDataCompetitionId?.ToString() ?? "-")</td>
                                    <td>@(string.IsNullOrWhiteSpace(campeonato.FootballDataCompetitionCode) ? "-" : campeonato.FootballDataCompetitionCode)</td>
                                    <td>@(campeonato.FootballDataSeason?.ToString() ?? "-")</td>
                                    <td class="text-end">
                                        @if (vinculado)
                                        {
                                            <form asp-action="TestarFootballDataOrgCompeticao" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="campeonatoId" value="@campeonato.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    Testar acesso
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (footballDataOrgCompeticoes.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Logo</th>
                            <th>ID</th>
                            <th>Código</th>
                            <th>Competição</th>
                            <th>País</th>
                            <th>Tipo</th>
                            <th>Plan</th>
                            <th>currentSeason/startDate</th>
                            <th>currentSeason/endDate</th>
                            <th>currentSeason/currentMatchday</th>
                            <th>Temporada atual</th>
                            <th>Vincular campeonato local</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var competicao in footballDataOrgCompeticoes)
                        {
                            var temporadaVinculo = competicao.TemporadaAtual ?? DateTime.Now.Year;
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(competicao.EmblemaUrl))
                                    {
                                        <img src="@competicao.EmblemaUrl" alt="@competicao.Nome" style="width: 32px; height: 32px; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td><strong>@competicao.Id</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(competicao.Codigo) ? "-" : competicao.Codigo)</td>
                                <td>@competicao.Nome</td>
                                <td>@competicao.Pais</td>
                                <td>@competicao.Tipo</td>
                                <td>@(string.IsNullOrWhiteSpace(competicao.Plano) ? "-" : competicao.Plano)</td>
                                <td>@DataFootballData(competicao.TemporadaAtualInicio)</td>
                                <td>@DataFootballData(competicao.TemporadaAtualFim)</td>
                                <td>@(competicao.RodadaAtual?.ToString() ?? "-")</td>
                                <td>@(competicao.TemporadaAtual.HasValue ? competicao.TemporadaAtual.Value.ToString() : "-")</td>
                                <td>
                                    <form asp-action="VincularFootballDataOrgCompeticao" method="post" class="d-flex flex-column flex-xl-row gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="footballDataCompetitionId" value="@competicao.Id" />
                                        <input type="hidden" name="competitionCode" value="@competicao.Codigo" />

                                        <select name="campeonatoId" class="form-select form-select-sm" required>
                                            <option value="">Campeonato local...</option>
                                            @foreach (var campeonato in campeonatos)
                                            {
                                                var jaVinculado = campeonato.FootballDataCompetitionId == competicao.Id;
                                                <option value="@campeonato.Id" selected="@jaVinculado">
                                                    @campeonato.Nome @campeonato.Ano
                                                </option>
                                            }
                                        </select>

                                        <input name="temporada"
                                               type="number"
                                               class="form-control form-control-sm"
                                               min="1900"
                                               max="2100"
                                               value="@temporadaVinculo"
                                               title="FootballDataSeason a salvar" />

                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Vincular
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card shadow-sm futplay-section-card mb-4">
        <div class="card-header bg-white">
            <strong>Buscar ligas/campeonatos na API-Football</strong>
        </div>

        <div class="card-body">
            <form asp-action="BuscarLigas" method="post">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">País</label>
                        <input name="pais" class="form-control" value="@(ViewBag.Pais ?? "Brazil")" />
                        <small class="text-muted">
                            Exemplos: Brazil, England, Spain, Germany, World
                        </small>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Temporada</label>
                        <input name="temporada" class="form-control" value="@(ViewBag.Temporada ?? DateTime.Now.Year)" />
                    </div>

                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100">
                            Buscar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm futplay-section-card">
            <div class="card-header bg-white">
                <strong>Campeonatos encontrados</strong>
            </div>

            <div class="card-body table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Logo</th>
                            <th>ID API</th>
                            <th>Nome</th>
                            <th>País</th>
                            <th>Tipo</th>
                            <th>Temporada</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var liga in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(liga.LogoUrl))
                                    {
                                        <img src="@liga.LogoUrl" alt="@liga.Nome" style="width: 36px; height: 36px; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>@liga.ApiLeagueId</td>
                                <td>
                                    <strong>@liga.Nome</strong>
                                </td>
                                <td>@liga.Pais</td>
                                <td>@liga.Tipo</td>
                                <td>@liga.Temporada</td>
                                <td>
                                    @if (liga.JaImportado)
                                    {
                                        <span class="badge bg-success">Importado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Novo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (!liga.JaImportado)
                                    {
                                        <form asp-action="ImportarLiga" method="post">
                                            <input type="hidden" name="apiLeagueId" value="@liga.ApiLeagueId" />
                                            <input type="hidden" name="nome" value="@liga.Nome" />
                                            <input type="hidden" name="tipo" value="@liga.Tipo" />
                                            <input type="hidden" name="pais" value="@liga.Pais" />
                                            <input type="hidden" name="temporada" value="@liga.Temporada" />
                                            <input type="hidden" name="logoUrl" value="@liga.LogoUrl" />

                                            <button type="submit" class="btn btn-sm btn-success">
                                                Importar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="AtualizarLiga" method="post">
                                            <input type="hidden" name="apiLeagueId" value="@liga.ApiLeagueId" />
                                            <input type="hidden" name="nome" value="@liga.Nome" />
                                            <input type="hidden" name="tipo" value="@liga.Tipo" />
                                            <input type="hidden" name="pais" value="@liga.Pais" />
                                            <input type="hidden" name="temporada" value="@liga.Temporada" />
                                            <input type="hidden" name="logoUrl" value="@liga.LogoUrl" />

                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                Atualizar dados
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (ViewBag.Pais != null)
    {
        <div class="alert alert-info">
            Nenhum campeonato encontrado para a busca informada.
        </div>
    }
</div>
