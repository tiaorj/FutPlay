@model FutPlay.Models.LigaParticipante

@{
    ViewData["Title"] = "Detalhes do Participante";
}

<div class="container futplay-portal-shell">
    <section class="futplay-detail-match">
        <div class="futplay-detail-scoreboard futplay-detail-scoreboard-single">
            <div class="futplay-detail-team">
                <span class="futplay-detail-crest futplay-detail-crest-large">
                    <span>@Model.Nome.Substring(0, Math.Min(2, Model.Nome.Length)).ToUpperInvariant()</span>
                </span>
                <h1>@Model.Nome</h1>
                <p>@Model.Liga?.Nome</p>
            </div>
        </div>
    </section>

    <section class="futplay-detail-grid mt-4">
        <article class="futplay-detail-panel">
            <h2>Resumo no Meu Pitaco</h2>
            <dl>
                <dt>E-mail</dt>
                <dd>@Model.Email</dd>
                <dt>Data de entrada</dt>
                <dd>@Model.DataEntrada.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt>Pontuação</dt>
                <dd>@Model.PontuacaoTotal pontos</dd>
                <dt>Status</dt>
                <dd>@(Model.Ativo ? "Ativo" : "Inativo")</dd>
            </dl>
        </article>

        <article class="futplay-detail-panel">
            <h2>Ações</h2>
            <div class="futplay-detail-actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="futplay-detail-primary">Editar cadastro</a>
                <a asp-action="Index">Voltar</a>
            </div>
        </article>
    </section>
</div>
