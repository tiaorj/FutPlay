@model List<FutPlay.Models.LigaParticipante>

@{
    ViewData["Title"] = User.IsInRole(AppRoles.Administrador) ? "Participantes" : "Meu Cadastro";
}

<div class="container futplay-portal-shell">
    <section class="futplay-portal-header mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <div class="futplay-portal-kicker">Bolão por usuário</div>
                <h1 class="futplay-portal-title">@ViewData["Title"]</h1>
                <p class="futplay-portal-lead mb-0">
                    @if (User.IsInRole(AppRoles.Administrador))
                    {
                        <span>Participantes cadastrados nas ligas do FutPlay.</span>
                    }
                    else
                    {
                        <span>Seus vínculos de participante nas ligas do FutPlay.</span>
                    }
                </p>
            </div>

            <div class="futplay-portal-actions">
                <a asp-action="Create">Novo participante</a>
            </div>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="futplay-league-empty">
            <div class="futplay-league-empty-mark">FP</div>
            <h2>Nenhum vínculo encontrado</h2>
            <p>Entre em uma liga para seus dados de participante aparecerem aqui.</p>
        </div>
    }
    else
    {
        <section class="futplay-league-panel">
            <div class="futplay-league-panel-head">
                <h2>Participantes</h2>
                <span>@Model.Count registros</span>
            </div>

            <div class="futplay-league-rows">
                @foreach (var participante in Model)
                {
                    <article class="futplay-league-row">
                        <div class="futplay-detail-crest">
                            <span>@participante.Nome.Substring(0, Math.Min(2, participante.Nome.Length)).ToUpperInvariant()</span>
                        </div>

                        <div class="futplay-league-row-info">
                            <span>@participante.Email</span>
                            <h3>@participante.Nome</h3>
                            <p>@participante.Liga?.Nome</p>
                        </div>

                        <div class="futplay-league-row-points">
                            <span>Pontos</span>
                            <strong>@participante.PontuacaoTotal</strong>
                        </div>

                        <div class="futplay-league-actions">
                            <a asp-action="Details"
                               asp-route-id="@participante.Id"
                               class="futplay-league-action-secondary">
                                Detalhes
                            </a>
                            <a asp-action="Edit"
                               asp-route-id="@participante.Id"
                               class="futplay-league-action-secondary">
                                Editar
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>
