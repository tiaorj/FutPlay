@model FutPlay.Models.Palpite

@{
    ViewData["Title"] = "Detalhes do Palpite";
}

<div class="container futplay-portal-shell">
    <section class="futplay-detail-match">
        <div class="futplay-detail-match-meta">
            <span>@Model.Liga?.Nome</span>
            <strong>@Model.DataPalpite.ToString("dd/MM/yyyy HH:mm")</strong>
            <span>@Model.LigaParticipante?.Nome</span>
        </div>

        <div class="futplay-detail-scoreboard">
            <div class="futplay-detail-team">
                <span class="futplay-detail-crest">
                    @if (!string.IsNullOrWhiteSpace(Model.Jogo?.TimeCasa?.EscudoUrl))
                    {
                        <img src="@Model.Jogo.TimeCasa.EscudoUrl" alt="@Model.Jogo.TimeCasa.Nome" />
                    }
                    else
                    {
                        <span>@(Model.Jogo?.TimeCasa?.Sigla ?? "CAS")</span>
                    }
                </span>
                <h1>@Model.Jogo?.TimeCasa?.Nome</h1>
            </div>

            <div class="futplay-detail-score">
                <strong>@Model.GolsCasaPalpite x @Model.GolsVisitantePalpite</strong>
                <span>@Model.PontosGanhos pontos</span>
            </div>

            <div class="futplay-detail-team futplay-detail-team-away">
                <span class="futplay-detail-crest">
                    @if (!string.IsNullOrWhiteSpace(Model.Jogo?.TimeVisitante?.EscudoUrl))
                    {
                        <img src="@Model.Jogo.TimeVisitante.EscudoUrl" alt="@Model.Jogo.TimeVisitante.Nome" />
                    }
                    else
                    {
                        <span>@(Model.Jogo?.TimeVisitante?.Sigla ?? "VIS")</span>
                    }
                </span>
                <h1>@Model.Jogo?.TimeVisitante?.Nome</h1>
            </div>
        </div>
    </section>

    <section class="futplay-detail-grid mt-4">
        <article class="futplay-detail-panel">
            <h2>Informações</h2>
            <dl>
                <dt>Liga</dt>
                <dd>@Model.Liga?.Nome</dd>
                <dt>Participante</dt>
                <dd>@Model.LigaParticipante?.Nome</dd>
                <dt>Data do palpite</dt>
                <dd>@Model.DataPalpite.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </article>

        <article class="futplay-detail-panel">
            <h2>Ações</h2>
            <div class="futplay-detail-actions">
                @if (User.IsInRole(AppRoles.Administrador))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="futplay-detail-primary">Editar</a>
                }
                <a asp-action="Index">Voltar para palpites</a>
            </div>
        </article>
    </section>
</div>
