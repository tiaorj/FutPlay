@model List<FutPlay.Models.Jogo>

@{
    ViewData["Title"] = "Jogos";
    var grupos = Model
        .GroupBy(j => j.Rodada.HasValue ? $"{j.Rodada}ª rodada" : j.DataJogo.ToString("dd/MM/yyyy"))
        .ToList();
}

<div class="container futplay-portal-shell">
    <section class="futplay-portal-header mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <div class="futplay-portal-kicker">Calendário esportivo</div>
                <h1 class="futplay-portal-title">Jogos</h1>
                <p class="futplay-portal-lead mb-0">
                    Agenda, resultados e placares dos campeonatos cadastrados no FutPlay.
                </p>
            </div>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <div class="futplay-portal-actions">
                    <a asp-action="Create">Novo jogo</a>
                </div>
            }
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="futplay-section-empty">Nenhum jogo cadastrado ainda.</div>
    }
    else
    {
        <section class="futplay-fixture-panel futplay-fixture-panel-wide">
            <div class="futplay-fixture-head">
                <span>‹</span>
                <h2>JOGOS</h2>
                <span>›</span>
            </div>

            @foreach (var grupo in grupos)
            {
                <div class="futplay-fixture-round">
                    <h3>@grupo.Key.ToUpperInvariant()</h3>

                    <div class="futplay-fixture-list">
                        @foreach (var jogo in grupo.OrderBy(j => j.DataJogo))
                        {
                            <article class="futplay-fixture-item futplay-fixture-item-row">
                                <div class="futplay-fixture-meta">
                                    <span>@jogo.Campeonato?.Nome</span>
                                    <strong>@jogo.DataJogo.ToString("dd/MM") · @jogo.DataJogo.ToString("HH:mm")</strong>
                                    @if (!string.IsNullOrWhiteSpace(jogo.Fase))
                                    {
                                        <span>@jogo.Fase</span>
                                    }
                                </div>

                                <div class="futplay-fixture-board">
                                    <div class="futplay-fixture-team">
                                        <span>@jogo.TimeCasa?.Nome</span>
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeCasa?.Sigla ?? "CAS")</span>
                                            }
                                        </span>
                                    </div>

                                    <strong class="futplay-fixture-versus">
                                        @(jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue ? $"{jogo.GolsCasa} x {jogo.GolsVisitante}" : "x")
                                    </strong>

                                    <div class="futplay-fixture-team">
                                        <span class="futplay-match-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                <span>@(jogo.TimeVisitante?.Sigla ?? "VIS")</span>
                                            }
                                        </span>
                                        <span>@jogo.TimeVisitante?.Nome</span>
                                    </div>
                                </div>

                                <div class="futplay-fixture-actions">
                                    <span class="futplay-match-status @(jogo.Status == "Finalizado" ? "futplay-match-status-finalizado" : "futplay-match-status-agendado")">
                                        @jogo.Status
                                    </span>
                                    <a asp-action="Details" asp-route-id="@jogo.Id">Fique por dentro</a>

                                    @if (User.IsInRole(AppRoles.Administrador))
                                    {
                                        <a asp-action="Edit" asp-route-id="@jogo.Id">Editar</a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </div>
            }
        </section>
    }
</div>
