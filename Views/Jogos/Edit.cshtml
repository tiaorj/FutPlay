@model FutPlay.Models.Jogo

@{
    ViewData["Title"] = "Editar Jogo";

    var returnUrl = ViewBag.ReturnUrl as string
        ?? Url.Action("Index", "Jogos", new { campeonatoId = Model.CampeonatoId, rodada = Model.Rodada })
        ?? "/Jogos";
    var editUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="container fp-score-home fp-admin-edit-page">
    <section class="fp-bet-header mb-3">
        <div class="fp-bet-header-info">
            <span>Administração de jogos</span>
            <h1>Editar jogo</h1>
            <p>Atualize data, status, times e resultado da partida.</p>
        </div>

        <div class="fp-bet-header-actions">
            @if (Model.CampeonatoId > 0)
            {
                <form asp-action="ImportarResultados" method="post" class="fp-inline-action-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="campeonatoId" value="@Model.CampeonatoId" />
                    <input type="hidden" name="returnUrl" value="@editUrl" />
                    <button type="submit">
                        Atualizar pela API
                    </button>
                </form>
            }

            <a href="@returnUrl">Voltar</a>
        </div>
    </section>

    <form asp-action="Edit" method="post" class="fp-admin-edit-form">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ApiFixtureId" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-lg-6">
                <section class="fp-home-card h-100">
                    <div class="fp-card-header-link">
                        <h2>Dados principais</h2>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="CampeonatoId" class="form-label"></label>
                            <select asp-for="CampeonatoId" class="form-select" asp-items="ViewBag.CampeonatoId">
                                <option value="">Selecione...</option>
                            </select>
                            <span asp-validation-for="CampeonatoId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Fase" class="form-label"></label>
                            <input asp-for="Fase" class="form-control" />
                            <span asp-validation-for="Fase" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Grupo" class="form-label"></label>
                            <input asp-for="Grupo" class="form-control" />
                            <span asp-validation-for="Grupo" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Rodada" class="form-label"></label>
                            <input asp-for="Rodada" class="form-control" />
                            <span asp-validation-for="Rodada" class="text-danger"></span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-lg-6">
                <section class="fp-home-card h-100">
                    <div class="fp-card-header-link">
                        <h2>Times</h2>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="TimeCasaId" class="form-label"></label>
                            <select asp-for="TimeCasaId" class="form-select" asp-items="ViewBag.TimeCasaId">
                                <option value="">Selecione...</option>
                            </select>
                            <span asp-validation-for="TimeCasaId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TimeVisitanteId" class="form-label"></label>
                            <select asp-for="TimeVisitanteId" class="form-select" asp-items="ViewBag.TimeVisitanteId">
                                <option value="">Selecione...</option>
                            </select>
                            <span asp-validation-for="TimeVisitanteId" class="text-danger"></span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-lg-6">
                <section class="fp-home-card h-100">
                    <div class="fp-card-header-link">
                        <h2>Data e status</h2>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-7">
                            <label asp-for="DataJogo" class="form-label"></label>
                            <input asp-for="DataJogo" class="form-control" type="datetime-local" />
                            <span asp-validation-for="DataJogo" class="text-danger"></span>
                        </div>

                        <div class="col-md-5">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Agendado">Agendado</option>
                                <option value="Em andamento">Em andamento</option>
                                <option value="Finalizado">Finalizado</option>
                                <option value="Cancelado">Cancelado</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch fp-admin-switch">
                                <input asp-for="Ativo" class="form-check-input" />
                                <label asp-for="Ativo" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-lg-6">
                <section class="fp-home-card h-100">
                    <div class="fp-card-header-link">
                        <h2>Resultado</h2>
                        @if (Model.ApiFixtureId.HasValue)
                        {
                            <span>API #@Model.ApiFixtureId</span>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="GolsCasa" class="form-label"></label>
                            <input asp-for="GolsCasa" class="form-control" />
                            <span asp-validation-for="GolsCasa" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GolsVisitante" class="form-label"></label>
                            <input asp-for="GolsVisitante" class="form-control" />
                            <span asp-validation-for="GolsVisitante" class="text-danger"></span>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <section class="fp-admin-edit-actions">
            <a href="@returnUrl" class="btn btn-outline-secondary">Voltar</a>
            <button type="submit" class="btn btn-success">Salvar alterações</button>
        </section>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
