<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - FutPlay</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FutPlay.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var isAdmin = User.IsInRole(AppRoles.Administrador);
        var isParticipante = User.IsInRole(AppRoles.Participante);
        var canUseParticipantArea = isAdmin || isParticipante;
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark futplay-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="futplay-brand-mark">⚽</span>
                    <span>FutPlay</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                        aria-controls="menuPrincipal" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-lg-1">

                        <li class="nav-item">
                            <a class="nav-link futplay-nav-pill @(currentController == "Home" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="Index">
                                Início
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link futplay-nav-pill @(currentController == "Campeonatos" ? "active" : "")"
                               asp-controller="Campeonatos"
                               asp-action="Index">
                                Campeonatos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link futplay-nav-pill @(currentController == "Jogos" ? "active" : "")"
                               asp-controller="Jogos"
                               asp-action="Index">
                                Jogos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link futplay-nav-pill @(currentController == "Times" ? "active" : "")"
                               asp-controller="Times"
                               asp-action="Index">
                                Times
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link futplay-nav-pill @(currentController == "Ligas" ? "active" : "")"
                               asp-controller="Ligas"
                               asp-action="Index">
                                Ligas
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link futplay-nav-pill @(currentController == "MinhasLigas" ? "active" : "")"
                                   asp-controller="MinhasLigas"
                                   asp-action="Index">
                                    Minhas Ligas
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link futplay-nav-pill"
                                   asp-controller="Ligas"
                                   asp-action="Create">
                                    Criar Liga
                                </a>
                            </li>
                            
                        }

                        @if (isAdmin)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle futplay-nav-pill futplay-admin-link @(currentController == "Importacoes" || currentController == "MockData" || currentController == "LigaParticipantes" || currentController == "Palpites" ? "active" : "")"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Admin
                                </a>

                                <ul class="dropdown-menu dropdown-menu-lg-end">
                                    <li>
                                        <h6 class="dropdown-header">Administração</h6>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Importacoes" asp-action="Index">
                                            Importações
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="MockData" asp-action="Index">
                                            Dados de Teste
                                        </a>
                                    </li>

                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="LigaParticipantes" asp-action="Index">
                                            Participantes
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Palpites" asp-action="Index">
                                            Palpites
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>

                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>
    </header>

    <main class="futplay-main">
        <div class="container mt-3">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Sucesso"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>
            }

            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Erro"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>
            }
        </div>

        @RenderBody()
    </main>

    <footer class="futplay-footer mt-5">
        <div class="container py-3 d-flex flex-column flex-md-row justify-content-between align-items-center">
            <span>
                &copy; @DateTime.Now.Year - FutPlay
            </span>

            <span class="text-muted small">
                Sistema de campeonatos, ligas, palpites e rankings de futebol.
            </span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
