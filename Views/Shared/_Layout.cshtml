@using FutPlay.Settings
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - @AppBrand.Name</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navigation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/competition-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bolao-palpites.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FutPlay.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var isAdmin = User.IsInRole(AppRoles.Administrador);
        var isParticipante = User.IsInRole(AppRoles.Participante);
        var canUseParticipantArea = isAdmin || isParticipante;
    }

    <header class="fp-sport-header">
        <nav class="navbar navbar-expand-lg navbar-dark futplay-navbar fp-sport-navbar">
            <div class="container">
                <a class="navbar-brand fp-sport-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="fp-sport-brand-ball">⚽</span>

                    <span>
                        <span class="fp-sport-brand-text">@AppBrand.Name</span>
                        <small>futebol & bolão</small>
                    </span>
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menuPrincipal"
                        aria-controls="menuPrincipal"
                        aria-expanded="false"
                        aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">

                    <div class="fp-top-search mx-lg-auto my-3 my-lg-0">
                        <span>🔎</span>
                        <input type="text"
                               class="form-control"
                               placeholder="Pesquise por partidas, competições, times e ligas"
                               disabled />
                    </div>

                    <div class="fp-top-login ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
        <div class="fp-sports-strip">
            <div class="container">
                <div class="fp-sports-strip-inner">

                    <div class="fp-sports-strip-scroll">

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="fp-sport-tab @(currentController == "Home" ? "active" : "")">
                            <span>🔥</span>
                            <strong>Em alta</strong>
                        </a>

                        @if (isAdmin)
                        {
                            <a asp-controller="Jogos"
                               asp-action="Index"
                               class="fp-sport-tab @(currentController == "Jogos" ? "active" : "")">
                                <span>⚽</span>
                                <strong>Jogos</strong>
                            </a>
                        }

                        <a asp-controller="Campeonatos"
                           asp-action="Index"
                           class="fp-sport-tab @(currentController == "Campeonatos" ? "active" : "")">
                            <span>🏆</span>
                            <strong>Competições</strong>
                        </a>

                        <a asp-controller="Times"
                           asp-action="Index"
                           class="fp-sport-tab @(currentController == "Times" ? "active" : "")">
                            <span>🛡️</span>
                            <strong>Times</strong>
                        </a>

                        <a asp-controller="Ligas"
                           asp-action="Index"
                           class="fp-sport-tab @(currentController == "Ligas" ? "active" : "")">
                            <span>🎯</span>
                            <strong>bolões</strong>
                        </a>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="MinhasLigas"
                               asp-action="Index"
                               class="fp-sport-tab @(currentController == "MinhasLigas" ? "active" : "")">
                                <span>📊</span>
                                <strong>Meus bolões</strong>
                            </a>

                            <a asp-controller="Ligas"
                               asp-action="Create"
                               class="fp-sport-tab">
                                <span>➕</span>
                                <strong>Criar liga</strong>
                            </a>
                        }

                    </div>

                    @if (isAdmin)
                    {
                        <div class="dropdown fp-sport-admin-dropdown">
                            <a class="fp-sport-tab dropdown-toggle @(currentController == "Importacoes" || currentController == "MockData" || currentController == "LigaParticipantes" || currentController == "Palpites" ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               data-bs-auto-close="outside"
                               aria-expanded="false">
                                <span>⚙️</span>
                                <strong>Admin</strong>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <h6 class="dropdown-header">Administração</h6>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Importacoes"
                                       asp-action="Index">
                                        Importações
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="MockData"
                                       asp-action="Index">
                                        Dados de Teste
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider" />
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="LigaParticipantes"
                                       asp-action="Index">
                                        Participantes
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Palpites"
                                       asp-action="Index">
                                        Palpites
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }

                </div>
            </div>
        </div>
    </header>

    <main class="futplay-main">
        <div class="container mt-3">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Sucesso"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>
            }

            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Erro"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>
            }
        </div>

        @RenderBody()
    </main>

    <footer class="futplay-footer mt-5">
        <div class="container py-3 d-flex flex-column flex-md-row justify-content-between align-items-center">
            <span>
                &copy; @DateTime.Now.Year - ⚽ @AppBrand.Name. Todos os direitos reservados.
            </span>

            <span class="text-muted small">
                Portal de futebol, campeonatos, ligas de palpites e rankings.
            </span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
