@using FutPlay.Settings
@{
    ViewData["Title"] = "Estatísticas";
}

<div class="container futplay-portal-shell">
    <section class="futplay-page-hero futplay-page-hero-dark mb-4">
        <div class="futplay-portal-kicker">Portal inteligente de futebol</div>
        <h1 class="futplay-page-title">Estatísticas</h1>
        <p class="futplay-subtitle mb-0">
            Compare equipes, acompanhe tendências das partidas, campanhas e indicadores para apoiar seus palpites no @AppBrand.Name.
        </p>
    </section>

    <section class="futplay-section-block">
        <div class="futplay-section-header">
            <h2 class="futplay-section-title">Ferramentas de análise</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <a asp-controller="Estatisticas"
                   asp-action="CompararTimes"
                   class="fp-stat-tool-card">
                    <span>Comparador</span>
                    <strong>Comparador de Times</strong>
                    <small>Compare desempenho, forma recente, ataque, defesa e classificação.</small>
                </a>
            </div>

            <div class="col-md-4">
                <div class="futplay-empty h-100">
                    Tendências por jogo
                </div>
            </div>

            <div class="col-md-4">
                <div class="futplay-empty h-100">
                    Campanhas por competição
                </div>
            </div>
        </div>
    </section>
</div>
