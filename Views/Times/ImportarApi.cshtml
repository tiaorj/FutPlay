@model List<FutPlay.ViewModels.ApiTimeViewModel>

@{
    ViewData["Title"] = "Importar Times da API";

    var tipoBusca = ViewBag.TipoBusca as string ?? "pais";
    var pais = ViewBag.Pais as string ?? "Brazil";
    var nome = ViewBag.Nome as string ?? "";
    var search = ViewBag.Search as string ?? "";
    var leagueId = ViewBag.LeagueId?.ToString() ?? "";
    var temporada = ViewBag.Temporada?.ToString() ?? DateTime.Today.Year.ToString();
}

<div class="container fp-score-home fp-api-import-page">
    <section class="fp-bet-header mb-3">
        <div class="fp-bet-header-info">
            <span>Administração</span>
            <h1>Importar times da API</h1>
            <p>Busque clubes e seleções na API-Football sem expor credenciais no navegador.</p>
        </div>

        <div class="fp-bet-header-actions">
            <a asp-action="Index">Voltar para Times</a>
        </div>
    </section>

    <section class="fp-home-card mb-3">
        <form asp-action="ImportarApi" method="post" class="fp-api-search-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="fp-api-search-mode" role="group" aria-label="Tipo de busca">
                <input type="radio" class="btn-check" name="tipoBusca" id="buscaPais" value="pais" checked="@(tipoBusca == "pais")" />
                <label class="btn btn-outline-primary" for="buscaPais">País</label>

                <input type="radio" class="btn-check" name="tipoBusca" id="buscaPaisNome" value="pais-nome" checked="@(tipoBusca == "pais-nome")" />
                <label class="btn btn-outline-primary" for="buscaPaisNome">País + Nome</label>

                <input type="radio" class="btn-check" name="tipoBusca" id="buscaNome" value="nome" checked="@(tipoBusca == "nome")" />
                <label class="btn btn-outline-primary" for="buscaNome">Nome</label>

                <input type="radio" class="btn-check" name="tipoBusca" id="buscaSearch" value="search" checked="@(tipoBusca == "search")" />
                <label class="btn btn-outline-primary" for="buscaSearch">Search</label>

                <input type="radio" class="btn-check" name="tipoBusca" id="buscaLiga" value="liga" checked="@(tipoBusca == "liga")" />
                <label class="btn btn-outline-primary" for="buscaLiga">Liga + temporada</label>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-lg-3 col-md-6">
                    <div class="fp-api-filter-card">
                        <label class="form-label" for="pais">País</label>
                        <input type="text"
                               id="pais"
                               name="pais"
                               value="@pais"
                               class="form-control"
                               placeholder="Brazil" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="fp-api-filter-card">
                        <label class="form-label" for="nome">Nome</label>
                        <input type="text"
                               id="nome"
                               name="nome"
                               value="@nome"
                               class="form-control"
                               placeholder="Flamengo" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="fp-api-filter-card">
                        <label class="form-label" for="search">Search</label>
                        <input type="text"
                               id="search"
                               name="search"
                               value="@search"
                               class="form-control"
                               placeholder="Manch" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="fp-api-filter-card">
                        <div class="row g-2">
                            <div class="col-7">
                                <label class="form-label" for="leagueId">Liga</label>
                                <input type="number"
                                       id="leagueId"
                                       name="leagueId"
                                       value="@leagueId"
                                       class="form-control"
                                       min="1" />
                            </div>

                            <div class="col-5">
                                <label class="form-label" for="temporada">Temporada</label>
                                <input type="number"
                                       id="temporada"
                                       name="temporada"
                                       value="@temporada"
                                       class="form-control"
                                       min="1900" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="fp-api-search-actions">
                <button type="submit" class="btn btn-success">Buscar times</button>
                <a asp-action="ImportarApi" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </form>
    </section>

    <section class="fp-home-card">
        <div class="fp-card-header-link">
            <h2>Resultado da busca</h2>
            <span>@Model.Count time(s)</span>
        </div>

        @if (!Model.Any())
        {
            <div class="fp-empty-mini">
                Nenhum time encontrado para os filtros informados.
            </div>
        }
        else
        {
            <div class="table-responsive d-none d-md-block">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Escudo</th>
                            <th>Time</th>
                            <th>País</th>
                            <th>API ID</th>
                            <th>Status</th>
                            <th class="text-end">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var time in Model)
                        {
                            <tr>
                                <td style="width: 70px;">
                                    @if (!string.IsNullOrWhiteSpace(time.EscudoUrl))
                                    {
                                        <img src="@time.EscudoUrl"
                                             alt="@time.Nome"
                                             class="fp-api-team-crest" />
                                    }
                                    else
                                    {
                                        <span class="fp-mini-crest">FP</span>
                                    }
                                </td>

                                <td>
                                    <strong>@time.Nome</strong>
                                </td>

                                <td>@time.Pais</td>
                                <td>@time.ApiTeamId</td>

                                <td>
                                    @if (time.JaImportado)
                                    {
                                        <span class="badge bg-secondary">Já importado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Novo</span>
                                    }
                                </td>

                                <td class="text-end">
                                    @await Html.PartialAsync("_ImportarTimeApiForm", time, new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                                    {
                                        ["TipoBusca"] = tipoBusca,
                                        ["Pais"] = pais,
                                        ["Nome"] = nome,
                                        ["Search"] = search,
                                        ["LeagueId"] = leagueId,
                                        ["Temporada"] = temporada
                                    })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="fp-api-team-card-list d-md-none">
                @foreach (var time in Model)
                {
                    <article class="fp-api-team-card">
                        <div class="fp-api-team-card-main">
                            <span class="fp-api-team-crest-wrap">
                                @if (!string.IsNullOrWhiteSpace(time.EscudoUrl))
                                {
                                    <img src="@time.EscudoUrl" alt="@time.Nome" class="fp-api-team-crest" />
                                }
                                else
                                {
                                    <span class="fp-mini-crest">FP</span>
                                }
                            </span>

                            <div>
                                <strong>@time.Nome</strong>
                                <span>@(string.IsNullOrWhiteSpace(time.Pais) ? "País não informado" : time.Pais)</span>
                                <small>API ID @time.ApiTeamId</small>
                            </div>
                        </div>

                        <div class="fp-api-team-card-actions">
                            @if (time.JaImportado)
                            {
                                <span class="badge bg-secondary">Já importado</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Novo</span>
                            }

                            @await Html.PartialAsync("_ImportarTimeApiForm", time, new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                            {
                                ["TipoBusca"] = tipoBusca,
                                ["Pais"] = pais,
                                ["Nome"] = nome,
                                ["Search"] = search,
                                ["LeagueId"] = leagueId,
                                ["Temporada"] = temporada
                            })
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>
