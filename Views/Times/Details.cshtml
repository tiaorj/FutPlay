@model FutPlay.Models.Time

@{
    ViewData["Title"] = "Detalhes do Time/Seleção";
}

<div class="container futplay-portal-shell">
    <section class="futplay-detail-match">
        <div class="futplay-detail-scoreboard futplay-detail-scoreboard-single">
            <div class="futplay-detail-team">
                <span class="futplay-detail-crest futplay-detail-crest-large">
                    @if (!string.IsNullOrWhiteSpace(Model.EscudoUrl))
                    {
                        <img src="@Model.EscudoUrl" alt="@Model.Nome" />
                    }
                    else
                    {
                        <span>@(Model.Sigla ?? "FC")</span>
                    }
                </span>
                <h1>@Model.Nome</h1>
                <p>@Model.Tipo</p>
            </div>
        </div>
    </section>

    <section class="futplay-detail-grid mt-4">
        <article class="futplay-detail-panel">
            <h2>Ficha do time</h2>
            <dl>
                <dt>Sigla</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Sigla) ? "-" : Model.Sigla)</dd>
                <dt>País</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Pais) ? "-" : Model.Pais)</dd>
                <dt>Status</dt>
                <dd>@(Model.Ativo ? "Ativo" : "Inativo")</dd>
            </dl>
        </article>

        <article class="futplay-detail-panel">
            <h2>Ações</h2>
            <div class="futplay-detail-actions">
                @if (User.IsInRole(AppRoles.Administrador))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="futplay-detail-primary">Editar time</a>
                }
                <a asp-action="Index">Voltar para times</a>
            </div>
        </article>
    </section>
</div>
