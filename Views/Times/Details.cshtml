@model FutPlay.ViewModels.TimeDetalhesViewModel
@using FutPlay.Settings
@{
    ViewData["Title"] = Model.Time.Nome;
}

<div class="container fp-score-home">

    <section class="fp-team-profile-header mb-3">
        <div class="fp-team-profile-logo">
            @if (!string.IsNullOrWhiteSpace(Model.Time.EscudoUrl))
            {
                <img src="@Model.Time.EscudoUrl" alt="@Model.Time.Nome" />
            }
            else
            {
                <span>@(Model.Time.Sigla ?? "FC")</span>
            }
        </div>

        <div class="fp-team-profile-info">
            <span>@Model.Time.Tipo</span>
            <h1>@Model.Time.Nome</h1>
            <p>
                @(string.IsNullOrWhiteSpace(Model.Time.Pais) ? "País não informado" : Model.Time.Pais)

                @if (!string.IsNullOrWhiteSpace(Model.Time.Sigla))
                {
                    <span> · @Model.Time.Sigla</span>
                }
            </p>
        </div>

        <div class="fp-team-profile-actions">
            @if (User.IsInRole(AppRoles.Administrador))
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.Time.Id">
                    Editar
                </a>
            }

            <a asp-action="Index">
                Times
            </a>
        </div>
    </section>

    <section class="fp-team-stat-strip mb-3">
        <article>
            <span>Jogos</span>
            <strong>@Model.TotalJogos</strong>
        </article>

        <article>
            <span>Vitórias</span>
            <strong>@Model.TotalVitorias</strong>
        </article>

        <article>
            <span>Empates</span>
            <strong>@Model.TotalEmpates</strong>
        </article>

        <article>
            <span>Derrotas</span>
            <strong>@Model.TotalDerrotas</strong>
        </article>

        <article>
            <span>Gols Pró</span>
            <strong>@Model.GolsPro</strong>
        </article>

        <article>
            <span>Saldo</span>
            <strong>@Model.SaldoGols</strong>
        </article>
    </section>

    <div class="row g-3">

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a class="active" href="#">Jogos</a>
                    <a href="#">Resultados</a>
                    <a href="#">Competições</a>
                </div>

                <div class="fp-score-filter-row">
                    <span class="fp-score-filter active">Agenda</span>
                    <span class="fp-score-filter">@Model.ProximosJogos.Count próximos</span>
                    <span class="fp-score-filter">@Model.UltimosResultados.Count resultados</span>
                </div>

                <div class="fp-match-list-title">
                    <span>⚽ Próximos jogos</span>
                    <small>@Model.ProximosJogos.Count jogo(s)</small>
                </div>

                @if (!Model.ProximosJogos.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Nenhum jogo futuro encontrado para este time.
                    </div>
                }
                else
                {
                    <div class="fp-score-match-list">
                        @foreach (var jogo in Model.ProximosJogos)
                        {
                            var casaSigla = !string.IsNullOrWhiteSpace(jogo.TimeCasa?.Sigla)
                            ? jogo.TimeCasa.Sigla
                            : "CAS";

                            var visitanteSigla = !string.IsNullOrWhiteSpace(jogo.TimeVisitante?.Sigla)
                            ? jogo.TimeVisitante.Sigla
                            : "VIS";

                            <article class="fp-score-match-row fp-score-match-row-full">
                                <div class="fp-score-match-time">
                                    <strong>@jogo.DataJogo.ToString("HH:mm")</strong>
                                    <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                </div>

                                <div class="fp-score-match-clubs">
                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                @casaSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeCasa?.Nome</span>
                                    </div>

                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                @visitanteSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeVisitante?.Nome</span>
                                    </div>
                                </div>

                                <div class="fp-score-match-score">
                                    <strong>-</strong>
                                    <strong>-</strong>
                                </div>

                                <div class="fp-score-match-extra">
                                    <span class="fp-status scheduled">@jogo.Status</span>

                                    <a asp-controller="Jogos"
                                       asp-action="Details"
                                       asp-route-id="@jogo.Id">
                                        Detalhes
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }

                <div class="fp-match-list-title">
                    <span>✅ Últimos resultados</span>
                    <small>@Model.UltimosResultados.Count jogo(s)</small>
                </div>

                @if (!Model.UltimosResultados.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Nenhum resultado encontrado para este time.
                    </div>
                }
                else
                {
                    <div class="fp-score-match-list">
                        @foreach (var jogo in Model.UltimosResultados)
                        {
                            var casaSigla = !string.IsNullOrWhiteSpace(jogo.TimeCasa?.Sigla)
                            ? jogo.TimeCasa.Sigla
                            : "CAS";

                            var visitanteSigla = !string.IsNullOrWhiteSpace(jogo.TimeVisitante?.Sigla)
                            ? jogo.TimeVisitante.Sigla
                            : "VIS";

                            <article class="fp-score-match-row fp-score-match-row-full">
                                <div class="fp-score-match-time">
                                    <strong>@jogo.DataJogo.ToString("HH:mm")</strong>
                                    <span>@jogo.DataJogo.ToString("dd/MM")</span>
                                </div>

                                <div class="fp-score-match-clubs">
                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeCasa?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeCasa.EscudoUrl" alt="@jogo.TimeCasa.Nome" />
                                            }
                                            else
                                            {
                                                @casaSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeCasa?.Nome</span>
                                    </div>

                                    <div class="fp-score-club">
                                        <span class="fp-mini-crest">
                                            @if (!string.IsNullOrWhiteSpace(jogo.TimeVisitante?.EscudoUrl))
                                            {
                                                <img src="@jogo.TimeVisitante.EscudoUrl" alt="@jogo.TimeVisitante.Nome" />
                                            }
                                            else
                                            {
                                                @visitanteSigla
                                            }
                                        </span>

                                        <span>@jogo.TimeVisitante?.Nome</span>
                                    </div>
                                </div>

                                <div class="fp-score-match-score">
                                    @if (jogo.GolsCasa.HasValue && jogo.GolsVisitante.HasValue)
                                    {
                                        <strong>@jogo.GolsCasa</strong>
                                        <strong>@jogo.GolsVisitante</strong>
                                    }
                                    else
                                    {
                                        <strong>-</strong>
                                        <strong>-</strong>
                                    }
                                </div>

                                <div class="fp-score-match-extra">
                                    <span class="fp-status finished">@jogo.Status</span>

                                    <a asp-controller="Jogos"
                                       asp-action="Details"
                                       asp-route-id="@jogo.Id">
                                        Detalhes
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </main>

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Ficha</h2>
                </div>

                <dl class="fp-team-info-list">
                    <dt>Nome</dt>
                    <dd>@Model.Time.Nome</dd>

                    <dt>Sigla</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Time.Sigla) ? "-" : Model.Time.Sigla)</dd>

                    <dt>País</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Time.Pais) ? "-" : Model.Time.Pais)</dd>

                    <dt>Tipo</dt>
                    <dd>@Model.Time.Tipo</dd>

                    <dt>Status</dt>
                    <dd>@(Model.Time.Ativo ? "Ativo" : "Inativo")</dd>

                    <dt>ID API</dt>
                    <dd>@(Model.Time.ApiTeamId.HasValue? Model.Time.ApiTeamId.Value.ToString() : "-")</dd>
                </dl>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Competições</h2>
                </div>

                @if (!Model.Campeonatos.Any())
                {
                    <div class="fp-empty-mini">
                        Nenhum campeonato encontrado para este time.
                    </div>
                }
                else
                {
                    <div class="fp-public-league-mini-list">
                        @foreach (var campeonato in Model.Campeonatos)
                        {
                            <article class="fp-public-league-mini">
                                <div>
                                    <strong>@campeonato.Nome @campeonato.Ano</strong>
                                    <span>@campeonato.Tipo</span>
                                </div>

                                <a asp-controller="Campeonatos"
                                   asp-action="Portal"
                                   asp-route-id="@campeonato.Id">
                                    Portal
                                </a>
                            </article>
                        }
                    </div>
                }
            </section>
        </aside>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>@AppBrand.Name</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações rápidas</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="Jogos"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Ver jogos
                    </a>

                    <a asp-controller="Campeonatos"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Competições
                    </a>

                    <a asp-action="Index"
                       class="btn btn-success">
                        Times
                    </a>
                </div>
            </section>
        </aside>

    </div>
</div>