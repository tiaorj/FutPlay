@model FutPlay.Models.Time

@{
    ViewData["Title"] = "Editar Time/Seleção";
}

<div class="container mt-4">
    <h1>Editar Time/Seleção</h1>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Sigla" class="form-label"></label>
                    <input asp-for="Sigla" class="form-control" />
                    <span asp-validation-for="Sigla" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Pais" class="form-label"></label>
                    <input asp-for="Pais" class="form-control" />
                    <span asp-validation-for="Pais" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label"></label>
                    <select asp-for="Tipo" class="form-select">
                        <option value="">Selecione...</option>
                        <option value="Seleção">Seleção</option>
                        <option value="Clube">Clube</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EscudoUrl" class="form-label"></label>
                    <input asp-for="EscudoUrl" class="form-control" />
                    <span asp-validation-for="EscudoUrl" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Salvar Alterações
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}