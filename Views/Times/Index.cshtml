@model List<FutPlay.Models.Time>

@{
    ViewData["Title"] = "Times e Seleções";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Times e Seleções</h1>
            <p class="text-muted mb-0">
                Cadastre clubes e seleções usados nos campeonatos.
            </p>
        </div>

        @if (User.IsInRole(AppRoles.Administrador))
        {
            <a asp-action="Create" class="btn btn-success">
                Novo Time/Seleção
            </a>
        }
    </div>

    <div class="row">
        @foreach (var time in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            @time.Nome
                            @if (!string.IsNullOrWhiteSpace(time.Sigla))
                            {
                                <small class="text-muted">(@time.Sigla)</small>
                            }
                        </h5>

                        <p class="card-text mb-1">
                            <strong>Tipo:</strong> @time.Tipo
                        </p>

                        @if (!string.IsNullOrWhiteSpace(time.Pais))
                        {
                            <p class="card-text mb-1">
                                <strong>País:</strong> @time.Pais
                            </p>
                        }

                        <p class="card-text mt-2">
                            @if (time.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </p>

                        <div class="futplay-actions">
                            <a asp-action="Details" asp-route-id="@time.Id" class="btn btn-outline-primary btn-sm">
                                Detalhes
                            </a>

                            @if (User.IsInRole(AppRoles.Administrador))
                            {
                                <a asp-action="Edit" asp-route-id="@time.Id" class="btn btn-outline-success btn-sm">
                                    Editar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
