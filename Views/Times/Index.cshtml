@model FutPlay.ViewModels.TimesIndexViewModel
@using FutPlay.Settings

@{
    ViewData["Title"] = "Times e Seleções";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var grupos = Model.Times
        .GroupBy(t => string.IsNullOrWhiteSpace(t.Tipo) ? "Times" : t.Tipo)
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="container fp-score-home">

    <div class="fp-score-page-title d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>Clubes e seleções usados nos campeonatos, jogos e classificações</span>

        @if (User.IsInRole(AppRoles.Administrador))
        {
            <a asp-action="Create" class="fp-score-admin-link">
                + Novo time/seleção
            </a>
        }
    </div>

    <div class="row g-3">

        <aside class="col-xl-3 col-lg-4">
            <section class="fp-home-card">
                <div class="fp-card-header-link">
                    <h2>Resumo</h2>
                </div>

                <div class="fp-score-stats-list">
                    <div>
                        <span>Total</span>
                        <strong>@Model.TotalTimes</strong>
                    </div>

                    <div>
                        <span>Ativos</span>
                        <strong>@Model.TotalAtivos</strong>
                    </div>

                    <div>
                        <span>Clubes</span>
                        <strong>@Model.TotalClubes</strong>
                    </div>

                    <div>
                        <span>Favoritos</span>
                        <strong>@Model.TotalFavoritos</strong>
                    </div>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Filtros</h2>
                </div>

                <div class="fp-score-filter-column">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="todos"
                       class="fp-score-filter @(Model.Filtro == "todos" ? "active" : "")">
                        Todos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="clubes"
                       class="fp-score-filter @(Model.Filtro == "clubes" ? "active" : "")">
                        Clubes
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="selecoes"
                       class="fp-score-filter @(Model.Filtro == "selecoes" ? "active" : "")">
                        Seleções
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="ativos"
                       class="fp-score-filter @(Model.Filtro == "ativos" ? "active" : "")">
                        Ativos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="favoritos"
                       class="fp-score-filter @(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos
                    </a>
                </div>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>País</h2>
                </div>

                <form asp-action="Index" method="get" class="fp-compact-filter-form">
                    <input type="hidden" name="filtro" value="@Model.Filtro" />

                    <select class="form-select form-select-sm" name="pais" onchange="this.form.submit()">
                        <option value="">Todos os países</option>
                        @foreach (var pais in Model.Paises)
                        {
                            <option value="@pais" selected="@(string.Equals(Model.Pais, pais, StringComparison.OrdinalIgnoreCase))">
                                @pais
                            </option>
                        }
                    </select>

                    <button class="btn btn-sm btn-outline-primary" type="submit">Aplicar</button>
                </form>
            </section>
        </aside>

        <main class="col-xl-6 col-lg-8">
            <section class="fp-score-board">
                <div class="fp-score-board-tabs">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="todos"
                       class="@(Model.Filtro != "favoritos" ? "active" : "")">
                        Todos
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="favoritos"
                       class="@(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos
                    </a>

                    <a asp-controller="Campeonatos" asp-action="Index">
                        Competições
                    </a>
                </div>

                <div class="fp-score-filter-row">
                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="todos"
                       class="fp-score-filter @(Model.Filtro == "todos" ? "active" : "")">
                        Todos (@Model.TotalTimes)
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="clubes"
                       class="fp-score-filter @(Model.Filtro == "clubes" ? "active" : "")">
                        Clubes (@Model.TotalClubes)
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="selecoes"
                       class="fp-score-filter @(Model.Filtro == "selecoes" ? "active" : "")">
                        Seleções (@Model.TotalSelecoes)
                    </a>

                    <a asp-action="Index"
                       asp-route-pais="@Model.Pais"
                       asp-route-filtro="favoritos"
                       class="fp-score-filter @(Model.Filtro == "favoritos" ? "active" : "")">
                        Favoritos (@Model.TotalFavoritos)
                    </a>
                </div>

                @if (Model.Filtro == "favoritos" && !Model.UsuarioAutenticado)
                {
                    <div class="fp-empty-mini m-3">
                        Entre na sua conta para ver e salvar seus times favoritos.
                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@returnUrl">
                            Fazer login
                        </a>
                    </div>
                }
                else if (!Model.Times.Any())
                {
                    <div class="fp-empty-mini m-3">
                        Nenhum time encontrado para estes filtros.
                    </div>
                }
                else
                {
                    <div class="fp-team-app-list">
                        @foreach (var grupo in grupos)
                        {
                            <div class="fp-match-list-title">
                                <span>@grupo.Key</span>
                                <small>@grupo.Count() time(s)</small>
                            </div>

                            @foreach (var time in grupo.OrderBy(t => t.Nome))
                            {
                                var favorito = Model.TimesFavoritosIds.Contains(time.Id);

                                <article class="fp-team-app-row">
                                    <div class="fp-team-app-logo">
                                        @if (!string.IsNullOrWhiteSpace(time.EscudoUrl))
                                        {
                                            <img src="@time.EscudoUrl" alt="@time.Nome" />
                                        }
                                        else
                                        {
                                            <span>@(time.Sigla ?? "FC")</span>
                                        }
                                    </div>

                                    <div class="fp-team-app-info">
                                        <strong>@time.Nome</strong>
                                        <span>
                                            @(string.IsNullOrWhiteSpace(time.Pais) ? "País não informado" : time.Pais)

                                            @if (!string.IsNullOrWhiteSpace(time.Sigla))
                                            {
                                                <span> · @time.Sigla</span>
                                            }

                                            @if (!time.Ativo)
                                            {
                                                <span> · Inativo</span>
                                            }
                                        </span>
                                    </div>

                                    <div class="fp-team-app-actions">
                                        <form asp-action="AlternarFavorito"
                                              method="post"
                                              class="fp-inline-favorite-form">
                                            <input type="hidden" name="id" value="@time.Id" />
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit"
                                                    class="fp-favorite-button @(favorito ? "active" : "")"
                                                    title="@(favorito ? "Remover dos favoritos" : "Adicionar aos favoritos")">
                                                @(favorito ? "★" : "☆")
                                            </button>
                                        </form>

                                        <a asp-action="Details" asp-route-id="@time.Id">
                                            Detalhes
                                        </a>

                                        @if (User.IsInRole(AppRoles.Administrador))
                                        {
                                            <a asp-action="Edit" asp-route-id="@time.Id">
                                                Editar
                                            </a>
                                        }
                                    </div>
                                </article>
                            }
                        }
                    </div>
                }
            </section>
        </main>

        <aside class="col-xl-3 d-none d-xl-block">
            <section class="fp-side-ad">
                <span>Publicidade</span>
                <strong>@AppBrand.Name</strong>
                <p>Espaço reservado para anúncio, destaque ou patrocinador.</p>
            </section>

            <section class="fp-home-card mt-3">
                <div class="fp-card-header-link">
                    <h2>Ações rápidas</h2>
                </div>

                <div class="d-grid gap-2">
                    <a asp-controller="Jogos"
                       asp-action="Index"
                       asp-route-aba="favoritos"
                       class="btn btn-outline-primary">
                        Jogos dos favoritos
                    </a>

                    <a asp-controller="Campeonatos"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        Competições
                    </a>

                    <a asp-controller="Ligas"
                       asp-action="Index"
                       class="btn btn-success">
                        Ligas públicas
                    </a>
                </div>
            </section>
        </aside>

    </div>
</div>
