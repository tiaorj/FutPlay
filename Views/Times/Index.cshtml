@model List<FutPlay.Models.Time>

@{
    ViewData["Title"] = "Times e Seleções";
    var grupos = Model.GroupBy(t => t.Tipo).OrderBy(g => g.Key).ToList();
}

<div class="container futplay-portal-shell">
    <section class="futplay-portal-header mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <div class="futplay-portal-kicker">Elencos e escudos</div>
                <h1 class="futplay-portal-title">Times e Seleções</h1>
                <p class="futplay-portal-lead mb-0">
                    Clubes e seleções usados nos campeonatos, jogos e classificações.
                </p>
            </div>

            @if (User.IsInRole(AppRoles.Administrador))
            {
                <div class="futplay-portal-actions">
                    <a asp-action="Create">Novo time/seleção</a>
                </div>
            }
        </div>
    </section>

    @foreach (var grupo in grupos)
    {
        <section class="futplay-team-section mb-4">
            <div class="futplay-team-section-head">
                <h2>@grupo.Key</h2>
                <span>@grupo.Count() times</span>
            </div>

            <div class="futplay-team-grid">
                @foreach (var time in grupo)
                {
                    <article class="futplay-team-card">
                        <div class="futplay-detail-crest">
                            @if (!string.IsNullOrWhiteSpace(time.EscudoUrl))
                            {
                                <img src="@time.EscudoUrl" alt="@time.Nome" />
                            }
                            else
                            {
                                <span>@(time.Sigla ?? "FC")</span>
                            }
                        </div>

                        <div>
                            <h3>@time.Nome</h3>
                            <p>
                                @(string.IsNullOrWhiteSpace(time.Pais) ? "País não informado" : time.Pais)
                                @if (!string.IsNullOrWhiteSpace(time.Sigla))
                                {
                                    <span> · @time.Sigla</span>
                                }
                            </p>
                        </div>

                        <div class="futplay-team-actions">
                            <a asp-action="Details" asp-route-id="@time.Id">Detalhes</a>
                            @if (User.IsInRole(AppRoles.Administrador))
                            {
                                <a asp-action="Edit" asp-route-id="@time.Id">Editar</a>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>
