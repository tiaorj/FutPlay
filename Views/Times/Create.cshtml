@model FutPlay.Models.Time

@{
    ViewData["Title"] = "Novo Time/Seleção";
}

<div class="container mt-4">
    <h1>Novo Time/Seleção</h1>

    <p class="text-muted">
        Cadastre clubes ou seleções para uso nos campeonatos.
    </p>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Brasil, Argentina, Flamengo" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Sigla" class="form-label"></label>
                    <input asp-for="Sigla" class="form-control" placeholder="Ex: BRA, ARG, FLA" />
                    <span asp-validation-for="Sigla" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Pais" class="form-label"></label>
                    <input asp-for="Pais" class="form-control" placeholder="Ex: Brasil" />
                    <span asp-validation-for="Pais" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label"></label>
                    <select asp-for="Tipo" class="form-select">
                        <option value="">Selecione...</option>
                        <option value="Seleção">Seleção</option>
                        <option value="Clube">Clube</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EscudoUrl" class="form-label"></label>
                    <input asp-for="EscudoUrl" class="form-control" placeholder="URL da imagem do escudo, opcional" />
                    <span asp-validation-for="EscudoUrl" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label"></label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Salvar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}