@using FutPlay.Settings
@{
    ViewData["Title"] = "Comunidade";
}

<div class="container futplay-portal-shell">
    <section class="futplay-page-hero futplay-page-hero-dark mb-4">
        <div class="futplay-portal-kicker">Torcida, rankings e palpites</div>
        <h1 class="futplay-page-title">Comunidade</h1>
        <p class="futplay-subtitle mb-0">
            Área em construção. Este espaço vai reunir interações da comunidade, destaques
            dos participantes, ligas em evidência e conversas em torno dos jogos no @AppBrand.Name.
        </p>
    </section>

    <section class="futplay-section-block">
        <div class="futplay-section-header">
            <h2 class="futplay-section-title">Em breve</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="futplay-empty h-100">
                    Ligas em destaque
                </div>
            </div>

            <div class="col-md-4">
                <div class="futplay-empty h-100">
                    Participantes da rodada
                </div>
            </div>

            <div class="col-md-4">
                <div class="futplay-empty h-100">
                    Discussões da comunidade
                </div>
            </div>
        </div>
    </section>
</div>
