@page
@model FutPlay.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    ViewData["Title"] = "Recuperar senha";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container fp-score-home">

    <section class="fp-auth-page">

        <div class="fp-auth-hero fp-auth-hero-password">
            <div class="fp-auth-brand">
                <span>⚽</span>
                <strong>FutPlay</strong>
            </div>

            <div class="fp-auth-hero-content">
                <span class="fp-auth-kicker">Recuperação de acesso</span>

                <h1>Volte para o jogo</h1>

                <p>
                    Informe seu e-mail para receber as instruções de recuperação
                    e continuar acompanhando seus bolões.
                </p>
            </div>

            <div class="fp-auth-match-card">
                <div class="fp-auth-match-header">
                    <span>Acesso FutPlay</span>
                    <small>Segurança</small>
                </div>

                <div class="fp-auth-match-board">
                    <div>
                        <span class="fp-auth-crest">🔐</span>
                        <strong>Conta</strong>
                    </div>

                    <b>→</b>

                    <div>
                        <span class="fp-auth-crest">📩</span>
                        <strong>E-mail</strong>
                    </div>
                </div>

                <div class="fp-auth-match-footer">
                    Enviaremos as instruções para seu e-mail
                </div>
            </div>
        </div>

        <div class="fp-auth-card">
            <div class="fp-auth-card-head">
                <span>Senha</span>
                <h2>Recuperar senha</h2>
                <p>Digite seu e-mail para receber o link de redefinição.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control fp-auth-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="nome@exemplo.com" />

                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <button type="submit" class="fp-auth-submit">
                    Enviar instruções
                </button>

                <div class="fp-auth-register-box">
                    <span>Lembrou sua senha?</span>

                    <a asp-page="./Login">
                        Voltar para o login
                    </a>
                </div>
            </form>
        </div>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}