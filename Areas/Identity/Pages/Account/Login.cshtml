@page
@model FutPlay.Areas.Identity.Pages.Account.LoginModel
@using FutPlay.Settings
@{
    ViewData["Title"] = "Entrar";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container fp-score-home">

    <section class="fp-auth-page">

        <div class="fp-auth-hero">
            <div class="fp-auth-brand">
                <span>⚽</span>
                <strong>Meu Pitaco FC</strong>
            </div>

            <div class="fp-auth-hero-content">
                <span class="fp-auth-kicker">Portal de futebol e bolões</span>

                <h1>Entre no seu bolão</h1>

                <p>
                    Acesse suas ligas, envie palpites, acompanhe rankings e fique por dentro dos jogos.
                </p>
            </div>

            <div class="fp-auth-match-card">
                <div class="fp-auth-match-header">
                    <span>Próximo palpite</span>
                    <small>Meu Pitaco FC</small>
                </div>

                <div class="fp-auth-match-board">
                    <div>
                        <span class="fp-auth-crest">CAS</span>
                        <strong>Casa</strong>
                    </div>

                    <b>x</b>

                    <div>
                        <span class="fp-auth-crest">VIS</span>
                        <strong>Visitante</strong>
                    </div>
                </div>

                <div class="fp-auth-match-footer">
                    Palpite antes do jogo começar
                </div>
            </div>
        </div>

        <div class="fp-auth-card">
            <div class="fp-auth-card-head">
                <span>Login</span>
                <h2>Entrar no Meu Pitaco FC</h2>
                <p>Use seu e-mail e senha para continuar.</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control fp-auth-input"
                           autocomplete="username"
                           placeholder="nome@exemplo.com" />

                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password"
                           class="form-control fp-auth-input"
                           autocomplete="current-password"
                           placeholder="senha" />

                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="fp-auth-options mb-3">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe"></label>
                    </div>

                    <a asp-page="./ForgotPassword">
                        Esqueci minha senha
                    </a>
                </div>

                <button id="login-submit" type="submit" class="fp-auth-submit">
                    Entrar
                </button>

                <div class="fp-auth-register-box">
                    <span>Ainda não tem conta?</span>

                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                        Criar conta grátis
                    </a>
                </div>
            </form>
        </div>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}