@page
@model FutPlay.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Criar conta";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container fp-score-home">

    <section class="fp-auth-page">

        <div class="fp-auth-hero fp-auth-hero-register">
            <div class="fp-auth-brand">
                <span>⚽</span>
                <strong>FutPlay</strong>
            </div>

            <div class="fp-auth-hero-content">
                <span class="fp-auth-kicker">Crie sua conta</span>

                <h1>Entre para o jogo</h1>

                <p>
                    Crie sua conta para participar de ligas, enviar palpites,
                    acompanhar rankings e disputar bolões com amigos.
                </p>
            </div>

            <div class="fp-auth-match-card">
                <div class="fp-auth-match-header">
                    <span>Seu primeiro bolão</span>
                    <small>FutPlay</small>
                </div>

                <div class="fp-auth-match-board">
                    <div>
                        <span class="fp-auth-crest">VOCÊ</span>
                        <strong>Você</strong>
                    </div>

                    <b>x</b>

                    <div>
                        <span class="fp-auth-crest">AMG</span>
                        <strong>Amigos</strong>
                    </div>
                </div>

                <div class="fp-auth-match-footer">
                    Crie sua conta e comece a palpitar
                </div>
            </div>
        </div>

        <div class="fp-auth-card">
            <div class="fp-auth-card-head">
                <span>Cadastro</span>
                <h2>Criar conta grátis</h2>
                <p>Informe seus dados para acessar o FutPlay.</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control fp-auth-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="nome@exemplo.com" />

                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password"
                           class="form-control fp-auth-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="senha" />

                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control fp-auth-input"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="confirmar senha" />

                    <label asp-for="Input.ConfirmPassword"></label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="fp-auth-submit">
                    Criar conta
                </button>

                <div class="fp-auth-register-box">
                    <span>Já tem uma conta?</span>

                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                        Entrar no FutPlay
                    </a>
                </div>
            </form>
        </div>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}